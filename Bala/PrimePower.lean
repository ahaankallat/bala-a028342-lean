import Bala.ProductCongruence

/-!
# Proposition 4.2 (`prop:primepower`): prime-power residues of `a`

This file formalizes Section 4 of `main.tex` ("Prime-power residues"):
`a(p^r) ≡ -1 (mod p^r)` for odd primes `p`, and `a(2) ≡ 1 (mod 2)`, `a(4) ≡ 3 (mod 4)`,
`a(2^r) ≡ 1 (mod 2^r)` for `r ≥ 3`.

See the bottom of the file for the overall status summary.
-/

noncomputable section

open Equiv Equiv.Perm

/-! ### The two small `p = 2` base cases: direct computation -/

/-- `a 2 = 3` and `a 4 = 59`, by direct computation from the recurrence in `Bala/Basic.lean`. -/
theorem a_two_eq : a 2 = 3 := by decide

theorem a_four_eq : a 4 = 59 := by decide

/-- **Proposition 4.2, `p = 2`, `r = 1`**: `a(2) ≡ 1 (mod 2)`. -/
theorem primepower_two_one' : (2 : ℤ) ∣ (a 2 - 1) := by
  rw [a_two_eq]; decide

/-- **Proposition 4.2, `p = 2`, `r = 2`**: `a(4) ≡ 3 (mod 4)`. -/
theorem primepower_two_two' : (4 : ℤ) ∣ (a 4 - 3) := by
  rw [a_four_eq]; decide

/-! ## Section 4.1 (`Setup`): the full rotation action of `C_N = ZMod N` on colored permutations
of `ZMod N` by conjugation, and the reduction `a(p^r) ≡ |X_N^H| (mod p^r)`.

This mirrors `rotPerm`/`rotAddAction`/`mixed_stabilizer_trivial` from `ProductCongruence.lean`,
but rotates *all* labels (the label type is `ZMod N` itself, with no `Fin n ⊕ ·` split), matching
the paper's `C_N` acting on all `N` labels by a full cyclic rotation. -/

section RotationAction

variable {N : ℕ} [NeZero N]

/-- Full rotation of the label type `ZMod N` by `g`. -/
def rotFull (g : ZMod N) : Equiv.Perm (ZMod N) := Equiv.addLeft g

@[simp] theorem rotFull_apply (g x : ZMod N) : rotFull g x = g + x := rfl

theorem rotFull_zero : rotFull (0 : ZMod N) = 1 := by
  ext x; simp [rotFull]

theorem rotFull_add (g1 g2 : ZMod N) : rotFull (g1 + g2) = rotFull g1 * rotFull g2 := by
  ext x
  change g1 + g2 + x = g1 + (g2 + x)
  rw [add_assoc]

/-- The conjugation action of `ZMod N` on `Equiv.Perm (ZMod N)` given by rotating all labels. -/
instance rotFullAddAction : AddAction (ZMod N) (Equiv.Perm (ZMod N)) where
  vadd g σ := rotFull g * σ * (rotFull g)⁻¹
  zero_vadd σ := by change rotFull 0 * σ * (rotFull 0)⁻¹ = σ; rw [rotFull_zero]; simp
  add_vadd g1 g2 σ := by
    change rotFull (g1 + g2) * σ * (rotFull (g1 + g2))⁻¹ =
      rotFull g1 * (rotFull g2 * σ * (rotFull g2)⁻¹) * (rotFull g1)⁻¹
    rw [rotFull_add, mul_inv_rev]
    group

theorem vaddFull_def (g : ZMod N) (σ : Equiv.Perm (ZMod N)) :
    g +ᵥ σ = rotFull g * σ * (rotFull g)⁻¹ := rfl

theorem permWeight_vaddFull (g : ZMod N) (σ : Equiv.Perm (ZMod N)) :
    permWeight (g +ᵥ σ) = permWeight σ := by
  rw [vaddFull_def]; exact permWeight_conj σ (rotFull g)

theorem rotFull_inv (g : ZMod N) : (rotFull g)⁻¹ = rotFull (-g) := by
  have h := rotFull_add g (-g)
  rw [add_neg_cancel, rotFull_zero] at h
  exact inv_eq_of_mul_eq_one_right h.symm

/-- The `ZMod N`-action on `Equiv.Perm (ZMod N)` is "abelian" in the sense that two rotations
commute as vadds; used to show that "fixed by `h0`" is a `ZMod N`-invariant condition. -/
theorem vadd_comm_vadd (g h : ZMod N) (σ : Equiv.Perm (ZMod N)) :
    g +ᵥ (h +ᵥ σ) = h +ᵥ (g +ᵥ σ) := by
  rw [← add_vadd, ← add_vadd, add_comm]

end RotationAction

/-! ### The key group-theory fact: every nonzero `g : ZMod (p^r)` has `p^(r-1)` as a `ℤ`-multiple

This is the formal core of "every nontrivial subgroup of `C_N` contains `H`": since `H` is
generated by `p^(r-1)`, showing `p^(r-1) ∈ AddSubgroup.zmultiples g` for every nonzero `g` shows
`AddSubgroup.zmultiples g ⊇ AddSubgroup.zmultiples (p^(r-1))`, i.e. `H` lies inside the subgroup
generated by any nonzero `g` -- in particular inside any subgroup containing a nonzero element. -/

theorem ppow_pred_mem_zmultiples {p r : ℕ} (hp : p.Prime) (hr : 1 ≤ r)
    {N : ℕ} [NeZero N] (hN : N = p ^ r) (g : ZMod N) (hg : g ≠ 0) :
    ((p ^ (r - 1) : ℕ) : ZMod N) ∈ AddSubgroup.zmultiples g := by
  classical
  rw [AddSubgroup.mem_zmultiples_iff]
  set a := g.val with ha_def
  have haN : a < N := ZMod.val_lt g
  have ha0 : a ≠ 0 := fun h => hg ((ZMod.val_eq_zero g).mp h)
  set d := Nat.gcd a N with hd_def
  have hdvdN : d ∣ N := Nat.gcd_dvd_right a N
  have hdvda : d ∣ a := Nat.gcd_dvd_left a N
  obtain ⟨j, hjr, hdj⟩ : ∃ j ≤ r, d = p ^ j := by
    rw [hN] at hdvdN
    exact (Nat.dvd_prime_pow hp).mp hdvdN
  have hdpos : 0 < d := Nat.gcd_pos_of_pos_left N (Nat.pos_of_ne_zero ha0)
  have hdlt : d < N := lt_of_le_of_lt (Nat.le_of_dvd (Nat.pos_of_ne_zero ha0) hdvda) haN
  have hjlt : j < r := by
    have hpj : p ^ j < p ^ r := by rw [← hdj, ← hN]; exact hdlt
    exact (Nat.pow_lt_pow_iff_right hp.one_lt).mp hpj
  have hddvd : d ∣ p ^ (r - 1) := by
    rw [hdj]; exact Nat.pow_dvd_pow p (by omega)
  obtain ⟨c, hc⟩ := hddvd
  -- Bézout: `d = a * gcdA a N + N * gcdB a N` as integers.
  have hbez : (d : ℤ) = (a : ℤ) * Nat.gcdA a N + (N : ℤ) * Nat.gcdB a N := Nat.gcd_eq_gcd_ab a N
  refine ⟨(c : ℤ) * Nat.gcdA a N, ?_⟩
  have hga : (a : ZMod N) = g := by rw [ha_def]; exact ZMod.natCast_zmod_val g
  have hstep : ((d : ℕ) : ZMod N) = (a : ZMod N) * (Nat.gcdA a N : ZMod N) := by
    have := congrArg (fun z : ℤ => (z : ZMod N)) hbez
    push_cast at this
    rw [this, ZMod.natCast_self]
    ring
  rw [zsmul_eq_mul, hc]
  push_cast
  rw [hstep, hga]
  ring

/-- **Contrapositive of "every nontrivial subgroup of `C_N` contains `H`".** If `σ` has
nontrivial `C_N`-stabilizer (witnessed by `g ≠ 0` with `g +ᵥ σ = σ`), then `σ` is already fixed
by `h0 := p^(r-1)`, the generator of `H`. -/
theorem H_fixed_of_nontrivial_stabilizer {p r : ℕ} (hp : p.Prime) (hr : 1 ≤ r)
    {N : ℕ} [NeZero N] (hN : N = p ^ r) (σ : Equiv.Perm (ZMod N))
    (g : ZMod N) (hg : g ≠ 0) (hgfix : g +ᵥ σ = σ) :
    ((p ^ (r - 1) : ℕ) : ZMod N) +ᵥ σ = σ := by
  have hmem : ((p ^ (r - 1) : ℕ) : ZMod N) ∈ AddSubgroup.zmultiples g :=
    ppow_pred_mem_zmultiples hp hr hN g hg
  have hle : AddSubgroup.zmultiples g ≤ AddAction.stabilizer (ZMod N) σ :=
    AddSubgroup.zmultiples_le.mpr (AddAction.mem_stabilizer_iff.mpr hgfix)
  exact AddAction.mem_stabilizer_iff.mp (hle hmem)

/-- A fixed rotation `g` acts by cancellation: `g +ᵥ σ = g +ᵥ τ → σ = τ`. -/
theorem vaddFull_left_cancel {N : ℕ} [NeZero N] (g : ZMod N) {σ τ : Equiv.Perm (ZMod N)}
    (h : g +ᵥ σ = g +ᵥ τ) : σ = τ := by
  have := congrArg (fun x => (-g) +ᵥ x) h
  simpa [← add_vadd] using this

/-- **`h0`-fixedness is `C_N`-invariant.** -/
theorem H_fixed_vadd_iff {N : ℕ} [NeZero N] (h0 g : ZMod N) (σ : Equiv.Perm (ZMod N)) :
    h0 +ᵥ (g +ᵥ σ) = g +ᵥ σ ↔ h0 +ᵥ σ = σ := by
  rw [vadd_comm_vadd]
  constructor
  · intro h; exact vaddFull_left_cancel g h
  · intro h; rw [h]

/-- **The Setup reduction (`eq:fixedcount`)**: `a(N) ≡ |X_N^H| (mod N)` for `N = p^r`, where
`X_N^H` is the set of colored permutations of `ZMod N` fixed by `h0 := p^(r-1)` (the generator of
`H`). Proved via `dvd_sum_of_free_action`: objects not fixed by `H` have trivial
`C_N`-stabilizer (`H_fixed_of_nontrivial_stabilizer`, contrapositive), hence lie in full free
`C_N`-orbits of size `N`, so their total weight is divisible by `N`. -/
theorem primepower_setup_reduction {p r : ℕ} (hp : p.Prime) (hr : 1 ≤ r)
    {N : ℕ} [NeZero N] (hN : N = p ^ r) :
    (N : ℤ) ∣ (a N -
      ∑ σ ∈ Finset.univ.filter
        (fun σ : Equiv.Perm (ZMod N) => ((p ^ (r - 1) : ℕ) : ZMod N) +ᵥ σ = σ),
        permWeight σ) := by
  classical
  set h0 : ZMod N := ((p ^ (r - 1) : ℕ) : ZMod N) with h0def
  set P : Equiv.Perm (ZMod N) → Prop := fun σ => h0 +ᵥ σ = σ with hP
  have hpermSum : permSum (ZMod N) = a N := by
    rw [permSum_congr (ZMod.finEquiv N).toEquiv.symm, permSum_eq_a]
  have hsplit : permSum (ZMod N) =
      (∑ σ ∈ Finset.univ.filter P, permWeight σ) +
      (∑ σ ∈ Finset.univ.filter (fun σ => ¬ P σ), permWeight σ) := by
    rw [Finset.sum_filter_add_sum_filter_not Finset.univ P]; rfl
  have hcard : (Fintype.card (ZMod N) : ℤ) = (N : ℤ) := by exact_mod_cast ZMod.card N
  have hnotfixed_dvd : (N : ℤ) ∣ ∑ σ ∈ Finset.univ.filter (fun σ => ¬ P σ), permWeight σ := by
    rw [← hcard]
    apply dvd_sum_of_free_action (G := ZMod N) (X := Equiv.Perm (ZMod N))
      permWeight permWeight_vaddFull
    · intro g σ hσ
      simp only [Finset.mem_filter, Finset.mem_univ, true_and, hP] at hσ ⊢
      intro hfix
      exact hσ ((H_fixed_vadd_iff h0 g σ).mp hfix)
    · intro σ hσ g hg
      simp only [Finset.mem_filter, Finset.mem_univ, true_and, hP] at hσ
      by_contra hg0
      exact hσ (H_fixed_of_nontrivial_stabilizer hp hr hN σ g hg0 hg)
  have hdvd : (N : ℤ) ∣ (a N -
      ∑ σ ∈ Finset.univ.filter P, permWeight σ) := by
    have : a N - ∑ σ ∈ Finset.univ.filter P, permWeight σ
        = ∑ σ ∈ Finset.univ.filter (fun σ => ¬ P σ), permWeight σ := by
      rw [← hpermSum, hsplit]; ring
    rw [this]; exact hnotfixed_dvd
  simpa [hP, h0def] using hdvd

/-! ## Section 4.1 continued / Sections 4.2-4.3: the block-cycle weight and the final assembly

**Status: not completed.** Everything above this point (the two `p = 2` base cases, and the
`C_N`/`H` "Setup" reduction `a(p^r) ≡ |X_N^H| (mod p^r)`) is fully proved with zero `sorry`. What
remains is the paper's harder combinatorial content: counting `X_N^H` via block-cycles
(`eq:weight`, `eq:Xfixed`), the two `p`-adic valuation-elimination arguments (odd-prime case and
`lem:two-elimination`), and the two lifting-the-exponent assembly steps. See the file-level status
summary at the very bottom of the file for a full account of what is proved, what is stated but
`sorry`-ed, and why. -/

/-- **Shift-counting lemma.** For `ℓ' ≥ 0`, exactly `p^ℓ'` of the `p^(ℓ'+1)` tuples
`v : Fin (ℓ'+1) → ZMod p` sum to zero. Proved via the bijection with `Fin ℓ' → ZMod p` that drops
the last coordinate (forward direction) resp. appends the unique value making the sum vanish
(backward direction). This is the `p^(ℓ-1)` count of "total shift zero" shift-assignments (with
`ℓ = ℓ' + 1`) used in the paper's `eq:weight`. -/
theorem card_tuple_sum_eq_zero {p : ℕ} [NeZero p] (ℓ' : ℕ) :
    Fintype.card {v : Fin (ℓ' + 1) → ZMod p // ∑ i, v i = 0} = p ^ ℓ' := by
  classical
  have e : {v : Fin (ℓ' + 1) → ZMod p // ∑ i, v i = 0} ≃ (Fin ℓ' → ZMod p) := by
    refine
      { toFun := fun v => v.1 ∘ Fin.castSucc
        invFun := fun w => ⟨Fin.snoc w (-∑ i, w i), ?_⟩
        left_inv := ?_
        right_inv := ?_ }
    · rw [Fin.sum_univ_castSucc]
      simp
    · rintro ⟨v, hv⟩
      rw [Fin.sum_univ_castSucc] at hv
      refine Subtype.ext ?_
      change (Fin.snoc (v ∘ Fin.castSucc) (-∑ i, (v ∘ Fin.castSucc) i) : Fin (ℓ' + 1) → ZMod p) = v
      have hlast : v (Fin.last ℓ') = -∑ i, (v ∘ Fin.castSucc) i := by
        have h2 : (∑ i, (v ∘ Fin.castSucc) i) + v (Fin.last ℓ') = 0 := hv
        linear_combination h2
      rw [← hlast]
      exact Fin.snoc_init_self v
    · intro w
      funext i
      change (Fin.snoc w (-∑ j, w j) : Fin (ℓ' + 1) → ZMod p) (Fin.castSucc i) = w i
      rw [Fin.snoc_castSucc]
  rw [Fintype.card_congr e, Fintype.card_pi]
  simp [ZMod.card]

/-- **The block-cycle weight for this file's chosen (permutation-level) route -- deliberately
*not* a verbatim transcription of the paper's `eq:weight`; see the note below.**
`blockWeight p ℓ = p^(ℓ-1) * (dvr(ℓ)^p + (p-1) dvr(pℓ))`. For `ℓ = 1` this is
`1^p + (p-1)*2 = 2p-1` regardless of `p` (matching the paper's `W_1`, since `dvr(1) = 1 = 1^p`);
for `p = 2` it specializes to `2^(ℓ-1)(dvr(ℓ)^2 + dvr(2ℓ))`, e.g. `W_1 = 3` (matching the paper)
but `W_2 = 2*(4+3) = 14`, whereas the paper's own `eq:weight` states `W_2 = 10 = 2*(2+3)` (with
`dvr(ℓ)` instead of `dvr(ℓ)^p`).

**Why the two formulas legitimately differ (no error in the paper -- both quantities are
correct, they are just different intermediates).** The paper's argument tracks *objects*
`(σ, coloring)` directly: an object is fixed by `H` only if `σ` is `H`-fixed *and* the coloring
is `H`-invariant (the induced `H`-action permutes cycles of `σ`, so invariance forces the `p`
sister cycles in a "total shift zero" block-cycle to share one color) -- giving exactly `dvr(ℓ)`
for that sub-case, and the paper's `|X_N^H|` literally counts these `H`-fixed *objects*. This
file's route to `a(p^r) mod p^r`, by contrast (`primepower_setup_reduction`), acts only on bare
*permutations*: it reuses `permWeight`/`dvd_sum_of_free_action` from `ProductCongruence.lean`
verbatim, which never tracks colorings at the object level at all -- `permWeight σ` is already the
*total* (unconstrained) count of colorings of `σ`, summed over `σ` fixed by `H` as a permutation.
Since a "total shift zero" `σ` is `p` *disjoint* `ℓ`-cycles, its `permWeight` contribution is
`dvr(ℓ)^p` (an independent divisor-choice per cycle), not `dvr(ℓ)`. Both `719`
(`H`-fixed objects, paper's literal `eq:weight`) and `1097` (`∑_{H-fixed-as-permutation σ}
permWeight σ`, this file's quantity) were checked by brute-force enumeration for `N = 9 = 3^2` and
are correct *for their respective definitions*; both are `≡ a(9) ≡ 8 (mod 9)`, confirming each is
individually a valid route to Proposition 4.2, and the same was checked for `N = 8 = 2^3`
(`H`-fixed-object count not recomputed there, but `∑_{H-fixed σ} permWeight σ = 2817`, matching
`blockWeight`'s formula below exactly). `blockWeight` here uses the `dvr(ℓ)^p` formula because
that is what matches `primepower_setup_reduction`, the bridge this file has actually proved; it
is not a "correction" to the paper, just the weight appropriate to a different, equally valid
bridge from `a` to a block-cycle count. (Since `dvr(1)^p = 1 = dvr(1)`, the two formulas coincide
exactly at `ℓ = 1`, the only length surviving the later mod-`p^r` valuation argument, so this
choice is invisible in the final theorem statements either way.) -/
def blockWeight (p ℓ : ℕ) : ℤ :=
  (p : ℤ) ^ (ℓ - 1) * ((numDivisors ℓ : ℤ) ^ p + ((p : ℤ) - 1) * (numDivisors (p * ℓ) : ℤ))

/-- The "block-permutation weight" of `τ : Equiv.Perm (Fin M)`: the product of `blockWeight p`
over `τ`'s genuine cycles (length `≥ 2`, as recorded by `Equiv.Perm.cycleType`), times
`blockWeight p 1` once for each of `τ`'s fixed points (a "length-1 block-cycle"). This is *not*
simply `(τ.cycleType.map (blockWeight p)).prod`, because `Equiv.Perm.cycleType` excludes fixed
points by Mathlib's convention, whereas the paper's `W_1` need not be `1` (so a fixed block still
carries genuine combinatorial weight, unlike a literal fixed point of an uncolored permutation). -/
def blockPermWeight (p M : ℕ) (τ : Equiv.Perm (Fin M)) : ℤ :=
  (τ.cycleType.map (blockWeight p)).prod * (blockWeight p 1) ^ (M - τ.support.card)

/-! ### Block/position coordinates on `ZMod (M*p)` (partial progress toward `XNH_eq_blockSum`)

Concrete scaffolding toward the block decomposition needed for `XNH_eq_blockSum`: for `x : ZMod
(M*p)`, `blk M x := x.val % M` is `x`'s block index (an `H`-orbit label, `0 ≤ blk M x < M`), and
`posn M x := x.val / M` is `x`'s position within that block (`0 ≤ posn M x < p`). `x` is
recovered from the pair via `x.val = blk M x + M * posn M x`. The key fact
(`blk_posn_add_M`, fully proved) is that adding `h0 = (M : ZMod (M*p))` -- the generator of `H` --
leaves the block fixed and cyclically increments the position mod `p`; this is the single-step
version of "`H` acts on labels by moving within a block," which is the starting point for
constructing the induced block permutation `τ` (not carried further here -- see the status
summary at the bottom of the file). -/

section BlockStructure

variable {M p : ℕ}

/-- The block (`H`-orbit index, in `[0, M)`) containing a label `x : ZMod (M*p)`. -/
def blk (M : ℕ) (x : ZMod (M * p)) : ℕ := x.val % M

/-- The position (in `[0, p)`) of `x` within its block. -/
def posn (M : ℕ) (x : ZMod (M * p)) : ℕ := x.val / M

theorem blk_lt (hM : 0 < M) (x : ZMod (M * p)) : blk M x < M := Nat.mod_lt _ hM

theorem posn_lt [NeZero (M * p)] (hM : 0 < M) (x : ZMod (M * p)) : posn M x < p := by
  unfold posn
  rw [Nat.div_lt_iff_lt_mul hM]
  have hv := x.val_lt
  have hcomm : M * p = p * M := Nat.mul_comm M p
  omega

theorem val_eq_blk_add_mul_posn (x : ZMod (M * p)) : x.val = blk M x + M * posn M x := by
  unfold blk posn
  rw [Nat.mod_add_div]

/-- Pure arithmetic core of `blk_posn_add_M`: incrementing the "high digit" `k` (of a base-`M`
two-digit number `q + M*k` with `q < M`, `k < p`) by one, working mod `M*p`, cyclically wraps `k`
mod `p` and leaves `q` unchanged. -/
theorem nat_step (p M q k : ℕ) (hq : q < M) (hk : k < p) :
    (q + M * k + M) % (M * p) = q + M * ((k + 1) % p) := by
  have heq : q + M * k + M = q + M * (k + 1) := by ring
  rw [heq]
  rcases Nat.lt_or_ge (k + 1) p with h | h
  · rw [Nat.mod_eq_of_lt (by nlinarith : q + M * (k + 1) < M * p), Nat.mod_eq_of_lt h]
  · have hkp : k + 1 = p := by omega
    rw [hkp, Nat.add_mod_right, Nat.mod_self, Nat.mul_zero, Nat.add_zero]
    exact Nat.mod_eq_of_lt (by nlinarith)

/-- **Single-step block/position increment.** Adding `h0 = (M : ZMod (M*p))` (the generator of
`H`) to `x` leaves `x`'s block unchanged and cyclically increments its position mod `p`. -/
theorem blk_posn_add_M [NeZero (M * p)] (hM : 0 < M) (hp1 : 1 < p) (x : ZMod (M * p)) :
    blk M (((M : ℕ) : ZMod (M * p)) + x) = blk M x ∧
    posn M (((M : ℕ) : ZMod (M * p)) + x) = (posn M x + 1) % p := by
  have hMN : M < M * p := by nlinarith
  have hMval : ((M : ℕ) : ZMod (M * p)).val = M := ZMod.val_cast_of_lt hMN
  have hadd : (((M : ℕ) : ZMod (M * p)) + x).val = (M + x.val) % (M * p) := by
    rw [ZMod.val_add, hMval]
  have hxval : x.val = blk M x + M * posn M x := val_eq_blk_add_mul_posn (M := M) x
  have hcomp : (M + x.val) % (M * p) = blk M x + M * ((posn M x + 1) % p) := by
    conv_lhs => rw [hxval]
    have hns := nat_step p M (blk M x) (posn M x) (blk_lt hM x) (posn_lt hM x)
    rw [← hns]
    ring_nf
  have hfinal : (((M : ℕ) : ZMod (M * p)) + x).val = blk M x + M * ((posn M x + 1) % p) := by
    rw [hadd, hcomp]
  refine ⟨?_, ?_⟩
  · show (((M : ℕ) : ZMod (M * p)) + x).val % M = blk M x
    rw [hfinal, Nat.add_mul_mod_self_left]
    exact Nat.mod_eq_of_lt (blk_lt hM x)
  · show (((M : ℕ) : ZMod (M * p)) + x).val / M = (posn M x + 1) % p
    rw [hfinal, Nat.add_mul_div_left _ _ hM]
    have h2 : blk M x / M = 0 := Nat.div_eq_of_lt (blk_lt hM x)
    omega

end BlockStructure

/-! ### The induced block permutation `blockPerm` (further progress toward `XNH_eq_blockSum`)

Building on `blk`/`posn`/`blk_posn_add_M` above: `blk_posn_add_mul_M` generalizes the single-step
increment to adding any `c`-fold multiple of `H`'s generator; `equivariance_of_H_fixed` (and its
variants) extract, from `h0 +ᵥ σ = σ`, the pointwise equivariance `σ (h0 + x) = h0 + σ x` (and its
`c`-fold and inverse versions); `exists_c_of_blk_eq` shows two labels lie in the same block iff
they differ by a multiple of `h0`. Combining these, `blk_sigma_welldef` shows `blk (σ ·)` is
constant on blocks for `H`-fixed `σ`, so it descends to a well-defined map on blocks
(`blockPermFun`), which `blockPermFun_injective` shows is injective, hence (finite domain)
bijective: `blockPerm` packages this as the induced block permutation `τ : Equiv.Perm (Fin M)`,
satisfying `blockPerm_apply : blockPerm hM hp1 hσ (blkFin M p hM x) = blkFin M p hM (σ x)`. This
completes item (1) of the roadmap in `XNH_eq_blockSum`'s docstring; items (2)-(4) (the shift
cocycle, the zero/nonzero-shift orbit-structure case split, and the block-level peeling induction)
remain -- see the status summary at the bottom of the file. -/

section KStep

variable {M p : ℕ}

theorem blk_posn_add_mul_M [NeZero (M * p)] (hM : 0 < M) (hp1 : 1 < p) (c : ℕ) (x : ZMod (M * p)) :
    blk M (((c * M : ℕ) : ZMod (M * p)) + x) = blk M x ∧
    posn M (((c * M : ℕ) : ZMod (M * p)) + x) = (posn M x + c) % p := by
  induction c with
  | zero =>
    have hz : (((0 * M : ℕ) : ZMod (M * p))) + x = x := by simp
    rw [hz]
    exact ⟨rfl, (Nat.mod_eq_of_lt (posn_lt hM x)).symm⟩
  | succ c ih =>
    obtain ⟨ih1, ih2⟩ := ih
    have hcast : ((((c+1) * M : ℕ) : ZMod (M * p))) =
        ((M:ℕ):ZMod (M*p)) + ((c * M : ℕ) : ZMod (M * p)) := by
      push_cast
      ring
    have hassoc : (((c+1)*M:ℕ):ZMod (M*p)) + x
        = ((M:ℕ):ZMod (M*p)) + (((c*M:ℕ):ZMod (M*p)) + x) := by
      rw [hcast, add_assoc]
    rw [hassoc]
    obtain ⟨s1, s2⟩ := blk_posn_add_M (M:=M) (p:=p) hM hp1 (((c*M:ℕ):ZMod (M*p)) + x)
    rw [s1, s2, ih1, ih2]
    refine ⟨rfl, ?_⟩
    have : (posn M x + c) % p + 1 ≡ posn M x + (c+1) [MOD p] := by
      have h1 : (posn M x + c) % p + 1 = ((posn M x + c) % p + 1) := rfl
      calc (posn M x + c) % p + 1 ≡ (posn M x + c) + 1 [MOD p] :=
            (Nat.ModEq.add_right 1 (Nat.mod_modEq _ _))
        _ = posn M x + (c+1) := by ring
    have := this.symm
    unfold Nat.ModEq at this
    omega

end KStep

section Equivariance

variable {M p : ℕ} [NeZero (M * p)]

/-- If `σ` is fixed by `H` (generated by `h0 = (M : ZMod (M*p))`), then `σ` is equivariant for
the single-step `H`-translation: `σ (h0 + x) = h0 + σ x`. -/
theorem equivariance_of_H_fixed {σ : Equiv.Perm (ZMod (M*p))}
    (hσ : ((M:ℕ):ZMod (M*p)) +ᵥ σ = σ) (x : ZMod (M*p)) :
    σ (((M:ℕ):ZMod (M*p)) + x) = ((M:ℕ):ZMod (M*p)) + σ x := by
  rw [vaddFull_def] at hσ
  have hcomm : rotFull ((M:ℕ):ZMod (M*p)) * σ = σ * rotFull ((M:ℕ):ZMod (M*p)) := by
    rwa [mul_inv_eq_iff_eq_mul] at hσ
  have h2 : (rotFull ((M:ℕ):ZMod (M*p)) * σ) x = (σ * rotFull ((M:ℕ):ZMod (M*p))) x := by
    rw [hcomm]
  simp only [Equiv.Perm.mul_apply, rotFull_apply] at h2
  exact h2.symm

/-- The inverse of an `H`-fixed `σ` satisfies the same equivariance. -/
theorem equivariance_of_H_fixed_inv {σ : Equiv.Perm (ZMod (M*p))}
    (hσ : ((M:ℕ):ZMod (M*p)) +ᵥ σ = σ) (y : ZMod (M*p)) :
    σ⁻¹ (((M:ℕ):ZMod (M*p)) + y) = ((M:ℕ):ZMod (M*p)) + σ⁻¹ y := by
  have hinv : (σ⁻¹ : Equiv.Perm (ZMod (M*p))) = σ.symm := rfl
  have h := equivariance_of_H_fixed hσ (σ⁻¹ y)
  rw [hinv] at h ⊢
  rw [Equiv.apply_symm_apply] at h
  have h2 := congrArg σ.symm h
  rw [Equiv.symm_apply_apply] at h2
  exact h2.symm

theorem equivariance_mul_M {σ : Equiv.Perm (ZMod (M*p))}
    (hσ : ((M:ℕ):ZMod (M*p)) +ᵥ σ = σ) (c : ℕ) (x : ZMod (M*p)) :
    σ (((c*M:ℕ):ZMod (M*p)) + x) = ((c*M:ℕ):ZMod (M*p)) + σ x := by
  induction c with
  | zero => simp
  | succ c ih =>
    have hcast : ((((c+1) * M : ℕ) : ZMod (M * p))) =
        ((M:ℕ):ZMod (M*p)) + ((c * M : ℕ) : ZMod (M * p)) := by push_cast; ring
    rw [hcast, add_assoc, equivariance_of_H_fixed hσ, ih, add_assoc]

theorem equivariance_inv_mul_M {σ : Equiv.Perm (ZMod (M*p))}
    (hσ : ((M:ℕ):ZMod (M*p)) +ᵥ σ = σ) (c : ℕ) (x : ZMod (M*p)) :
    σ⁻¹ (((c*M:ℕ):ZMod (M*p)) + x) = ((c*M:ℕ):ZMod (M*p)) + σ⁻¹ x := by
  induction c with
  | zero => simp
  | succ c ih =>
    have hcast : ((((c+1) * M : ℕ) : ZMod (M * p))) =
        ((M:ℕ):ZMod (M*p)) + ((c * M : ℕ) : ZMod (M * p)) := by push_cast; ring
    rw [hcast, add_assoc, equivariance_of_H_fixed_inv hσ, ih, add_assoc]

end Equivariance

section BlockCharacterization

variable {M p : ℕ} [NeZero (M * p)]

theorem eq_of_blk_posn_eq (hM : 0 < M) (a b : ZMod (M * p))
    (h1 : blk M a = blk M b) (h2 : posn M a = posn M b) : a = b := by
  apply ZMod.val_injective (M*p)
  rw [val_eq_blk_add_mul_posn (M:=M) a, val_eq_blk_add_mul_posn (M:=M) b, h1, h2]

/-- Pure arithmetic: given `i, j < p`, there is `c < p` with `(i + c) % p = j`. -/
theorem exists_c_mod (p i j : ℕ) (hp1 : 1 < p) (hi : i < p) (hj : j < p) :
    ∃ c < p, (i + c) % p = j := by
  refine ⟨(j + (p - i)) % p, Nat.mod_lt _ (by omega), ?_⟩
  have hmod : (i + (j + (p - i)) % p) % p = (i + (j + (p - i))) % p := Nat.add_mod_mod i _ p
  rw [hmod]
  have heq2 : i + (j + (p - i)) = j + p := by omega
  rw [heq2, Nat.add_mod_right]
  exact Nat.mod_eq_of_lt hj

/-- **Same block ⟺ differ by a multiple of `M`.** If `blk M x = blk M y`, there is `c < p` with
`y = x + (c*M : ZMod (M*p))`. -/
theorem exists_c_of_blk_eq (hM : 0 < M) (hp1 : 1 < p) {x y : ZMod (M*p)}
    (h : blk M x = blk M y) : ∃ c < p, y = ((c*M:ℕ):ZMod (M*p)) + x := by
  obtain ⟨c, hcp, hc⟩ := exists_c_mod p (posn M x) (posn M y) hp1 (posn_lt hM x) (posn_lt hM y)
  refine ⟨c, hcp, ?_⟩
  apply eq_of_blk_posn_eq hM
  · obtain ⟨b1, _⟩ := blk_posn_add_mul_M (M:=M) (p:=p) hM hp1 c x
    rw [b1, h]
  · obtain ⟨_, b2⟩ := blk_posn_add_mul_M (M:=M) (p:=p) hM hp1 c x
    rw [b2, hc]

end BlockCharacterization

section BlockPerm

variable {M p : ℕ} [NeZero (M * p)]

/-- `blk` packaged as a `Fin M`. -/
def blkFin (M p : ℕ) (hM : 0 < M) (x : ZMod (M*p)) : Fin M := ⟨blk M x, blk_lt hM x⟩

/-- A section of `blkFin`: lift a block index back to a canonical representative label. -/
def secBlk (M p : ℕ) (hM : 0 < M) (b : Fin M) : ZMod (M*p) := ((b.1 : ℕ) : ZMod (M*p))

theorem blkFin_secBlk (hM : 0 < M) (hp1 : 1 < p) (b : Fin M) :
    blkFin M p hM (secBlk M p hM b) = b := by
  have hbN : (b.1:ℕ) < M*p := by have := b.2; nlinarith
  have hval : (secBlk M p hM b).val = b.1 := ZMod.val_cast_of_lt hbN
  apply Fin.ext
  show blk M (secBlk M p hM b) = b.1
  unfold blk
  rw [hval]
  exact Nat.mod_eq_of_lt b.2

/-- **Well-definedness of the block map's descent**: if `σ` is `H`-fixed, `blk (σ ·)` depends
only on the block of its argument. -/
theorem blk_sigma_welldef (hM : 0 < M) (hp1 : 1 < p) {σ : Equiv.Perm (ZMod (M*p))}
    (hσ : ((M:ℕ):ZMod (M*p)) +ᵥ σ = σ) {x y : ZMod (M*p)} (h : blk M x = blk M y) :
    blk M (σ x) = blk M (σ y) := by
  obtain ⟨c, _, hc⟩ := exists_c_of_blk_eq hM hp1 h
  rw [hc, equivariance_mul_M hσ]
  obtain ⟨b1, _⟩ := blk_posn_add_mul_M (M:=M) (p:=p) hM hp1 c (σ x)
  rw [b1]

/-- The raw block-descent map `Fin M → Fin M` induced by `σ`, before packaging as an `Equiv`. -/
def blockPermFun (hM : 0 < M) (σ : Equiv.Perm (ZMod (M*p))) (b : Fin M) : Fin M :=
  blkFin M p hM (σ (secBlk M p hM b))

theorem blockPermFun_blkFin (hM : 0 < M) (hp1 : 1 < p) {σ : Equiv.Perm (ZMod (M*p))}
    (hσ : ((M:ℕ):ZMod (M*p)) +ᵥ σ = σ) (x : ZMod (M*p)) :
    blockPermFun hM σ (blkFin M p hM x) = blkFin M p hM (σ x) := by
  unfold blockPermFun
  apply Fin.ext
  show blk M (σ (secBlk M p hM (blkFin M p hM x))) = blk M (σ x)
  apply blk_sigma_welldef hM hp1 hσ
  have := blkFin_secBlk hM hp1 (blkFin M p hM x)
  exact congrArg Fin.val this

theorem blockPermFun_injective (hM : 0 < M) (hp1 : 1 < p) {σ : Equiv.Perm (ZMod (M*p))}
    (hσ : ((M:ℕ):ZMod (M*p)) +ᵥ σ = σ) : Function.Injective (blockPermFun hM σ) := by
  intro b1 b2 hb
  unfold blockPermFun at hb
  have hblk : blk M (σ (secBlk M p hM b1)) = blk M (σ (secBlk M p hM b2)) := congrArg Fin.val hb
  obtain ⟨c, _, hc⟩ := exists_c_of_blk_eq hM hp1 hblk
  have hinvEq : (σ⁻¹ : Equiv.Perm (ZMod (M*p))) = σ.symm := rfl
  have hc2 : σ.symm (σ (secBlk M p hM b2))
      = σ.symm (((c*M:ℕ):ZMod (M*p)) + σ (secBlk M p hM b1)) := congrArg σ.symm hc
  rw [Equiv.symm_apply_apply] at hc2
  have step1 := equivariance_inv_mul_M (M:=M) (p:=p) hσ c (σ (secBlk M p hM b1))
  rw [hinvEq] at step1
  rw [Equiv.symm_apply_apply] at step1
  have hinv : secBlk M p hM b2 = ((c*M:ℕ):ZMod (M*p)) + secBlk M p hM b1 := by
    rw [hc2, step1]
  have hblk2 : blk M (secBlk M p hM b2) = blk M (secBlk M p hM b1) := by
    rw [hinv]
    obtain ⟨b1', _⟩ := blk_posn_add_mul_M (M:=M) (p:=p) hM hp1 c (secBlk M p hM b1)
    exact b1'
  have e1 := blkFin_secBlk hM hp1 b1
  have e2 := blkFin_secBlk hM hp1 b2
  apply Fin.ext
  calc (b1:ℕ) = blk M (secBlk M p hM b1) := (congrArg Fin.val e1).symm
    _ = blk M (secBlk M p hM b2) := hblk2.symm
    _ = (b2:ℕ) := congrArg Fin.val e2

/-- **The induced block permutation.** For `H`-fixed `σ`, `blockPerm` is the bijection of `Fin M`
induced by `σ`'s action on blocks: `blockPerm hM hp1 hσ (blkFin M p hM x) = blkFin M p hM (σ x)`. -/
noncomputable def blockPerm (hM : 0 < M) (hp1 : 1 < p) {σ : Equiv.Perm (ZMod (M*p))}
    (hσ : ((M:ℕ):ZMod (M*p)) +ᵥ σ = σ) : Equiv.Perm (Fin M) :=
  Equiv.ofBijective (blockPermFun hM σ)
    (Finite.injective_iff_bijective.mp (blockPermFun_injective hM hp1 hσ))

theorem blockPerm_apply (hM : 0 < M) (hp1 : 1 < p) {σ : Equiv.Perm (ZMod (M*p))}
    (hσ : ((M:ℕ):ZMod (M*p)) +ᵥ σ = σ) (x : ZMod (M*p)) :
    blockPerm hM hp1 hσ (blkFin M p hM x) = blkFin M p hM (σ x) :=
  blockPermFun_blkFin hM hp1 hσ x

end BlockPerm

/-! ### The shift / order computation (further progress toward `XNH_eq_blockSum`)

`equivariance_mul_M_pow` and `blkFin_pow` extend equivariance and the block-descent property to
powers of `σ`. `sigma_pow_ell_mul` shows that iterating `σ` around a block-cycle `q` times shifts
by `q` copies of the total shift. `period_sigma_eq` is the mathematical core of the paper's
"total shift zero ⟹ `p` disjoint `ℓ`-cycles; total shift nonzero ⟹ one `pℓ`-cycle" claim: using
`MulAction.period` (Mathlib's "orbit length of a point under a group element" API), it computes
the `σ`-orbit length of a canonical block representative `x0` exactly as `ℓ` (if the total shift
`s` is zero) or `ℓ * p` (if `s ≠ 0`), where `ℓ` is the block-cycle length of `x0`'s block under the
induced block permutation `τ`. This completes item (2)-(3)'s *order* computation from the roadmap
in `XNH_eq_blockSum`'s docstring for the distinguished point `x0` itself; extending this to the
*full* orbit-structure claim (all `p` sister points, not just `x0`) and then to the block-level
peeling induction (item (4)) remains -- see the status summary at the bottom of the file. -/

section ShiftAndOrder

open MulAction

variable {M p : ℕ} [NeZero (M * p)]

theorem equivariance_mul_M_pow {σ : Equiv.Perm (ZMod (M*p))}
    (hσ : ((M:ℕ):ZMod (M*p)) +ᵥ σ = σ) (c k : ℕ) (x : ZMod (M*p)) :
    (σ^k) (((c*M:ℕ):ZMod (M*p)) + x) = ((c*M:ℕ):ZMod (M*p)) + (σ^k) x := by
  induction k with
  | zero => simp
  | succ k ih =>
    rw [pow_succ', Equiv.Perm.mul_apply, Equiv.Perm.mul_apply, ih, equivariance_mul_M hσ]

theorem blkFin_pow (hM : 0 < M) (hp1 : 1 < p) {σ : Equiv.Perm (ZMod (M*p))}
    (hσ : ((M:ℕ):ZMod (M*p)) +ᵥ σ = σ) (k : ℕ) (x : ZMod (M*p)) :
    blkFin M p hM ((σ^k) x) = ((blockPerm hM hp1 hσ)^k) (blkFin M p hM x) := by
  induction k with
  | zero => simp
  | succ k ih =>
    rw [pow_succ', Equiv.Perm.mul_apply, pow_succ', Equiv.Perm.mul_apply,
      ← blockPerm_apply hM hp1 hσ ((σ^k) x), ih]

/-- **Iterating `σ` around a block-cycle `q` times shifts by `q` copies of the total shift `s`.**
Here `x0` is a canonical block representative (`posn M x0 = 0`), `ℓ` is the block-cycle length,
`s` is the total shift (`posn M (σ^[ℓ] x0)`, since `σ^ℓ x0` lands back in `x0`'s block). -/
theorem sigma_pow_ell_mul (hM : 0 < M) (hp1 : 1 < p) {σ : Equiv.Perm (ZMod (M*p))}
    (hσ : ((M:ℕ):ZMod (M*p)) +ᵥ σ = σ) (x0 : ZMod (M*p)) (ℓ s : ℕ)
    (hℓs : (σ^ℓ) x0 = ((s*M:ℕ):ZMod (M*p)) + x0) (q : ℕ) :
    (σ^(ℓ*q)) x0 = ((q*s*M:ℕ):ZMod (M*p)) + x0 := by
  induction q with
  | zero => simp
  | succ q ih =>
    have hmul : ℓ * (q+1) = ℓ + ℓ*q := by ring
    rw [hmul, pow_add, Equiv.Perm.mul_apply, ih, equivariance_mul_M_pow hσ, hℓs]
    have hcast : (((q+1)*s*M:ℕ):ZMod (M*p)) =
        ((s*M:ℕ):ZMod (M*p)) + ((q*s*M:ℕ):ZMod (M*p)) := by push_cast; ring
    rw [hcast]
    abel

end ShiftAndOrder

section PeriodComputation

open MulAction

variable {M p : ℕ} [NeZero (M * p)]

theorem posn_secBlk (hM : 0 < M) (hp1 : 1 < p) (b0 : Fin M) : posn M (secBlk M p hM b0) = 0 := by
  have hbN : (b0.1:ℕ) < M*p := by have := b0.2; nlinarith
  have hval : (secBlk M p hM b0).val = b0.1 := ZMod.val_cast_of_lt hbN
  unfold posn
  rw [hval]
  exact Nat.div_eq_of_lt b0.2

/-- **The core order/period computation (Section 4.1, `eq:weight` combinatorics).** For `x0` a
canonical block representative and `ℓ := period τ b0` the block-cycle length, the `σ`-orbit
length of `x0` is `ℓ` if the total shift `s` around the block-cycle is zero, and `ℓ * p`
otherwise. This is the mathematical core of the paper's "total shift zero ⟹ `p` disjoint
`ℓ`-cycles; total shift nonzero ⟹ one `pℓ`-cycle" claim. -/
theorem period_sigma_eq (hM : 0 < M) (hp1 : 1 < p) (hpp : p.Prime) {σ : Equiv.Perm (ZMod (M*p))}
    (hσ : ((M:ℕ):ZMod (M*p)) +ᵥ σ = σ) (b0 : Fin M) :
    period σ (secBlk M p hM b0) =
      period (blockPerm hM hp1 hσ) b0 *
        (if posn M ((σ ^ period (blockPerm hM hp1 hσ) b0) (secBlk M p hM b0)) = 0 then 1 else p) := by
  set x0 := secBlk M p hM b0 with hx0
  set τ := blockPerm hM hp1 hσ with hτ
  set ℓ := period τ b0 with hℓdef
  set s := posn M ((σ^ℓ) x0) with hsdef
  have hℓpos : 0 < ℓ := period_pos_of_orderOf_pos (orderOf_pos τ) b0
  have hspos : s < p := posn_lt hM _
  -- `σ^ℓ x0` lies in `x0`'s block, and equals `s*M + x0`.
  have hblkeq : blk M ((σ^ℓ) x0) = blk M x0 := by
    have h1 : blkFin M p hM ((σ^ℓ) x0) = (τ^ℓ) (blkFin M p hM x0) := blkFin_pow hM hp1 hσ ℓ x0
    have h1x0 : blkFin M p hM x0 = b0 := blkFin_secBlk hM hp1 b0
    have h2 : (τ^ℓ) b0 = b0 := pow_period_smul τ b0
    have h3 : blkFin M p hM ((σ^ℓ) x0) = b0 := by rw [h1, h1x0, h2]
    calc blk M ((σ^ℓ) x0) = (blkFin M p hM ((σ^ℓ) x0) : ℕ) := rfl
      _ = (b0 : ℕ) := congrArg Fin.val h3
      _ = (blkFin M p hM x0 : ℕ) := (congrArg Fin.val h1x0).symm
      _ = blk M x0 := rfl
  have hx0posn : posn M x0 = 0 := posn_secBlk hM hp1 b0
  have hx0blk : blk M x0 = x0.val := by
    have := val_eq_blk_add_mul_posn (M:=M) x0
    rw [hx0posn, Nat.mul_zero, Nat.add_zero] at this
    exact this.symm
  have hℓs : (σ^ℓ) x0 = ((s*M:ℕ):ZMod (M*p)) + x0 := by
    apply eq_of_blk_posn_eq hM
    · obtain ⟨b1, _⟩ := blk_posn_add_mul_M (M:=M) (p:=p) hM hp1 s x0
      rw [b1, hblkeq]
    · obtain ⟨_, b2⟩ := blk_posn_add_mul_M (M:=M) (p:=p) hM hp1 s x0
      rw [b2, hx0posn, Nat.zero_add]
      exact (Nat.mod_eq_of_lt hspos).symm
  -- `ℓ ∣ period σ x0`.
  have hℓdvd : ℓ ∣ period σ x0 := by
    rw [hℓdef]
    apply pow_smul_eq_iff_period_dvd.mp
    show (τ^(period σ x0)) b0 = b0
    have h1 : blkFin M p hM ((σ^(period σ x0)) x0) = (τ^(period σ x0)) (blkFin M p hM x0) :=
      blkFin_pow hM hp1 hσ _ x0
    have h1x0 : blkFin M p hM x0 = b0 := blkFin_secBlk hM hp1 b0
    have h2 : (σ^(period σ x0)) x0 = x0 := pow_period_smul σ x0
    rw [h2, h1x0] at h1
    exact h1.symm
  obtain ⟨q0, hq0⟩ := hℓdvd
  have hq0pos : 0 < q0 := by
    rcases Nat.eq_zero_or_pos q0 with h | h
    · exfalso; rw [h, Nat.mul_zero] at hq0
      have := period_pos_of_orderOf_pos (orderOf_pos σ) x0
      omega
    · exact h
  by_cases hs0 : s = 0
  · -- total shift zero: period σ x0 = ℓ
    have hfix : (σ^ℓ) • x0 = x0 := by
      show (σ^ℓ) x0 = x0
      rw [hℓs, hs0]; simp
    have hle : period σ x0 ≤ ℓ := period_le_of_fixed hℓpos hfix
    have hge : ℓ ≤ period σ x0 := by
      rw [hq0]; exact Nat.le_mul_of_pos_right ℓ hq0pos
    rw [hs0]
    simp only [if_true]
    omega
  · -- total shift nonzero: period σ x0 = ℓ * p
    have hndvd : ¬ p ∣ s := by
      intro hdvd
      have := Nat.le_of_dvd (Nat.pos_of_ne_zero hs0) hdvd
      omega
    have hfix : (σ^(ℓ*p)) • x0 = x0 := by
      show (σ^(ℓ*p)) x0 = x0
      have hstep := sigma_pow_ell_mul hM hp1 hσ x0 ℓ s hℓs p
      rw [hstep]
      have hdvd0 : (M*p) ∣ (p*s*M) := ⟨s, by ring⟩
      have hcast0 : ((p*s*M:ℕ):ZMod (M*p)) = 0 := (ZMod.natCast_eq_zero_iff (p*s*M) (M*p)).mpr hdvd0
      rw [hcast0, zero_add]
    have hle : period σ x0 ≤ ℓ*p := period_le_of_fixed (by positivity) hfix
    have hstep2 := sigma_pow_ell_mul hM hp1 hσ x0 ℓ s hℓs q0
    rw [← hq0] at hstep2
    have hfixed3 : (σ^(period σ x0)) x0 = x0 := pow_period_smul σ x0
    rw [hfixed3] at hstep2
    have hdvd1 : (M*p) ∣ (q0*s*M) := by
      have hz : ((q0*s*M:ℕ):ZMod (M*p)) = 0 := by
        have := hstep2.symm
        have heq : ((q0*s*M:ℕ):ZMod (M*p)) + x0 = x0 := this
        have := add_right_cancel (a := ((q0*s*M:ℕ):ZMod (M*p))) (b := x0) (c := (0:ZMod (M*p)))
        rw [zero_add] at this
        exact this heq
      exact (ZMod.natCast_eq_zero_iff (q0*s*M) (M*p)).mp hz
    have hpdvd : p ∣ q0*s := by
      obtain ⟨k, hk⟩ := hdvd1
      refine ⟨k, ?_⟩
      have hM0 : M ≠ 0 := by omega
      have : M * (q0*s) = M * (p*k) := by
        have hk' : q0*s*M = (M*p)*k := hk
        nlinarith [hk']
      exact Nat.eq_of_mul_eq_mul_left (by omega) this
    have hpq0 : p ∣ q0 := (hpp.dvd_mul.mp hpdvd).resolve_right hndvd
    have hge : ℓ*p ≤ period σ x0 := by
      rw [hq0]
      have : p ≤ q0 := Nat.le_of_dvd hq0pos hpq0
      exact Nat.mul_le_mul_left ℓ this
    have : period σ x0 = ℓ*p := le_antisymm hle hge
    rw [if_neg hs0]
    exact this

end PeriodComputation

/-! ### The full cycle-type structure (completing items (2)-(3) of `XNH_eq_blockSum`'s roadmap)

`periodOrbit m a` realizes the `MulAction.period`-orbit of `a` under `m` as an explicit `Finset`
(`mem_periodOrbit`, `card_periodOrbit`, `pow_mem_periodOrbit`, `periodOrbit_injOn`).
`blockCycleLabels` is the `p * ℓ` labels lying above a block-cycle of `τ` through `b0`
(`card_blockCycleLabels` computes its cardinality via a fiber-counting bijection,
`card_fiber_blkFin`). `periodOrbit_subset_blockCycleLabels` shows `x0`'s `σ`-orbit lies inside it;
combined with `period_sigma_eq` and a cardinality argument,
`periodOrbit_eq_blockCycleLabels_of_shift_ne_zero` gives the **nonzero-shift case**: `x0`'s orbit
*is* the entire `pℓ`-label set (a single `pℓ`-cycle). `period_translate_eq` shows the `σ`-period is
the same for every point in `x0`'s block; combined with `periodOrbit_translate` (orbits of
translates are translates of the orbit) and an explicit subset/superset argument,
`blockCycleLabels_eq_biUnion_translates` gives the **zero-shift case**: the `pℓ`-label set is the
union of the `p` translated orbits `periodOrbit σ (x0 + j•h0)` (`j = 0, …, p-1`), each of size `ℓ`
by `period_translate_eq` + `period_sigma_eq`. This completes items (2)-(3) of the roadmap: what
remains for `XNH_eq_blockSum` is item (4), the block-level peeling induction / bijection -- see the
status summary at the bottom of the file. -/

section OrbitFinset

open MulAction

/-- The orbit of `a` under `m`, as a `Finset`, realized via `Finset.range (period m a)`. -/
noncomputable def periodOrbit {α M : Type*} [Monoid M] [MulAction M α] [Fintype α] [DecidableEq α]
    (m : M) (a : α) : Finset α :=
  Finset.image (fun k => m^k • a) (Finset.range (period m a))

theorem mem_periodOrbit {α M : Type*} [Monoid M] [MulAction M α] [Fintype α] [DecidableEq α]
    (m : M) (a y : α) : y ∈ periodOrbit m a ↔ ∃ k < period m a, m^k • a = y := by
  unfold periodOrbit
  simp [Finset.mem_image, Finset.mem_range]

theorem periodOrbit_injOn {α M : Type*} [Monoid M] [MulAction M α] (m : M) (a : α) :
    Set.InjOn (fun k => m^k • a) (Finset.range (period m a) : Finset ℕ) := by
  intro k1 hk1 k2 hk2 heq
  simp only [Finset.coe_range, Set.mem_Iio] at hk1 hk2
  have h1 : (m • ·) ^[k1] a = (m • ·)^[k2] a := by
    rw [smul_iterate_apply, smul_iterate_apply]; exact heq
  have := Function.iterate_injOn_Iio_minimalPeriod (f := (m • ·)) (x := a)
  rw [← period_eq_minimalPeriod] at this
  exact this (Set.mem_Iio.mpr hk1) (Set.mem_Iio.mpr hk2) h1

theorem card_periodOrbit {α M : Type*} [Monoid M] [MulAction M α] [Fintype α] [DecidableEq α]
    (m : M) (a : α) : (periodOrbit m a).card = period m a := by
  unfold periodOrbit
  rw [Finset.card_image_of_injOn (periodOrbit_injOn m a), Finset.card_range]

theorem pow_mem_periodOrbit {α M : Type*} [Monoid M] [MulAction M α] [Fintype α] [DecidableEq α]
    (m : M) (a : α) (hppos : 0 < period m a) (k : ℕ) : m^k • a ∈ periodOrbit m a := by
  rw [mem_periodOrbit]
  exact ⟨k % period m a, Nat.mod_lt _ hppos, by rw [pow_mod_period_smul]⟩

end OrbitFinset

section BlockCycleLabels

open MulAction

variable {M p : ℕ} [NeZero (M * p)]

/-- The `p * ℓ` labels lying above a block-cycle of `τ := blockPerm hM hp1 hσ` through `b0`. -/
noncomputable def blockCycleLabels (hM : 0 < M) (hp1 : 1 < p) {σ : Equiv.Perm (ZMod (M*p))}
    (hσ : ((M:ℕ):ZMod (M*p)) +ᵥ σ = σ) (b0 : Fin M) : Finset (ZMod (M*p)) :=
  Finset.univ.filter (fun x => blkFin M p hM x ∈ periodOrbit (blockPerm hM hp1 hσ) b0)

theorem card_fiber_blkFin (hM : 0 < M) (hp1 : 1 < p) (b : Fin M) :
    (Finset.univ.filter (fun x : ZMod (M*p) => blkFin M p hM x = b)).card = p := by
  have hbij : (Finset.univ.filter (fun x : ZMod (M*p) => blkFin M p hM x = b))
      = Finset.image (fun j : Fin p => ((j.1*M:ℕ):ZMod (M*p)) + secBlk M p hM b) Finset.univ := by
    ext x
    simp only [Finset.mem_filter, Finset.mem_univ, true_and, Finset.mem_image]
    constructor
    · intro hx
      refine ⟨⟨posn M x, posn_lt hM x⟩, ?_⟩
      apply eq_of_blk_posn_eq hM
      · obtain ⟨b1, _⟩ := blk_posn_add_mul_M (M:=M) (p:=p) hM hp1 (posn M x) (secBlk M p hM b)
        rw [b1]
        have := blkFin_secBlk hM hp1 b
        have heq : blk M (secBlk M p hM b) = b.1 := congrArg Fin.val this
        rw [heq, ← hx]
        rfl
      · obtain ⟨_, b2⟩ := blk_posn_add_mul_M (M:=M) (p:=p) hM hp1 (posn M x) (secBlk M p hM b)
        rw [b2, posn_secBlk hM hp1 b, Nat.zero_add]
        exact Nat.mod_eq_of_lt (posn_lt hM x)
    · rintro ⟨j, rfl⟩
      apply Fin.ext
      show blk M (((j.1*M:ℕ):ZMod (M*p)) + secBlk M p hM b) = b.1
      obtain ⟨b1, _⟩ := blk_posn_add_mul_M (M:=M) (p:=p) hM hp1 j.1 (secBlk M p hM b)
      rw [b1]
      have := blkFin_secBlk hM hp1 b
      exact congrArg Fin.val this
  rw [hbij, Finset.card_image_of_injOn, Finset.card_univ, Fintype.card_fin]
  intro j1 _ j2 _ heq
  have h1 : posn M (((j1.1*M:ℕ):ZMod (M*p)) + secBlk M p hM b) = j1.1 := by
    obtain ⟨_, b2⟩ := blk_posn_add_mul_M (M:=M) (p:=p) hM hp1 j1.1 (secBlk M p hM b)
    rw [b2, posn_secBlk hM hp1 b, Nat.zero_add]
    exact Nat.mod_eq_of_lt j1.2
  have h2 : posn M (((j2.1*M:ℕ):ZMod (M*p)) + secBlk M p hM b) = j2.1 := by
    obtain ⟨_, b2⟩ := blk_posn_add_mul_M (M:=M) (p:=p) hM hp1 j2.1 (secBlk M p hM b)
    rw [b2, posn_secBlk hM hp1 b, Nat.zero_add]
    exact Nat.mod_eq_of_lt j2.2
  have hp1eq : posn M (((j1.1*M:ℕ):ZMod (M*p)) + secBlk M p hM b)
      = posn M (((j2.1*M:ℕ):ZMod (M*p)) + secBlk M p hM b) := congrArg (posn M) heq
  rw [h1, h2] at hp1eq
  exact Fin.ext hp1eq

end BlockCycleLabels

section BlockCycleLabelsCard

open MulAction

variable {M p : ℕ} [NeZero (M * p)]

theorem blockCycleLabels_eq_biUnion (hM : 0 < M) (hp1 : 1 < p) {σ : Equiv.Perm (ZMod (M*p))}
    (hσ : ((M:ℕ):ZMod (M*p)) +ᵥ σ = σ) (b0 : Fin M) :
    blockCycleLabels hM hp1 hσ b0
      = (periodOrbit (blockPerm hM hp1 hσ) b0).biUnion
          (fun b => Finset.univ.filter (fun x : ZMod (M*p) => blkFin M p hM x = b)) := by
  unfold blockCycleLabels
  ext x
  simp only [Finset.mem_filter, Finset.mem_univ, true_and, Finset.mem_biUnion]
  constructor
  · intro hx; exact ⟨blkFin M p hM x, hx, rfl⟩
  · rintro ⟨b, hb, hxb⟩; rw [hxb]; exact hb

theorem card_blockCycleLabels (hM : 0 < M) (hp1 : 1 < p) {σ : Equiv.Perm (ZMod (M*p))}
    (hσ : ((M:ℕ):ZMod (M*p)) +ᵥ σ = σ) (b0 : Fin M) :
    (blockCycleLabels hM hp1 hσ b0).card = p * (periodOrbit (blockPerm hM hp1 hσ) b0).card := by
  rw [blockCycleLabels_eq_biUnion hM hp1 hσ b0]
  rw [Finset.card_biUnion]
  · simp_rw [card_fiber_blkFin hM hp1]
    rw [Finset.sum_const, smul_eq_mul, mul_comm]
  · intro b1 _ b2 hb2 hne
    simp only [Finset.disjoint_left, Finset.mem_filter, Finset.mem_univ, true_and]
    intro x hx1 hx2
    exact hne (hx1 ▸ hx2 ▸ rfl : b1 = b2) |>.elim

end BlockCycleLabelsCard

section OrbitStructure

open MulAction

variable {M p : ℕ} [NeZero (M * p)]

theorem periodOrbit_subset_blockCycleLabels (hM : 0 < M) (hp1 : 1 < p)
    {σ : Equiv.Perm (ZMod (M*p))} (hσ : ((M:ℕ):ZMod (M*p)) +ᵥ σ = σ) (b0 : Fin M) :
    periodOrbit σ (secBlk M p hM b0) ⊆ blockCycleLabels hM hp1 hσ b0 := by
  intro x hx
  rw [mem_periodOrbit] at hx
  obtain ⟨k, _, hk⟩ := hx
  have hkval : (σ^k) (secBlk M p hM b0) = x := hk
  unfold blockCycleLabels
  rw [Finset.mem_filter]
  refine ⟨Finset.mem_univ _, ?_⟩
  rw [← hkval]
  have h1 : blkFin M p hM ((σ^k) (secBlk M p hM b0))
      = ((blockPerm hM hp1 hσ)^k) (blkFin M p hM (secBlk M p hM b0)) := blkFin_pow hM hp1 hσ k _
  rw [blkFin_secBlk hM hp1] at h1
  rw [h1]
  have hℓpos : 0 < period (blockPerm hM hp1 hσ) b0 :=
    period_pos_of_orderOf_pos (orderOf_pos (blockPerm hM hp1 hσ)) b0
  exact pow_mem_periodOrbit (blockPerm hM hp1 hσ) b0 hℓpos k

/-- **The nonzero-shift case: a single `pℓ`-cycle.** If the total shift around the block-cycle
through `b0` is nonzero, `x0 := secBlk M p hM b0`'s `σ`-orbit is *all* of `blockCycleLabels`. -/
theorem periodOrbit_eq_blockCycleLabels_of_shift_ne_zero (hM : 0 < M) (hp1 : 1 < p)
    (hpp : p.Prime) {σ : Equiv.Perm (ZMod (M*p))} (hσ : ((M:ℕ):ZMod (M*p)) +ᵥ σ = σ)
    (b0 : Fin M)
    (hs : posn M ((σ ^ period (blockPerm hM hp1 hσ) b0) (secBlk M p hM b0)) ≠ 0) :
    periodOrbit σ (secBlk M p hM b0) = blockCycleLabels hM hp1 hσ b0 := by
  apply Finset.eq_of_subset_of_card_le (periodOrbit_subset_blockCycleLabels hM hp1 hσ b0)
  rw [card_periodOrbit, card_blockCycleLabels hM hp1 hσ b0, card_periodOrbit]
  rw [period_sigma_eq hM hp1 hpp hσ b0]
  rw [if_neg hs]
  exact le_of_eq (mul_comm p _)

end OrbitStructure

section ZeroShiftCase

open MulAction

variable {M p : ℕ} [NeZero (M * p)]

theorem period_eq_of_iff_dvd {P Q : ℕ} (h : ∀ k, P ∣ k ↔ Q ∣ k) : P = Q :=
  Nat.dvd_antisymm ((h Q).mpr dvd_rfl) ((h P).mp dvd_rfl)

/-- **The `σ`-period is translation-invariant within a block-cycle.** -/
theorem period_translate_eq (hM : 0 < M) (hp1 : 1 < p) {σ : Equiv.Perm (ZMod (M*p))}
    (hσ : ((M:ℕ):ZMod (M*p)) +ᵥ σ = σ) (x0 : ZMod (M*p)) (j : ℕ) :
    period σ (((j*M:ℕ):ZMod (M*p)) + x0) = period σ x0 := by
  apply period_eq_of_iff_dvd
  intro k
  rw [← pow_smul_eq_iff_period_dvd, ← pow_smul_eq_iff_period_dvd]
  show (σ^k) (((j*M:ℕ):ZMod (M*p)) + x0) = ((j*M:ℕ):ZMod (M*p)) + x0 ↔ (σ^k) x0 = x0
  rw [equivariance_mul_M_pow hσ]
  constructor
  · intro h; exact add_left_cancel h
  · intro h; rw [h]

/-- In the zero-shift case (`period σ x0 = period τ b0`), `x0`'s `σ`-orbit visits pairwise
distinct blocks. -/
theorem blkFin_inj_on_periodOrbit (hM : 0 < M) (hp1 : 1 < p) {σ : Equiv.Perm (ZMod (M*p))}
    (hσ : ((M:ℕ):ZMod (M*p)) +ᵥ σ = σ) (b0 : Fin M)
    (hℓeq : period σ (secBlk M p hM b0) = period (blockPerm hM hp1 hσ) b0)
    {y1 y2 : ZMod (M*p)}
    (hy1 : y1 ∈ periodOrbit σ (secBlk M p hM b0)) (hy2 : y2 ∈ periodOrbit σ (secBlk M p hM b0))
    (heq : blkFin M p hM y1 = blkFin M p hM y2) : y1 = y2 := by
  rw [mem_periodOrbit] at hy1 hy2
  obtain ⟨k1, hk1, hk1'⟩ := hy1
  obtain ⟨k2, hk2, hk2'⟩ := hy2
  rw [hℓeq] at hk1 hk2
  have hv1 : (σ^k1) (secBlk M p hM b0) = y1 := hk1'
  have hv2 : (σ^k2) (secBlk M p hM b0) = y2 := hk2'
  have hb1 : blkFin M p hM ((σ^k1) (secBlk M p hM b0))
      = ((blockPerm hM hp1 hσ)^k1) (blkFin M p hM (secBlk M p hM b0)) := blkFin_pow hM hp1 hσ k1 _
  have hb2 : blkFin M p hM ((σ^k2) (secBlk M p hM b0))
      = ((blockPerm hM hp1 hσ)^k2) (blkFin M p hM (secBlk M p hM b0)) := blkFin_pow hM hp1 hσ k2 _
  rw [blkFin_secBlk hM hp1] at hb1 hb2
  rw [hv1] at hb1; rw [hv2] at hb2
  have hτeq : ((blockPerm hM hp1 hσ)^k1) b0 = ((blockPerm hM hp1 hσ)^k2) b0 := by
    rw [← hb1, ← hb2, heq]
  have hk1v : (blockPerm hM hp1 hσ)^k1 • b0 = ((blockPerm hM hp1 hσ)^k2) b0 := hτeq
  have hk12 : k1 = k2 := periodOrbit_injOn (blockPerm hM hp1 hσ) b0
    (by simp only [Finset.coe_range, Set.mem_Iio]; exact hk1)
    (by simp only [Finset.coe_range, Set.mem_Iio]; exact hk2) hk1v
  rw [← hv1, ← hv2, hk12]

theorem periodOrbit_translate (hM : 0 < M) (hp1 : 1 < p) {σ : Equiv.Perm (ZMod (M*p))}
    (hσ : ((M:ℕ):ZMod (M*p)) +ᵥ σ = σ) (x0 : ZMod (M*p)) (j : ℕ) :
    periodOrbit σ (((j*M:ℕ):ZMod (M*p)) + x0)
      = Finset.image (fun y => ((j*M:ℕ):ZMod (M*p)) + y) (periodOrbit σ x0) := by
  unfold periodOrbit
  rw [period_translate_eq hM hp1 hσ]
  rw [Finset.image_image]
  apply Finset.image_congr
  intro k _
  show (σ^k) (((j*M:ℕ):ZMod (M*p)) + x0) = ((j*M:ℕ):ZMod (M*p)) + (σ^k) x0
  exact equivariance_mul_M_pow hσ j k x0

/-- **The zero-shift case: `p` disjoint `ℓ`-cycles partitioning `blockCycleLabels`.** -/
theorem blockCycleLabels_eq_biUnion_translates (hM : 0 < M) (hp1 : 1 < p) (hpp : p.Prime)
    {σ : Equiv.Perm (ZMod (M*p))} (hσ : ((M:ℕ):ZMod (M*p)) +ᵥ σ = σ) (b0 : Fin M)
    (hs : posn M ((σ ^ period (blockPerm hM hp1 hσ) b0) (secBlk M p hM b0)) = 0) :
    blockCycleLabels hM hp1 hσ b0
      = (Finset.range p).biUnion
          (fun j => periodOrbit σ (((j*M:ℕ):ZMod (M*p)) + secBlk M p hM b0)) := by
  have hsub : (Finset.range p).biUnion
      (fun j => periodOrbit σ (((j*M:ℕ):ZMod (M*p)) + secBlk M p hM b0))
      ⊆ blockCycleLabels hM hp1 hσ b0 := by
    intro z hz
    rw [Finset.mem_biUnion] at hz
    obtain ⟨j, _, hj⟩ := hz
    rw [periodOrbit_translate hM hp1 hσ] at hj
    rw [Finset.mem_image] at hj
    obtain ⟨y, hy, rfl⟩ := hj
    have hyT := periodOrbit_subset_blockCycleLabels hM hp1 hσ b0 hy
    unfold blockCycleLabels at hyT ⊢
    rw [Finset.mem_filter] at hyT ⊢
    refine ⟨Finset.mem_univ _, ?_⟩
    have heqb : blkFin M p hM (((j*M:ℕ):ZMod (M*p)) + y) = blkFin M p hM y := by
      apply Fin.ext
      obtain ⟨b1, _⟩ := blk_posn_add_mul_M (M:=M) (p:=p) hM hp1 j y
      exact b1
    rw [heqb]
    exact hyT.2
  apply Finset.Subset.antisymm _ hsub
  intro z hz
  rw [Finset.mem_biUnion]
  -- z lies above the block-cycle; find its H-position `j` and the base point `x0 + jM`.
  unfold blockCycleLabels at hz
  rw [Finset.mem_filter] at hz
  obtain ⟨-, hzmem⟩ := hz
  rw [mem_periodOrbit] at hzmem
  obtain ⟨k, hk, hzk⟩ := hzmem
  set x0 := secBlk M p hM b0 with hx0def
  have hℓσ : period σ x0 = period (blockPerm hM hp1 hσ) b0 := by
    rw [period_sigma_eq hM hp1 hpp hσ b0, if_pos hs, mul_one]
  have hkσ : k < period σ x0 := by rw [hℓσ]; exact hk
  set y := (σ^k) x0 with hydef
  have hyorb : y ∈ periodOrbit σ x0 := by
    rw [mem_periodOrbit]; exact ⟨k, hkσ, rfl⟩
  have hby : blkFin M p hM y = ((blockPerm hM hp1 hσ)^k) b0 := by
    have := blkFin_pow hM hp1 hσ k x0
    rw [hx0def, blkFin_secBlk hM hp1] at this
    exact this
  have hblkeq : blk M y = blk M z := by
    have h1 : blkFin M p hM y = blkFin M p hM z := hby.trans hzk
    exact congrArg Fin.val h1
  obtain ⟨j, hjp, hjeq⟩ := exists_c_of_blk_eq hM hp1 hblkeq
  refine ⟨j, Finset.mem_range.mpr hjp, ?_⟩
  rw [periodOrbit_translate hM hp1 hσ]
  rw [Finset.mem_image]
  exact ⟨y, hyorb, hjeq.symm⟩

end ZeroShiftCase

/- ### Item (4a): the block-level exponential formula recursion

This is a direct generalization of `ProductCongruence.lean`'s `permSum`/`CycleFinset`/
`permSum_succ_recurrence` machinery, replacing `numDivisors` with `blockWeight p`. The key
technical subtlety (**caught by a numeric counterexample, not just estimated**): the naive
generalization `blockPermWeightPiece p σ = blockPermWeightPiece p (σ.cycleOf x0) *
blockPermWeightPiece p (ρPerm hS)` (mirroring `permWeight_eq_mul` verbatim) is **false**, because
`blockPermWeightPiece`'s "fixed-point correction" `(blockWeight p 1)^(Fintype.card α -
support.card)` is *global* (relative to the whole ambient type `α`), so naively multiplying the
`cycleOf x0`-piece (which is identity, hence "fixed", on all of `Sᶜ`) by the `ρPerm`-piece (which
separately re-accounts for `Sᶜ`) double-counts `Sᶜ`'s fixed points. Concretely, for `α = Fin 2`,
`S = {0}`, `σ = 1`: direct computation gives `blockPermWeightPiece p σ = (blockWeight p 1)^2`,
but the naive product gives `(blockWeight p 1)^2 * (blockWeight p 1) = (blockWeight p 1)^3 ≠
(blockWeight p 1)^2` whenever `blockWeight p 1 ≠ 0, 1` (e.g. `p = 3` gives `blockWeight 3 1 = 5`).
The *corrected* multiplicativity (`blockPermWeightPiece_eq_mul` below) instead factors as the
**local** block-cycle weight `blockWeight p S.card` (not the global `cycleOf x0`-piece) times the
`ρPerm`-piece; the proof carefully separates the exponent `Fintype.card α - σ.support.card` into
an `S`-local part (`S.card - (cycleOf x0).support.card`, which equals `S.card` when `S.card = 1`
and `0` when `S.card ≥ 2` -- correctly recovering `blockWeight p S.card` in both cases) and an
`Sᶜ`-local part (matching `blockPermWeightPiece p (ρPerm hS)`'s own correction exactly, no
double-counting). Once this is fixed, `sum_orbitAt_eq_block`, `blockPermSum_congr`, and
`blockPermSum_succ_recurrence` are direct (if lengthy) adaptations of `ProductCongruence.lean`'s
`sum_orbitAt_eq`/`permSum_congr`/`permSum_succ_recurrence`, and
`blockPermSum_eq_sum_blockPermWeight` bridges back to `blockPermWeight` (defined above only for
`Fin M`; `blockPermWeightPiece`/`blockPermSum` generalize it to any finite type, matching how
`permWeight`/`permSum` are generic). This completes item (4a) of `XNH_eq_blockSum`'s roadmap: the
block-level exponential-formula recursion. What remains is item (4b): the bijection between
`H`-fixed permutations of `ZMod N` and (block permutation, shift-tuple-per-block-cycle) pairs that
would let this recursion be transferred to `∑_{H-fixed σ} permWeight σ` -- see the status summary
at the bottom of the file. -/

section GeneralizedBlockPermSum

variable {α : Type*} [Fintype α] [DecidableEq α]

def blockPermWeightPiece (p : ℕ) (τ : Equiv.Perm α) : ℤ :=
  (τ.cycleType.map (blockWeight p)).prod * (blockWeight p 1) ^ (Fintype.card α - τ.support.card)

def blockPermSum (p : ℕ) (α : Type*) [Fintype α] [DecidableEq α] : ℤ :=
  ∑ τ : Equiv.Perm α, blockPermWeightPiece p τ

/-- **Corrected multiplicativity.** For `σ` with `orbitAt σ x0 = S`, `blockPermWeightPiece`
factors as the *local* block-cycle weight `blockWeight p S.card` (not
`blockPermWeightPiece p (σ.cycleOf x0)`, which would double-count fixed points of `Sᶜ` -- see
the file's status summary for the numeric counterexample that caught this) times the piece for
the complement. -/
theorem blockPermWeightPiece_eq_mul (p : ℕ) {σ : Equiv.Perm α} {x0 : α} {S : Finset α}
    (hx0 : x0 ∈ S) (hS : orbitAt σ x0 = S) :
    blockPermWeightPiece p σ = blockWeight p S.card * blockPermWeightPiece p (ρPerm hS) := by
  have hcycle : σ.cycleType = (σ.cycleOf x0).cycleType + (ρPerm hS).cycleType := by
    conv_lhs => rw [← cycleOf_mul_ofSubtype_ρPerm hS]
    rw [(disjoint_cycleOf_ofSubtype_ρPerm hS).cycleType_mul, Equiv.Perm.cycleType_ofSubtype]
  have hsupp : σ.support.card = (σ.cycleOf x0).support.card + (ρPerm hS).support.card := by
    rw [← Equiv.Perm.sum_cycleType, ← Equiv.Perm.sum_cycleType, ← Equiv.Perm.sum_cycleType,
      hcycle, Multiset.sum_add]
  have hcardS : S.card + Fintype.card (↥(Sᶜ : Finset α)) = Fintype.card α := by
    rw [Fintype.card_coe, Finset.card_compl]
    have hle := S.card_le_univ
    omega
  have hSeq_of_two_le : ∀ (hcyc : (σ.cycleOf x0).IsCycle) (hx0mem : x0 ∈ (σ.cycleOf x0).support),
      S = (σ.cycleOf x0).support := by
    intro hcyc hx0mem
    have hsupp_eq : orbitAt (σ.cycleOf x0) x0 = (σ.cycleOf x0).support := by
      unfold orbitAt
      rw [cycleOf_cycleOf_self]
      exact Finset.insert_eq_self.mpr hx0mem
    rw [orbitAt_cycleOf_self, hS] at hsupp_eq
    exact hsupp_eq
  have hSeq_of_one : σ.cycleOf x0 = 1 → S = {x0} := by
    intro h1
    have hor : orbitAt σ x0 = {x0} := by
      unfold orbitAt
      rw [h1]
      simp
    rw [hS] at hor
    exact hor
  have hSge : (σ.cycleOf x0).support.card ≤ S.card := by
    rcases eq_one_or_isCycle_of_cycleOf_self_eq (cycleOf_cycleOf_self σ x0) with h1 | ⟨hcyc, hx0mem⟩
    · rw [h1]; simp
    · rw [hSeq_of_two_le hcyc hx0mem]
  have hρge : (ρPerm hS).support.card ≤ Fintype.card (↥(Sᶜ : Finset α)) :=
    (ρPerm hS).support.card_le_univ
  -- The local weight `blockWeight p S.card` matches `(cycleOf x0).cycleType.map blockWeight).prod
  -- * (blockWeight p 1)^(S.card - (cycleOf x0).support.card)` in both the trivial (`S.card = 1`)
  -- and genuine-cycle (`S.card ≥ 2`) cases.
  have hlocal : (((σ.cycleOf x0).cycleType.map (blockWeight p)).prod)
      * (blockWeight p 1) ^ (S.card - (σ.cycleOf x0).support.card) = blockWeight p S.card := by
    rcases eq_one_or_isCycle_of_cycleOf_self_eq (cycleOf_cycleOf_self σ x0) with h1 | ⟨hcyc, hx0mem⟩
    · have hS1 : S.card = 1 := by rw [hSeq_of_one h1]; simp
      rw [h1]
      simp [hS1]
    · have hSeq := hSeq_of_two_le hcyc hx0mem
      rw [hcyc.cycleType, ← hSeq]
      simp
  unfold blockPermWeightPiece
  rw [hcycle, Multiset.map_add, Multiset.prod_add]
  have hexp : Fintype.card α - σ.support.card
      = (S.card - (σ.cycleOf x0).support.card) + (Fintype.card (↥(Sᶜ : Finset α)) - (ρPerm hS).support.card) := by
    omega
  rw [hexp, pow_add]
  rw [← hlocal]
  ring

end GeneralizedBlockPermSum

section SumOrbitBlock

variable {α : Type*} [Fintype α] [DecidableEq α]

theorem sum_orbitAt_eq_block (p : ℕ) (x0 : α) (S : Finset α) (hx0 : x0 ∈ S) :
    ∑ σ ∈ Finset.univ.filter (fun σ : Equiv.Perm α => orbitAt σ x0 = S), blockPermWeightPiece p σ
      = (Nat.factorial (S.card - 1) : ℤ) * blockWeight p S.card
          * blockPermSum p (↥(Sᶜ : Finset α)) := by
  classical
  have hCFcard : (CycleFinset x0 S).card = Nat.factorial (S.card - 1) := by
    rcases Nat.lt_or_ge S.card 2 with hS1 | hS2
    · have hS1' : S.card = 1 := by
        have hpos : 1 ≤ S.card := Finset.card_pos.mpr ⟨x0, hx0⟩
        omega
      rw [CycleFinset_card_one hx0 hS1', hS1']
      simp
    · rw [CycleFinset_eq_of_two_le hx0 hS2, card_isCycle_support_eq hS2]
  have hprod : (Nat.factorial (S.card-1):ℤ) * blockWeight p S.card * blockPermSum p (↥(Sᶜ : Finset α))
      = ∑ q ∈ CycleFinset x0 S ×ˢ (Finset.univ : Finset (Equiv.Perm (↥(Sᶜ : Finset α)))),
          blockWeight p S.card * blockPermWeightPiece p q.2 := by
    rw [Finset.sum_product]
    unfold blockPermSum
    simp_rw [← Finset.mul_sum]
    rw [← hCFcard, Finset.sum_const, nsmul_eq_mul]
    ring
  rw [hprod]
  apply Finset.sum_bij'
    (i := fun (σ : Equiv.Perm α)
        (hσ : σ ∈ Finset.univ.filter (fun σ : Equiv.Perm α => orbitAt σ x0 = S)) =>
      (σ.cycleOf x0, ρPerm (Finset.mem_filter.mp hσ).2))
    (j := fun (q : Equiv.Perm α × Equiv.Perm (↥(Sᶜ : Finset α)))
        (_ : q ∈ CycleFinset x0 S ×ˢ (Finset.univ : Finset (Equiv.Perm (↥(Sᶜ : Finset α))))) =>
      q.1 * Equiv.Perm.ofSubtype q.2)
    ?_ ?_ ?_ ?_ ?_
  · intro σ hσ
    rw [Finset.mem_product]
    exact ⟨cycleOf_mem_CycleFinset (Finset.mem_filter.mp hσ).2, Finset.mem_univ _⟩
  · intro q hq
    rw [Finset.mem_filter]
    refine ⟨Finset.mem_univ _, ?_⟩
    exact orbitAt_mul_ofSubtype (Finset.mem_product.mp hq).1 q.2
  · intro σ hσ
    exact cycleOf_mul_ofSubtype_ρPerm (Finset.mem_filter.mp hσ).2
  · intro q hq
    have hq1 : q.1 ∈ CycleFinset x0 S := (Finset.mem_product.mp hq).1
    refine Prod.ext (cycleOf_mul_ofSubtype_eq hq1 q.2) ?_
    exact ρPerm_mul_ofSubtype hq1 q.2 (orbitAt_mul_ofSubtype hq1 q.2)
  · intro σ hσ
    exact blockPermWeightPiece_eq_mul p hx0 (Finset.mem_filter.mp hσ).2

end SumOrbitBlock

section BlockPermSumCongr

variable {α β : Type*} [Fintype α] [DecidableEq α] [Fintype β] [DecidableEq β]

theorem blockPermWeightPiece_permCongr (p : ℕ) (e : α ≃ β) (σ : Equiv.Perm α) :
    blockPermWeightPiece p (e.permCongr σ) = blockPermWeightPiece p σ := by
  unfold blockPermWeightPiece
  rw [cycleType_permCongr]
  have hcard : Fintype.card β = Fintype.card α := (Fintype.card_congr e).symm
  have hsupp : (e.permCongr σ).support.card = σ.support.card := by
    rw [← Equiv.Perm.sum_cycleType, ← Equiv.Perm.sum_cycleType, cycleType_permCongr]
  rw [hcard, hsupp]

theorem blockPermSum_congr (p : ℕ) (e : α ≃ β) : blockPermSum p α = blockPermSum p β := by
  unfold blockPermSum
  rw [Finset.sum_congr rfl (fun σ (_ : σ ∈ Finset.univ) =>
    (blockPermWeightPiece_permCongr p e σ).symm)]
  exact Equiv.sum_comp e.permCongr (fun τ => blockPermWeightPiece p τ)

end BlockPermSumCongr

section BlockPermSumRecurrence

theorem blockPermSum_succ_recurrence (p n : ℕ) :
    blockPermSum p (Fin (n + 1)) = ∑ m ∈ Finset.Icc 1 (n + 1),
      (Nat.choose n (m - 1) : ℤ) * (Nat.factorial (m - 1) : ℤ) * blockWeight p m
        * blockPermSum p (Fin (n + 1 - m)) := by
  classical
  have hstep1 : blockPermSum p (Fin (n + 1)) =
      ∑ S ∈ Finset.univ.filter (fun S : Finset (Fin (n + 1)) => (0 : Fin (n + 1)) ∈ S),
        ∑ σ ∈ Finset.univ.filter
          (fun σ : Equiv.Perm (Fin (n + 1)) => orbitAt σ (0 : Fin (n + 1)) = S),
          blockPermWeightPiece p σ := by
    unfold blockPermSum
    exact (Finset.sum_fiberwise_of_maps_to
      (t := Finset.univ.filter (fun S : Finset (Fin (n + 1)) => (0 : Fin (n + 1)) ∈ S))
      (fun σ (_ : σ ∈ (Finset.univ : Finset (Equiv.Perm (Fin (n + 1))))) =>
        Finset.mem_filter.mpr ⟨Finset.mem_univ _, x0_mem_orbitAt σ (0 : Fin (n + 1))⟩)
      (blockPermWeightPiece p)).symm
  have hstep2 : ∀ S ∈ Finset.univ.filter (fun S : Finset (Fin (n + 1)) => (0 : Fin (n + 1)) ∈ S),
      ∑ σ ∈ Finset.univ.filter
        (fun σ : Equiv.Perm (Fin (n + 1)) => orbitAt σ (0 : Fin (n + 1)) = S),
        blockPermWeightPiece p σ
        = (Nat.factorial (S.card - 1) : ℤ) * blockWeight p S.card
            * blockPermSum p (Fin ((n + 1) - S.card)) := by
    intro S hS
    rw [Finset.mem_filter] at hS
    have hcardeq : Fintype.card (↥(Sᶜ : Finset (Fin (n + 1)))) = (n + 1) - S.card := by
      rw [Fintype.card_coe, Finset.card_compl, Fintype.card_fin]
    rw [sum_orbitAt_eq_block p (0 : Fin (n + 1)) S hS.2,
      blockPermSum_congr p (Fintype.equivFinOfCardEq hcardeq)]
  rw [hstep1, Finset.sum_congr rfl hstep2]
  have hstep3 : ∑ S ∈ Finset.univ.filter (fun S : Finset (Fin (n + 1)) => (0 : Fin (n + 1)) ∈ S),
      ((Nat.factorial (S.card - 1) : ℤ) * blockWeight p S.card
        * blockPermSum p (Fin ((n + 1) - S.card)))
      = ∑ m ∈ Finset.Icc 1 (n + 1),
          ∑ S ∈ (Finset.univ.filter
              (fun S : Finset (Fin (n + 1)) => (0 : Fin (n + 1)) ∈ S)) with S.card = m,
            ((Nat.factorial (S.card - 1) : ℤ) * blockWeight p S.card
              * blockPermSum p (Fin ((n + 1) - S.card))) := by
    exact (Finset.sum_fiberwise_of_maps_to
      (t := Finset.Icc 1 (n + 1))
      (fun S (hS : S ∈ Finset.univ.filter
          (fun S : Finset (Fin (n + 1)) => (0 : Fin (n + 1)) ∈ S)) => by
        rw [Finset.mem_filter] at hS
        rw [Finset.mem_Icc]
        refine ⟨Finset.card_pos.mpr ⟨(0 : Fin (n + 1)), hS.2⟩, ?_⟩
        calc S.card ≤ Fintype.card (Fin (n + 1)) := Finset.card_le_univ S
          _ = n + 1 := Fintype.card_fin _)
      (fun S => (Nat.factorial (S.card - 1) : ℤ) * blockWeight p S.card
        * blockPermSum p (Fin ((n + 1) - S.card)))).symm
  rw [hstep3]
  refine Finset.sum_congr rfl (fun m hm => ?_)
  rw [Finset.mem_Icc] at hm
  have hconst : ∀ S ∈ Finset.filter (fun S : Finset (Fin (n + 1)) => S.card = m)
      (Finset.univ.filter (fun S : Finset (Fin (n + 1)) => (0 : Fin (n + 1)) ∈ S)),
      ((Nat.factorial (S.card - 1) : ℤ) * blockWeight p S.card
        * blockPermSum p (Fin ((n + 1) - S.card)))
      = (Nat.factorial (m - 1) : ℤ) * blockWeight p m * blockPermSum p (Fin ((n + 1) - m)) := by
    intro S hS
    rw [Finset.mem_filter] at hS
    rw [hS.2]
  rw [Finset.sum_congr rfl hconst, Finset.sum_const]
  have hcardS : (Finset.filter (fun S : Finset (Fin (n + 1)) => S.card = m)
      (Finset.univ.filter (fun S : Finset (Fin (n + 1)) => (0 : Fin (n + 1)) ∈ S))).card
      = n.choose (m - 1) := by
    have heq : Finset.filter (fun S : Finset (Fin (n + 1)) => S.card = m)
        (Finset.univ.filter (fun S : Finset (Fin (n + 1)) => (0 : Fin (n + 1)) ∈ S))
        = Finset.univ.filter
            (fun S : Finset (Fin (n + 1)) => (0 : Fin (n + 1)) ∈ S ∧ S.card = m) := by
      ext S
      simp only [Finset.mem_filter, Finset.mem_univ, true_and]
    rw [heq]
    exact card_filter_zero_mem_card_eq n m (by omega)
  rw [hcardS, nsmul_eq_mul]
  ring

end BlockPermSumRecurrence

/-- Bridges the generic `blockPermSum`/`blockPermWeightPiece` (defined for any finite type, item
(4a)'s natural setting) back to `blockPermWeight` (defined above only for `Fin M`, matching
`XNH_eq_blockSum`'s statement). -/
theorem blockPermSum_eq_sum_blockPermWeight (p M : ℕ) :
    blockPermSum p (Fin M) = ∑ τ : Equiv.Perm (Fin M), blockPermWeight p M τ := by
  unfold blockPermSum blockPermWeight blockPermWeightPiece
  simp_rw [Fintype.card_fin]

/- ### Item (4b): constructively assembling an `H`-fixed permutation from block data

The converse/constructive direction to items (2)-(3) (which only *analyzed* a *given* `H`-fixed
`σ`): given a block permutation `τ : Equiv.Perm (Fin M)` and a shift function `t : Fin M → ZMod p`
assigning a shift to *every* block (not just one block-cycle), `assembledFun`/`assembledSigma`
directly constructs a permutation `x ↦` "the point in block `τ (blkFin x)` at position
`posn x + t (blkFin x)`". This single global construction (no recursion, no "remaining/smaller"
permutation needed) is bijective (`assembledFun_injective`, via `Finite.injective_iff_bijective`
as suggested) and `H`-fixed (`assembledSigma_H_fixed`, via a converse of `equivariance_of_H_fixed`
proved here as `H_fixed_of_equivariant`). `tExtract` recovers `t` from a given `H`-fixed `σ`
(`tExtract σ b := posn (σ (secBlk b))`), and `assembledSigma_tExtract_eq` is the key round-trip
identity `assembledSigma (blockPerm σ) (tExtract σ) = σ`, proved via `reconstruct` (every label is
its block's canonical representative shifted by its own position) plus `equivariance_mul_M`. What
remains: injectivity of `(τ,t) ↦ assembledSigma τ t` (the other round-trip direction, expected to
be short given the structural facts already in hand) to get the full bijection
`Equiv.Perm (Fin M) × (Fin M → ZMod p) ≃ {H-fixed σ}`, and then the weight-matching computation
`∑_t permWeight (assembledSigma τ t) = blockPermWeightPiece p τ` (via `period_sigma_eq` and the
cycle-structure lemmas above, now *applied* to `assembledSigma τ t` rather than re-derived) to
finish `XNH_eq_blockSum`. See the status summary at the bottom of the file. -/

section Assemble

variable {M p : ℕ} [NeZero (M * p)]

/-- **The assembled permutation.** Given a block permutation `τ` and a "shift" `t : Fin M →
ZMod p` assigning a shift to *every* block, directly construct a permutation of `ZMod (M*p)`:
`x` (in block `b := blkFin x`) maps to the point in block `τ b` at position `posn x + t b`. -/
def assembledFun (hM : 0 < M) (τ : Equiv.Perm (Fin M)) (t : Fin M → ZMod p) (x : ZMod (M*p)) :
    ZMod (M*p) :=
  (((((posn M x : ZMod p) + t (blkFin M p hM x)).val * M : ℕ) : ZMod (M*p)))
    + secBlk M p hM (τ (blkFin M p hM x))

theorem blkFin_assembledFun (hM : 0 < M) (hp1 : 1 < p) (τ : Equiv.Perm (Fin M))
    (t : Fin M → ZMod p) (x : ZMod (M*p)) :
    blkFin M p hM (assembledFun hM τ t x) = τ (blkFin M p hM x) := by
  unfold assembledFun
  apply Fin.ext
  show blk M (((((posn M x : ZMod p) + t (blkFin M p hM x)).val * M : ℕ) : ZMod (M*p))
    + secBlk M p hM (τ (blkFin M p hM x))) = _
  obtain ⟨b1, _⟩ := blk_posn_add_mul_M (M:=M) (p:=p) hM hp1
    (((posn M x : ZMod p) + t (blkFin M p hM x)).val) (secBlk M p hM (τ (blkFin M p hM x)))
  rw [b1]
  have := blkFin_secBlk hM hp1 (τ (blkFin M p hM x))
  exact congrArg Fin.val this

theorem posn_assembledFun (hM : 0 < M) (hp1 : 1 < p) (τ : Equiv.Perm (Fin M))
    (t : Fin M → ZMod p) (x : ZMod (M*p)) :
    (posn M (assembledFun hM τ t x) : ZMod p) = (posn M x : ZMod p) + t (blkFin M p hM x) := by
  haveI hpNZ : NeZero p := ⟨by omega⟩
  unfold assembledFun
  obtain ⟨_, b2⟩ := blk_posn_add_mul_M (M:=M) (p:=p) hM hp1
    (((posn M x : ZMod p) + t (blkFin M p hM x)).val) (secBlk M p hM (τ (blkFin M p hM x)))
  rw [b2, posn_secBlk hM hp1, Nat.zero_add]
  rw [Nat.mod_eq_of_lt (ZMod.val_lt _)]
  exact ZMod.natCast_zmod_val _

end Assemble

section AssembleBijective

variable {M p : ℕ} [NeZero (M * p)]

theorem assembledFun_injective (hM : 0 < M) (hp1 : 1 < p) (τ : Equiv.Perm (Fin M))
    (t : Fin M → ZMod p) : Function.Injective (assembledFun hM τ t) := by
  haveI hpNZ : NeZero p := ⟨by omega⟩
  intro x y hxy
  have hb : blkFin M p hM (assembledFun hM τ t x) = blkFin M p hM (assembledFun hM τ t y) :=
    congrArg (blkFin M p hM) hxy
  rw [blkFin_assembledFun hM hp1, blkFin_assembledFun hM hp1] at hb
  have hbxy : blkFin M p hM x = blkFin M p hM y := τ.injective hb
  have hp' : (posn M (assembledFun hM τ t x) : ZMod p)
      = (posn M (assembledFun hM τ t y) : ZMod p) := by rw [hxy]
  rw [posn_assembledFun hM hp1, posn_assembledFun hM hp1, hbxy] at hp'
  have hposn : (posn M x : ZMod p) = (posn M y : ZMod p) := add_right_cancel hp'
  have hposn' : posn M x = posn M y := by
    have h1 := posn_lt hM x
    have h2 := posn_lt hM y
    have := congrArg ZMod.val hposn
    rwa [ZMod.val_cast_of_lt h1, ZMod.val_cast_of_lt h2] at this
  apply eq_of_blk_posn_eq hM
  · exact congrArg Fin.val hbxy
  · exact hposn'

noncomputable def assembledSigma (hM : 0 < M) (hp1 : 1 < p) (τ : Equiv.Perm (Fin M))
    (t : Fin M → ZMod p) : Equiv.Perm (ZMod (M*p)) :=
  Equiv.ofBijective (assembledFun hM τ t)
    (Finite.injective_iff_bijective.mp (assembledFun_injective hM hp1 τ t))

theorem assembledSigma_apply (hM : 0 < M) (hp1 : 1 < p) (τ : Equiv.Perm (Fin M))
    (t : Fin M → ZMod p) (x : ZMod (M*p)) :
    assembledSigma hM hp1 τ t x = assembledFun hM τ t x := rfl

end AssembleBijective

section HFixedFromEquivariance

variable {M p : ℕ} [NeZero (M * p)]

/-- Converse of `equivariance_of_H_fixed`: pointwise equivariance implies `H`-fixedness. -/
theorem H_fixed_of_equivariant {σ : Equiv.Perm (ZMod (M*p))}
    (heq : ∀ x, σ (((M:ℕ):ZMod (M*p)) + x) = ((M:ℕ):ZMod (M*p)) + σ x) :
    ((M:ℕ):ZMod (M*p)) +ᵥ σ = σ := by
  rw [vaddFull_def]
  have hcomm : rotFull ((M:ℕ):ZMod (M*p)) * σ = σ * rotFull ((M:ℕ):ZMod (M*p)) := by
    ext x
    show rotFull ((M:ℕ):ZMod (M*p)) (σ x) = σ (rotFull ((M:ℕ):ZMod (M*p)) x)
    rw [rotFull_apply, rotFull_apply, heq]
  rw [mul_inv_eq_iff_eq_mul]
  exact hcomm

theorem posn_add_M_zmod (hM : 0 < M) (hp1 : 1 < p) (y : ZMod (M*p)) :
    (posn M (((M:ℕ):ZMod (M*p)) + y) : ZMod p) = (posn M y : ZMod p) + 1 := by
  haveI hpNZ : NeZero p := ⟨by omega⟩
  obtain ⟨_, hp⟩ := blk_posn_add_M (M:=M) (p:=p) hM hp1 y
  rw [hp, ZMod.natCast_mod]
  push_cast
  ring

theorem blk_add_M_blkFin (hM : 0 < M) (hp1 : 1 < p) (y : ZMod (M*p)) :
    blkFin M p hM (((M:ℕ):ZMod (M*p)) + y) = blkFin M p hM y := by
  obtain ⟨hb, _⟩ := blk_posn_add_M (M:=M) (p:=p) hM hp1 y
  exact Fin.ext hb

theorem assembledSigma_H_fixed (hM : 0 < M) (hp1 : 1 < p) (τ : Equiv.Perm (Fin M))
    (t : Fin M → ZMod p) :
    ((M:ℕ):ZMod (M*p)) +ᵥ (assembledSigma hM hp1 τ t) = assembledSigma hM hp1 τ t := by
  haveI hpNZ : NeZero p := ⟨by omega⟩
  apply H_fixed_of_equivariant
  intro x
  simp only [assembledSigma_apply]
  apply eq_of_blk_posn_eq hM
  · have hb1 : blkFin M p hM (assembledFun hM τ t (((M:ℕ):ZMod (M*p)) + x))
        = blkFin M p hM (((M:ℕ):ZMod (M*p)) + assembledFun hM τ t x) := by
      rw [blkFin_assembledFun hM hp1, blk_add_M_blkFin hM hp1, blk_add_M_blkFin hM hp1,
        ← blkFin_assembledFun hM hp1 τ t x]
    exact congrArg Fin.val hb1
  · have hL : (posn M (assembledFun hM τ t (((M:ℕ):ZMod (M*p)) + x)) : ZMod p)
        = (posn M x : ZMod p) + t (blkFin M p hM x) + 1 := by
      rw [posn_assembledFun hM hp1, blk_add_M_blkFin hM hp1, posn_add_M_zmod hM hp1]
      ring
    have hR : (posn M (((M:ℕ):ZMod (M*p)) + assembledFun hM τ t x) : ZMod p)
        = (posn M x : ZMod p) + t (blkFin M p hM x) + 1 := by
      rw [posn_add_M_zmod hM hp1, posn_assembledFun hM hp1]
    have heq : (posn M (assembledFun hM τ t (((M:ℕ):ZMod (M*p)) + x)) : ZMod p)
        = (posn M (((M:ℕ):ZMod (M*p)) + assembledFun hM τ t x) : ZMod p) := by rw [hL, hR]
    have h1 := posn_lt hM (assembledFun hM τ t (((M:ℕ):ZMod (M*p)) + x))
    have h2 := posn_lt hM (((M:ℕ):ZMod (M*p)) + assembledFun hM τ t x)
    have := congrArg ZMod.val heq
    rwa [ZMod.val_cast_of_lt h1, ZMod.val_cast_of_lt h2] at this

end HFixedFromEquivariance

section Reconstruct

variable {M p : ℕ} [NeZero (M * p)]

theorem reconstruct (hM : 0 < M) (hp1 : 1 < p) (x : ZMod (M*p)) :
    x = ((posn M x * M : ℕ) : ZMod (M*p)) + secBlk M p hM (blkFin M p hM x) := by
  apply eq_of_blk_posn_eq hM
  · obtain ⟨b1, _⟩ := blk_posn_add_mul_M (M:=M) (p:=p) hM hp1 (posn M x)
      (secBlk M p hM (blkFin M p hM x))
    rw [b1]
    exact (congrArg Fin.val (blkFin_secBlk hM hp1 (blkFin M p hM x))).symm
  · obtain ⟨_, b2⟩ := blk_posn_add_mul_M (M:=M) (p:=p) hM hp1 (posn M x)
      (secBlk M p hM (blkFin M p hM x))
    rw [b2, posn_secBlk hM hp1, Nat.zero_add]
    exact (Nat.mod_eq_of_lt (posn_lt hM x)).symm

end Reconstruct

section Extract

variable {M p : ℕ} [NeZero (M * p)]

/-- Extract the "shift" data from an `H`-fixed `σ`: for each block `b`, how much `σ` shifts the
canonical representative `secBlk b`. -/
def tExtract (hM : 0 < M) (hp1 : 1 < p) (σ : Equiv.Perm (ZMod (M*p))) (b : Fin M) : ZMod p :=
  (posn M (σ (secBlk M p hM b)) : ZMod p)

theorem assembledSigma_tExtract_eq (hM : 0 < M) (hp1 : 1 < p) {σ : Equiv.Perm (ZMod (M*p))}
    (hσ : ((M:ℕ):ZMod (M*p)) +ᵥ σ = σ) :
    assembledSigma hM hp1 (blockPerm hM hp1 hσ) (tExtract hM hp1 σ) = σ := by
  haveI hpNZ : NeZero p := ⟨by omega⟩
  ext x
  rw [assembledSigma_apply]
  apply eq_of_blk_posn_eq hM
  · have hb : blkFin M p hM (assembledFun hM (blockPerm hM hp1 hσ) (tExtract hM hp1 σ) x)
        = blkFin M p hM (σ x) := by
      rw [blkFin_assembledFun hM hp1, blockPerm_apply]
    exact congrArg Fin.val hb
  · have key : σ x = ((posn M x * M : ℕ) : ZMod (M*p)) + σ (secBlk M p hM (blkFin M p hM x)) := by
      conv_lhs => rw [reconstruct hM hp1 x]
      rw [equivariance_mul_M hσ]
    have hL : (posn M (assembledFun hM (blockPerm hM hp1 hσ) (tExtract hM hp1 σ) x) : ZMod p)
        = (posn M x : ZMod p) + tExtract hM hp1 σ (blkFin M p hM x) :=
      posn_assembledFun hM hp1 _ _ x
    have hR : (posn M (σ x) : ZMod p) = (posn M x : ZMod p) + tExtract hM hp1 σ (blkFin M p hM x) := by
      rw [key]
      obtain ⟨_, b2⟩ := blk_posn_add_mul_M (M:=M) (p:=p) hM hp1 (posn M x)
        (σ (secBlk M p hM (blkFin M p hM x)))
      rw [b2, ZMod.natCast_mod]
      unfold tExtract
      push_cast
      ring
    have heq : (posn M (assembledFun hM (blockPerm hM hp1 hσ) (tExtract hM hp1 σ) x) : ZMod p)
        = (posn M (σ x) : ZMod p) := by rw [hL, hR]
    have h1 := posn_lt hM (assembledFun hM (blockPerm hM hp1 hσ) (tExtract hM hp1 σ) x)
    have h2 := posn_lt hM (σ x)
    have := congrArg ZMod.val heq
    rwa [ZMod.val_cast_of_lt h1, ZMod.val_cast_of_lt h2] at this

end Extract

section RoundTrip2

variable {M p : ℕ} [NeZero (M * p)]

/-- **Round-trip 2**: `(τ, t) ↦ assembledSigma τ t` is injective, giving (combined with
`assembledSigma_tExtract_eq`) the full bijection `Equiv.Perm (Fin M) × (Fin M → ZMod p) ≃
{H-fixed σ}`. -/
theorem assembledSigma_injective2 (hM : 0 < M) (hp1 : 1 < p) :
    Function.Injective (fun q : Equiv.Perm (Fin M) × (Fin M → ZMod p) =>
      assembledSigma hM hp1 q.1 q.2) := by
  haveI hpNZ : NeZero p := ⟨by omega⟩
  rintro ⟨τ1, t1⟩ ⟨τ2, t2⟩ hxy
  simp only at hxy
  have hfun : ∀ x, assembledFun hM τ1 t1 x = assembledFun hM τ2 t2 x := fun x => by
    have h := congrArg (fun e : Equiv.Perm (ZMod (M*p)) => e x) hxy
    simpa [assembledSigma_apply] using h
  have hτ : τ1 = τ2 := by
    apply Equiv.ext
    intro b
    have h := congrArg (blkFin M p hM) (hfun (secBlk M p hM b))
    rw [blkFin_assembledFun hM hp1, blkFin_assembledFun hM hp1, blkFin_secBlk hM hp1] at h
    exact h
  have ht : t1 = t2 := by
    funext b
    have h1 := congrArg (fun y => (posn M y : ZMod p)) (hfun (secBlk M p hM b))
    rw [posn_assembledFun hM hp1, posn_assembledFun hM hp1, blkFin_secBlk hM hp1,
      posn_secBlk hM hp1] at h1
    rw [Nat.cast_zero, zero_add, zero_add] at h1
    exact h1
  rw [hτ, ht]

end RoundTrip2

/- ### Item (4b) completion: the weight-matching computation

The remaining piece of `XNH_eq_blockSum`'s roadmap (see the status summary at the bottom of the
file for the full account of items (1)-(4a) already completed): the weight-matching identity
`∑_t permWeight (assembledSigma τ t) = blockPermWeightPiece p τ`, and its assembly (via the
`(τ,t) ↔ H-fixed σ` bijection from round-trips 1+2 above) into `XNH_eq_blockSum` itself.

The strategy: peel one `τ`-block-cycle at a time from a distinguished representative point,
tracking a *properly shift-restricted* sum `G` (summing only over the shift values actually
relevant to the not-yet-peeled blocks, via `Function.extend`) that satisfies the exact same
`blockWeight`-weighted recursion as a new Finset-indexed variant of `blockPermWeightPiece`
(`blockPermWeightPieceOnSet`, proved via a direct re-derivation of `blockPermWeightPiece_eq_mul`'s
cycle-type-splitting argument, staying entirely within `Fin M`). The single-block-cycle base case
(`blockCycleLabels_weight_zero_shift`/`_nonzero_shift`) reuses items (2)-(3)'s cycle-structure
analysis (`period_sigma_eq`, `blockCycleLabels_eq_biUnion_translates`,
`periodOrbit_eq_blockCycleLabels_of_shift_ne_zero`) together with a genuinely new
"nested-invariant-subset" factorization of `permWeight` (`permWeight_nested_split`, a
generalization of `ProductCongruence.lean`'s single-orbit `permWeight_eq_mul` to *any* pair of
nested invariant subsets) and the shift-counting lemma `card_tuple_sum_eq_zero`. Both directions
of the item-(4b) round-trip (`assembledSigma_tExtract_eq` above, `assembledSigma_injective2`
above) combine into the bijection `sigmaEquiv`, closing `XNH_eq_blockSum`. -/


/-- General invariant-subset multiplicativity of `permWeight`. -/
theorem permWeight_eq_mul_of_invariant {α : Type*} [Fintype α] [DecidableEq α]
    {σ : Equiv.Perm α} {S : Finset α} (hS : ∀ x, σ x ∈ S ↔ x ∈ S) :
    permWeight σ = permWeight (σ.subtypePerm hS) *
      permWeight (σ.subtypePerm (p := fun x => x ∈ (Sᶜ : Finset α)) (fun x => by
        simp only [Finset.mem_compl]
        exact not_iff_not.mpr (hS x))) := by
  set hS' : ∀ x, σ x ∈ (Sᶜ : Finset α) ↔ x ∈ (Sᶜ : Finset α) := fun x => by
    simp only [Finset.mem_compl]
    exact not_iff_not.mpr (hS x)
  have hmul : Equiv.Perm.ofSubtype (σ.subtypePerm hS) * Equiv.Perm.ofSubtype (σ.subtypePerm hS') = σ := by
    ext y
    rw [Equiv.Perm.mul_apply]
    by_cases hy : y ∈ S
    · have hy' : y ∉ (Sᶜ : Finset α) := by simp [hy]
      rw [Equiv.Perm.ofSubtype_apply_of_not_mem (σ.subtypePerm hS') hy',
        Equiv.Perm.ofSubtype_apply_of_mem (σ.subtypePerm hS) hy,
        Equiv.Perm.subtypePerm_apply]
    · have hy' : y ∈ (Sᶜ : Finset α) := by simp [hy]
      have hsy : σ y ∉ S := fun h => hy ((hS y).mp h)
      rw [Equiv.Perm.ofSubtype_apply_of_mem (σ.subtypePerm hS') hy',
        Equiv.Perm.subtypePerm_apply,
        Equiv.Perm.ofSubtype_apply_of_not_mem (σ.subtypePerm hS) hsy]
  have hdisj : (Equiv.Perm.ofSubtype (σ.subtypePerm hS)).Disjoint
      (Equiv.Perm.ofSubtype (σ.subtypePerm hS')) := by
    intro y
    by_cases hy : y ∈ S
    · right
      have hy' : y ∉ (Sᶜ : Finset α) := by simp [hy]
      exact Equiv.Perm.ofSubtype_apply_of_not_mem (σ.subtypePerm hS') hy'
    · left
      exact Equiv.Perm.ofSubtype_apply_of_not_mem (σ.subtypePerm hS) hy
  have hcycle : σ.cycleType = (σ.subtypePerm hS).cycleType + (σ.subtypePerm hS').cycleType := by
    conv_lhs => rw [← hmul]
    rw [hdisj.cycleType_mul, Equiv.Perm.cycleType_ofSubtype, Equiv.Perm.cycleType_ofSubtype]
  unfold permWeight
  rw [hcycle, Multiset.map_add, Multiset.prod_add]

/-- `periodOrbit` (via `MulAction.period`) agrees with `orbitAt` (via `cycleOf`/`SameCycle`)
for a permutation acting on a finite type. -/
theorem periodOrbit_eq_orbitAt {β : Type*} [Fintype β] [DecidableEq β] (σ : Equiv.Perm β) (x0 : β) :
    periodOrbit σ x0 = orbitAt σ x0 := by
  ext y
  rw [mem_periodOrbit, mem_orbitAt]
  constructor
  · rintro ⟨k, _, hk⟩
    exact ⟨(k:ℤ), by rw [zpow_natCast]; exact hk⟩
  · rintro ⟨i, hi⟩
    have hℓpos : 0 < MulAction.period σ x0 := MulAction.period_pos_of_orderOf_pos (orderOf_pos σ) x0
    have hre : (σ ^ (i % (MulAction.period σ x0 : ℤ))) • x0 = (σ^i) • x0 :=
      MulAction.zpow_mod_period_smul i
    set k := i % (MulAction.period σ x0 : ℤ) with hkdef
    have hk0 : 0 ≤ k := Int.emod_nonneg i (by exact_mod_cast hℓpos.ne')
    have hklt : k < (MulAction.period σ x0 : ℤ) := Int.emod_lt_of_pos i (by exact_mod_cast hℓpos)
    refine ⟨k.toNat, ?_, ?_⟩
    · zify
      rwa [Int.toNat_of_nonneg hk0]
    · have hcast : ((k.toNat : ℤ)) = k := Int.toNat_of_nonneg hk0
      have hz : (σ ^ (k.toNat : ℤ)) • x0 = (σ^i) • x0 := by rw [hcast]; exact hre
      rw [zpow_natCast] at hz
      show (σ ^ k.toNat) x0 = y
      have hz' : (σ ^ k.toNat) x0 = (σ^i) x0 := hz
      rw [hz', hi]

/-- **Nested split**: if `T1 ⊆ T2` are both `σ`-invariant, `permWeight` further factors. -/
theorem permWeight_nested_split {α : Type*} [Fintype α] [DecidableEq α]
    {σ : Equiv.Perm α} {T1 T2 : Finset α} (hT1 : ∀ x, σ x ∈ T1 ↔ x ∈ T1)
    (hT2 : ∀ x, σ x ∈ T2 ↔ x ∈ T2) (hsub : T1 ⊆ T2) :
    permWeight (σ.subtypePerm hT2) = permWeight (σ.subtypePerm hT1) *
      permWeight (σ.subtypePerm (p := fun x => x ∈ (T2 \ T1)) (fun x => by
        simp only [Finset.mem_sdiff]
        exact (hT2 x).and (not_iff_not.mpr (hT1 x)))) := by
  have hTd : ∀ x, σ x ∈ (T2 \ T1) ↔ x ∈ (T2 \ T1) := fun x => by
    simp only [Finset.mem_sdiff]
    exact (hT2 x).and (not_iff_not.mpr (hT1 x))
  have hmul : Equiv.Perm.ofSubtype (σ.subtypePerm hT2)
      = Equiv.Perm.ofSubtype (σ.subtypePerm hT1) * Equiv.Perm.ofSubtype (σ.subtypePerm hTd) := by
    ext y
    rw [Equiv.Perm.mul_apply]
    by_cases hy1 : y ∈ T1
    · have hy2 : y ∈ T2 := hsub hy1
      have hyd : y ∉ (T2 \ T1) := by simp [hy1]
      rw [Equiv.Perm.ofSubtype_apply_of_not_mem (σ.subtypePerm hTd) hyd,
        Equiv.Perm.ofSubtype_apply_of_mem (σ.subtypePerm hT1) hy1,
        Equiv.Perm.subtypePerm_apply,
        Equiv.Perm.ofSubtype_apply_of_mem (σ.subtypePerm hT2) hy2,
        Equiv.Perm.subtypePerm_apply]
    · by_cases hy2 : y ∈ T2
      · have hyd : y ∈ (T2 \ T1) := by simp [hy1, hy2]
        have hsy1 : σ y ∉ T1 := fun h => hy1 ((hT1 y).mp h)
        rw [Equiv.Perm.ofSubtype_apply_of_mem (σ.subtypePerm hTd) hyd,
          Equiv.Perm.subtypePerm_apply,
          Equiv.Perm.ofSubtype_apply_of_not_mem (σ.subtypePerm hT1) hsy1,
          Equiv.Perm.ofSubtype_apply_of_mem (σ.subtypePerm hT2) hy2,
          Equiv.Perm.subtypePerm_apply]
      · have hyd : y ∉ (T2 \ T1) := by simp [hy2]
        rw [Equiv.Perm.ofSubtype_apply_of_not_mem (σ.subtypePerm hTd) hyd,
          Equiv.Perm.ofSubtype_apply_of_not_mem (σ.subtypePerm hT1) hy1,
          Equiv.Perm.ofSubtype_apply_of_not_mem (σ.subtypePerm hT2) hy2]
  have hdisj : (Equiv.Perm.ofSubtype (σ.subtypePerm hT1)).Disjoint
      (Equiv.Perm.ofSubtype (σ.subtypePerm hTd)) := by
    intro y
    by_cases hy1 : y ∈ T1
    · have hyd : y ∉ (T2 \ T1) := by simp [hy1]
      right
      exact Equiv.Perm.ofSubtype_apply_of_not_mem (σ.subtypePerm hTd) hyd
    · left
      exact Equiv.Perm.ofSubtype_apply_of_not_mem (σ.subtypePerm hT1) hy1
  have hcycle : (σ.subtypePerm hT2).cycleType
      = (σ.subtypePerm hT1).cycleType + (σ.subtypePerm hTd).cycleType := by
    have h1 := congrArg Equiv.Perm.cycleType hmul
    rwa [hdisj.cycleType_mul, Equiv.Perm.cycleType_ofSubtype, Equiv.Perm.cycleType_ofSubtype,
      Equiv.Perm.cycleType_ofSubtype] at h1
  unfold permWeight
  rw [hcycle, Multiset.map_add, Multiset.prod_add]

/-- Variant of `permWeight_nested_split` where the `T2 \ T1` piece is replaced by an arbitrary
`T3` known (propositionally) to equal `T2 \ T1`, avoiding the need to match the auto-generated
invariance proof syntactically (uses proof irrelevance via `subst`). -/
theorem permWeight_nested_split' {α : Type*} [Fintype α] [DecidableEq α]
    {σ : Equiv.Perm α} {T1 T2 T3 : Finset α} (hT1 : ∀ x, σ x ∈ T1 ↔ x ∈ T1)
    (hT2 : ∀ x, σ x ∈ T2 ↔ x ∈ T2) (hT3 : ∀ x, σ x ∈ T3 ↔ x ∈ T3) (hsub : T1 ⊆ T2)
    (hdiff : T2 \ T1 = T3) :
    permWeight (σ.subtypePerm hT2) = permWeight (σ.subtypePerm hT1) * permWeight (σ.subtypePerm hT3) := by
  subst hdiff
  exact permWeight_nested_split hT1 hT2 hsub

theorem permWeight_ofSubtype {α : Type*} [Fintype α] [DecidableEq α] {p : α → Prop}
    [DecidablePred p] (u : Equiv.Perm (Subtype p)) :
    permWeight (Equiv.Perm.ofSubtype u) = permWeight u := by
  unfold permWeight
  rw [Equiv.Perm.cycleType_ofSubtype]

/-- `σ.cycleOf x0` is exactly `σ` restricted to `orbitAt σ x0`, extended by the identity. -/
theorem cycleOf_eq_ofSubtype_subtypePerm {α : Type*} [Fintype α] [DecidableEq α]
    (σ : Equiv.Perm α) (x0 : α) :
    σ.cycleOf x0 = Equiv.Perm.ofSubtype (σ.subtypePerm (orbitAt_invariant σ x0)) := by
  ext y
  by_cases hy : y ∈ orbitAt σ x0
  · rw [Equiv.Perm.ofSubtype_apply_of_mem (σ.subtypePerm (orbitAt_invariant σ x0)) hy,
      Equiv.Perm.subtypePerm_apply]
    have hySame : σ.SameCycle x0 y := mem_orbitAt.mp hy
    exact hySame.cycleOf_apply
  · rw [Equiv.Perm.ofSubtype_apply_of_not_mem (σ.subtypePerm (orbitAt_invariant σ x0)) hy]
    have hyNotSame : ¬ σ.SameCycle x0 y := fun h => hy (mem_orbitAt.mpr h)
    exact Equiv.Perm.cycleOf_apply_of_not_sameCycle hyNotSame

theorem permWeight_cycleOf_eq_numDivisors {α : Type*} [Fintype α] [DecidableEq α]
    (σ : Equiv.Perm α) (x0 : α) :
    permWeight (σ.cycleOf x0) = numDivisors (orbitAt σ x0).card := by
  unfold permWeight
  rcases eq_one_or_isCycle_of_cycleOf_self_eq (cycleOf_cycleOf_self σ x0) with h1 | ⟨hcyc, hx0mem⟩
  · have hS1 : (orbitAt σ x0).card = 1 := by
      have hor : orbitAt σ x0 = {x0} := by unfold orbitAt; rw [h1]; simp
      rw [hor]; simp
    rw [h1, hS1]
    have hnd1 : numDivisors 1 = 1 := by decide
    simp [Equiv.Perm.cycleType_one, hnd1]
  · rw [hcyc.cycleType]
    have hsupp_eq : orbitAt (σ.cycleOf x0) x0 = (σ.cycleOf x0).support := by
      unfold orbitAt
      rw [cycleOf_cycleOf_self]
      exact Finset.insert_eq_self.mpr hx0mem
    rw [orbitAt_cycleOf_self] at hsupp_eq
    rw [hsupp_eq]
    simp

/-- **Single-orbit weight**: `permWeight` of `σ` restricted to a single `σ`-orbit is
`numDivisors` of the orbit's size. -/
theorem permWeight_subtypePerm_orbitAt {α : Type*} [Fintype α] [DecidableEq α]
    (σ : Equiv.Perm α) (x0 : α) :
    permWeight (σ.subtypePerm (orbitAt_invariant σ x0)) = numDivisors (orbitAt σ x0).card := by
  have hbridge := cycleOf_eq_ofSubtype_subtypePerm σ x0
  have hcyc : (σ.subtypePerm (orbitAt_invariant σ x0)).cycleType = (σ.cycleOf x0).cycleType := by
    rw [hbridge, Equiv.Perm.cycleType_ofSubtype]
  unfold permWeight
  rw [hcyc]
  exact permWeight_cycleOf_eq_numDivisors σ x0

/-- Transport `permWeight` of a `subtypePerm` across a proved equality of the underlying
`Finset`s (avoids needing the two invariance proofs to be syntactically identical). -/
theorem permWeight_subtypePerm_congr_finset {α : Type*} [Fintype α] [DecidableEq α]
    {σ : Equiv.Perm α} {S T : Finset α} (hS : ∀ x, σ x ∈ S ↔ x ∈ S) (hT : ∀ x, σ x ∈ T ↔ x ∈ T)
    (hST : S = T) : permWeight (σ.subtypePerm hS) = permWeight (σ.subtypePerm hT) := by
  subst hST
  rfl

theorem orbitAt_eq_of_mem {α : Type*} [Fintype α] [DecidableEq α] (σ : Equiv.Perm α) {x y z : α}
    (hz1 : z ∈ orbitAt σ x) (hz2 : z ∈ orbitAt σ y) : orbitAt σ x = orbitAt σ y := by
  rw [mem_orbitAt] at hz1 hz2
  have hxy : σ.SameCycle x y := hz1.trans hz2.symm
  ext w
  rw [mem_orbitAt, mem_orbitAt]
  exact ⟨fun h => hxy.symm.trans h, fun h => hxy.trans h⟩

section CycleTypeSplitting

variable {α : Type*} [Fintype α] [DecidableEq α]

theorem cycleType_subtypePerm_orbitAt (σ : Equiv.Perm α) (x0 : α) :
    (σ.subtypePerm (orbitAt_invariant σ x0)).cycleType = (σ.cycleOf x0).cycleType := by
  have hbridge := cycleOf_eq_ofSubtype_subtypePerm σ x0
  rw [hbridge, Equiv.Perm.cycleType_ofSubtype]

theorem cycleType_nested_split {σ : Equiv.Perm α} {T1 T2 : Finset α}
    (hT1 : ∀ x, σ x ∈ T1 ↔ x ∈ T1) (hT2 : ∀ x, σ x ∈ T2 ↔ x ∈ T2) (hsub : T1 ⊆ T2) :
    (σ.subtypePerm hT2).cycleType = (σ.subtypePerm hT1).cycleType +
      (σ.subtypePerm (p := fun x => x ∈ (T2 \ T1)) (fun x => by
        simp only [Finset.mem_sdiff]
        exact (hT2 x).and (not_iff_not.mpr (hT1 x)))).cycleType := by
  have hTd : ∀ x, σ x ∈ (T2 \ T1) ↔ x ∈ (T2 \ T1) := fun x => by
    simp only [Finset.mem_sdiff]
    exact (hT2 x).and (not_iff_not.mpr (hT1 x))
  have hmul : Equiv.Perm.ofSubtype (σ.subtypePerm hT2)
      = Equiv.Perm.ofSubtype (σ.subtypePerm hT1) * Equiv.Perm.ofSubtype (σ.subtypePerm hTd) := by
    ext y
    rw [Equiv.Perm.mul_apply]
    by_cases hy1 : y ∈ T1
    · have hy2 : y ∈ T2 := hsub hy1
      have hyd : y ∉ (T2 \ T1) := by simp [hy1]
      rw [Equiv.Perm.ofSubtype_apply_of_not_mem (σ.subtypePerm hTd) hyd,
        Equiv.Perm.ofSubtype_apply_of_mem (σ.subtypePerm hT1) hy1,
        Equiv.Perm.subtypePerm_apply,
        Equiv.Perm.ofSubtype_apply_of_mem (σ.subtypePerm hT2) hy2,
        Equiv.Perm.subtypePerm_apply]
    · by_cases hy2 : y ∈ T2
      · have hyd : y ∈ (T2 \ T1) := by simp [hy1, hy2]
        have hsy1 : σ y ∉ T1 := fun h => hy1 ((hT1 y).mp h)
        rw [Equiv.Perm.ofSubtype_apply_of_mem (σ.subtypePerm hTd) hyd,
          Equiv.Perm.subtypePerm_apply,
          Equiv.Perm.ofSubtype_apply_of_not_mem (σ.subtypePerm hT1) hsy1,
          Equiv.Perm.ofSubtype_apply_of_mem (σ.subtypePerm hT2) hy2,
          Equiv.Perm.subtypePerm_apply]
      · have hyd : y ∉ (T2 \ T1) := by simp [hy2]
        rw [Equiv.Perm.ofSubtype_apply_of_not_mem (σ.subtypePerm hTd) hyd,
          Equiv.Perm.ofSubtype_apply_of_not_mem (σ.subtypePerm hT1) hy1,
          Equiv.Perm.ofSubtype_apply_of_not_mem (σ.subtypePerm hT2) hy2]
  have hdisj : (Equiv.Perm.ofSubtype (σ.subtypePerm hT1)).Disjoint
      (Equiv.Perm.ofSubtype (σ.subtypePerm hTd)) := by
    intro y
    by_cases hy1 : y ∈ T1
    · have hyd : y ∉ (T2 \ T1) := by simp [hy1]
      right
      exact Equiv.Perm.ofSubtype_apply_of_not_mem (σ.subtypePerm hTd) hyd
    · left
      exact Equiv.Perm.ofSubtype_apply_of_not_mem (σ.subtypePerm hT1) hy1
  have h1 := congrArg Equiv.Perm.cycleType hmul
  rwa [hdisj.cycleType_mul, Equiv.Perm.cycleType_ofSubtype, Equiv.Perm.cycleType_ofSubtype,
    Equiv.Perm.cycleType_ofSubtype] at h1

theorem support_card_nested_split {σ : Equiv.Perm α} {T1 T2 : Finset α}
    (hT1 : ∀ x, σ x ∈ T1 ↔ x ∈ T1) (hT2 : ∀ x, σ x ∈ T2 ↔ x ∈ T2) (hsub : T1 ⊆ T2) :
    (σ.subtypePerm hT2).support.card = (σ.subtypePerm hT1).support.card +
      (σ.subtypePerm (p := fun x => x ∈ (T2 \ T1)) (fun x => by
        simp only [Finset.mem_sdiff]
        exact (hT2 x).and (not_iff_not.mpr (hT1 x)))).support.card := by
  rw [← Equiv.Perm.sum_cycleType, ← Equiv.Perm.sum_cycleType, ← Equiv.Perm.sum_cycleType,
    cycleType_nested_split hT1 hT2 hsub, Multiset.sum_add]

end CycleTypeSplitting

section AssembledCycle

variable {M p : ℕ} [NeZero (M * p)]

theorem blockPerm_assembledSigma (hM : 0 < M) (hp1 : 1 < p) (τ : Equiv.Perm (Fin M))
    (t : Fin M → ZMod p) :
    blockPerm hM hp1 (assembledSigma_H_fixed hM hp1 τ t) = τ := by
  apply Equiv.ext
  intro b
  have h := blockPerm_apply hM hp1 (assembledSigma_H_fixed hM hp1 τ t) (secBlk M p hM b)
  rw [blkFin_secBlk hM hp1] at h
  rw [h, assembledSigma_apply, blkFin_assembledFun hM hp1, blkFin_secBlk hM hp1]

theorem posn_pow_assembledSigma (hM : 0 < M) (hp1 : 1 < p) (τ : Equiv.Perm (Fin M))
    (t : Fin M → ZMod p) (b0 : Fin M) (k : ℕ) :
    (posn M (((assembledSigma hM hp1 τ t)^k) (secBlk M p hM b0)) : ZMod p)
      = ∑ i ∈ Finset.range k, t ((τ^i) b0) := by
  haveI hpNZ : NeZero p := ⟨by omega⟩
  induction k with
  | zero => simp [posn_secBlk hM hp1]
  | succ k ih =>
    have hblk : blkFin M p hM (((assembledSigma hM hp1 τ t)^k) (secBlk M p hM b0)) = (τ^k) b0 := by
      rw [blkFin_pow hM hp1 (assembledSigma_H_fixed hM hp1 τ t), blkFin_secBlk hM hp1,
        blockPerm_assembledSigma]
    rw [pow_succ', Equiv.Perm.mul_apply, assembledSigma_apply, posn_assembledFun hM hp1, hblk, ih,
      Finset.sum_range_succ]

theorem periodOrbit_invariant {β : Type*} [Fintype β] [DecidableEq β] (τ : Equiv.Perm β)
    (b0 y : β) : τ y ∈ periodOrbit τ b0 ↔ y ∈ periodOrbit τ b0 := by
  rw [periodOrbit_eq_orbitAt]
  exact orbitAt_invariant τ b0 y

theorem blockCycleLabels_invariant (hM : 0 < M) (hp1 : 1 < p) {σ : Equiv.Perm (ZMod (M*p))}
    (hσ : ((M:ℕ):ZMod (M*p)) +ᵥ σ = σ) (b0 : Fin M) (x : ZMod (M*p)) :
    σ x ∈ blockCycleLabels hM hp1 hσ b0 ↔ x ∈ blockCycleLabels hM hp1 hσ b0 := by
  unfold blockCycleLabels
  simp only [Finset.mem_filter, Finset.mem_univ, true_and]
  rw [← blockPerm_apply hM hp1 hσ x]
  exact periodOrbit_invariant (blockPerm hM hp1 hσ) b0 (blkFin M p hM x)

/-- **Disjointness of translate-orbits in the zero-shift case.** Different `H`-translates
`j*M + x0` of the block-representative `x0` generate pairwise disjoint `σ`-orbits, provided the
`σ`-period of `x0` matches the block-cycle length (the zero-shift hypothesis). -/
theorem periodOrbit_translate_disjoint (hM : 0 < M) (hp1 : 1 < p)
    {σ : Equiv.Perm (ZMod (M*p))} (hσ : ((M:ℕ):ZMod (M*p)) +ᵥ σ = σ) (b0 : Fin M)
    (hℓeq : MulAction.period σ (secBlk M p hM b0) = MulAction.period (blockPerm hM hp1 hσ) b0)
    {j1 j2 : ℕ} (hj1 : j1 < p) (hj2 : j2 < p) (hne : j1 ≠ j2) :
    Disjoint (periodOrbit σ (((j1*M:ℕ):ZMod (M*p)) + secBlk M p hM b0))
      (periodOrbit σ (((j2*M:ℕ):ZMod (M*p)) + secBlk M p hM b0)) := by
  rw [Finset.disjoint_left]
  intro z hz1 hz2
  rw [periodOrbit_translate hM hp1 hσ, Finset.mem_image] at hz1 hz2
  obtain ⟨w1, hw1, hzw1⟩ := hz1
  obtain ⟨w2, hw2, hzw2⟩ := hz2
  have hblkeq : blkFin M p hM w1 = blkFin M p hM w2 := by
    have e1 : blkFin M p hM (((j1*M:ℕ):ZMod (M*p)) + w1) = blkFin M p hM w1 := by
      apply Fin.ext
      obtain ⟨hb,_⟩ := blk_posn_add_mul_M (M:=M) (p:=p) hM hp1 j1 w1
      exact hb
    have e2 : blkFin M p hM (((j2*M:ℕ):ZMod (M*p)) + w2) = blkFin M p hM w2 := by
      apply Fin.ext
      obtain ⟨hb,_⟩ := blk_posn_add_mul_M (M:=M) (p:=p) hM hp1 j2 w2
      exact hb
    rw [← e1, ← e2, hzw1, hzw2]
  have hw1w2 : w1 = w2 := blkFin_inj_on_periodOrbit hM hp1 hσ b0 hℓeq hw1 hw2 hblkeq
  have hposn1 : posn M z = (posn M w1 + j1) % p := by
    rw [← hzw1]
    obtain ⟨_,hb⟩ := blk_posn_add_mul_M (M:=M) (p:=p) hM hp1 j1 w1
    exact hb
  have hposn2 : posn M z = (posn M w1 + j2) % p := by
    rw [← hzw2, hw1w2]
    obtain ⟨_,hb⟩ := blk_posn_add_mul_M (M:=M) (p:=p) hM hp1 j2 w2
    exact hb
  have hmod : (posn M w1 + j1) % p = (posn M w1 + j2) % p := by rw [← hposn1, hposn2]
  have hj12 : j1 % p = j2 % p := Nat.ModEq.add_left_cancel' (posn M w1) hmod
  rw [Nat.mod_eq_of_lt hj1, Nat.mod_eq_of_lt hj2] at hj12
  exact hne hj12

/-- **Zero-shift block-cycle weight**: if the total shift around the block-cycle through `b0` is
zero, `permWeight` of `σ` restricted to `blockCycleLabels` is `(numDivisors ℓ)^p` (`p` disjoint
`ℓ`-cycles). -/
theorem blockCycleLabels_weight_zero_shift (hM : 0 < M) (hp1 : 1 < p) (hpp : p.Prime)
    {σ : Equiv.Perm (ZMod (M*p))} (hσ : ((M:ℕ):ZMod (M*p)) +ᵥ σ = σ) (b0 : Fin M)
    (hs : posn M ((σ ^ MulAction.period (blockPerm hM hp1 hσ) b0) (secBlk M p hM b0)) = 0) :
    permWeight (σ.subtypePerm (blockCycleLabels_invariant hM hp1 hσ b0))
      = (numDivisors (MulAction.period (blockPerm hM hp1 hσ) b0) : ℤ) ^ p := by
  set ℓ := MulAction.period (blockPerm hM hp1 hσ) b0 with hℓdef
  set x0 := secBlk M p hM b0 with hx0def
  have hℓeq : MulAction.period σ x0 = ℓ := by
    rw [period_sigma_eq hM hp1 hpp hσ b0, if_pos hs, mul_one]
  set U : ℕ → Finset (ZMod (M*p)) :=
    fun j => (Finset.range j).biUnion (fun j' => periodOrbit σ (((j'*M:ℕ):ZMod (M*p)) + x0))
    with hUdef
  have hUinv : ∀ j (x : ZMod (M*p)), σ x ∈ U j ↔ x ∈ U j := by
    intro j x
    simp only [hUdef, Finset.mem_biUnion]
    constructor
    · rintro ⟨j', hj', hxj'⟩
      exact ⟨j', hj', (periodOrbit_invariant σ (((j'*M:ℕ):ZMod (M*p)) + x0) x).mp hxj'⟩
    · rintro ⟨j', hj', hxj'⟩
      exact ⟨j', hj', (periodOrbit_invariant σ (((j'*M:ℕ):ZMod (M*p)) + x0) x).mpr hxj'⟩
  have hUp : U p = blockCycleLabels hM hp1 hσ b0 := by
    show (Finset.range p).biUnion (fun j' => periodOrbit σ (((j'*M:ℕ):ZMod (M*p)) + x0)) = _
    exact (blockCycleLabels_eq_biUnion_translates hM hp1 hpp hσ b0 hs).symm
  have hstep : ∀ j, j < p → permWeight (σ.subtypePerm (hUinv (j+1)))
      = permWeight (σ.subtypePerm (hUinv j)) * (numDivisors ℓ : ℤ) := by
    intro j hjp
    have hsub : U j ⊆ U (j+1) := by
      apply Finset.biUnion_subset_biUnion_of_subset_left
      intro x hx
      simp only [Finset.mem_range] at hx ⊢
      omega
    have hdiff : U (j+1) \ U j = periodOrbit σ (((j*M:ℕ):ZMod (M*p)) + x0) := by
      apply Finset.Subset.antisymm
      · intro z hz
        rw [Finset.mem_sdiff] at hz
        obtain ⟨hz1, hz2⟩ := hz
        simp only [hUdef, Finset.mem_biUnion, Finset.mem_range] at hz1 hz2
        obtain ⟨j', hj'lt, hzj'⟩ := hz1
        rcases Nat.lt_succ_iff_lt_or_eq.mp hj'lt with hlt | heq
        · exact absurd ⟨j', hlt, hzj'⟩ hz2
        · rw [heq] at hzj'; exact hzj'
      · intro z hz
        rw [Finset.mem_sdiff]
        refine ⟨?_, ?_⟩
        · simp only [hUdef, Finset.mem_biUnion]
          exact ⟨j, Finset.mem_range.mpr (Nat.lt_succ_self j), hz⟩
        · simp only [hUdef, Finset.mem_biUnion]
          rintro ⟨j', hj'lt, hzj'⟩
          rw [Finset.mem_range] at hj'lt
          exact Finset.disjoint_left.mp
            (periodOrbit_translate_disjoint hM hp1 hσ b0 hℓeq (by omega : j' < p) hjp
              (by omega)) hzj' hz
    have hdiffO : U (j+1) \ U j = orbitAt σ (((j*M:ℕ):ZMod (M*p)) + x0) := by
      rw [hdiff, periodOrbit_eq_orbitAt]
    have hcard : (orbitAt σ (((j*M:ℕ):ZMod (M*p)) + x0)).card = ℓ := by
      rw [← periodOrbit_eq_orbitAt, card_periodOrbit, period_translate_eq hM hp1 hσ x0 j, hℓeq]
    rw [permWeight_nested_split' (hUinv j) (hUinv (j+1))
      (orbitAt_invariant σ (((j*M:ℕ):ZMod (M*p)) + x0)) hsub hdiffO,
      permWeight_subtypePerm_orbitAt, hcard]
  have hind : ∀ j ≤ p, permWeight (σ.subtypePerm (hUinv j)) = (numDivisors ℓ : ℤ)^j := by
    intro j
    induction j with
    | zero =>
      intro _
      have hU0 : U 0 = ∅ := by rw [hUdef]; simp
      have hU0empty : IsEmpty (↥(U 0)) := Finset.isEmpty_coe_sort.mpr hU0
      have heq1 : σ.subtypePerm (hUinv 0) = 1 := by
        apply Equiv.ext
        intro x
        exact hU0empty.elim x
      rw [heq1]
      unfold permWeight
      simp [Equiv.Perm.cycleType_one]
    | succ j ih =>
      intro hjle
      have hjlt : j < p := by omega
      rw [hstep j hjlt, ih (by omega)]
      ring
  have hfinal := hind p (le_refl p)
  rwa [permWeight_subtypePerm_congr_finset (hUinv p) (blockCycleLabels_invariant hM hp1 hσ b0)
    hUp] at hfinal

/-- **Nonzero-shift block-cycle weight**: if the total shift around the block-cycle through `b0`
is nonzero, `permWeight` of `σ` restricted to `blockCycleLabels` is `numDivisors (p*ℓ)` (a single
`pℓ`-cycle). -/
theorem blockCycleLabels_weight_nonzero_shift (hM : 0 < M) (hp1 : 1 < p) (hpp : p.Prime)
    {σ : Equiv.Perm (ZMod (M*p))} (hσ : ((M:ℕ):ZMod (M*p)) +ᵥ σ = σ) (b0 : Fin M)
    (hs : posn M ((σ ^ MulAction.period (blockPerm hM hp1 hσ) b0) (secBlk M p hM b0)) ≠ 0) :
    permWeight (σ.subtypePerm (blockCycleLabels_invariant hM hp1 hσ b0))
      = (numDivisors (p * MulAction.period (blockPerm hM hp1 hσ) b0) : ℤ) := by
  set x0 := secBlk M p hM b0 with hx0def
  have heqset : orbitAt σ x0 = blockCycleLabels hM hp1 hσ b0 := by
    rw [← periodOrbit_eq_orbitAt]
    exact periodOrbit_eq_blockCycleLabels_of_shift_ne_zero hM hp1 hpp hσ b0 hs
  have hcard : (blockCycleLabels hM hp1 hσ b0).card = p * MulAction.period (blockPerm hM hp1 hσ) b0 := by
    rw [card_blockCycleLabels hM hp1 hσ b0, card_periodOrbit]
  have hw := permWeight_subtypePerm_orbitAt σ x0
  rw [permWeight_subtypePerm_congr_finset (orbitAt_invariant σ x0)
    (blockCycleLabels_invariant hM hp1 hσ b0) heqset, heqset, hcard] at hw
  exact hw

/-- **Block-cycle weight for `assembledSigma`, expressed via the shift-sum.** For a fixed
`τ`-block-cycle through `b0` of length `ℓ`, the total shift `∑_{i<ℓ} t(τ^i b0)` determines the
`permWeight` of `assembledSigma τ t` restricted to that block-cycle's labels: `(numDivisors ℓ)^p`
if the shift is zero, `numDivisors (p*ℓ)` otherwise. -/
theorem assembledSigma_blockCycle_weight (hM : 0 < M) (hp1 : 1 < p) (hpp : p.Prime)
    (τ : Equiv.Perm (Fin M)) (t : Fin M → ZMod p) (b0 : Fin M) :
    permWeight ((assembledSigma hM hp1 τ t).subtypePerm
      (blockCycleLabels_invariant hM hp1 (assembledSigma_H_fixed hM hp1 τ t) b0))
      = if (∑ i ∈ Finset.range (MulAction.period τ b0), t ((τ^i) b0)) = 0
        then (numDivisors (MulAction.period τ b0) : ℤ) ^ p
        else (numDivisors (p * MulAction.period τ b0) : ℤ) := by
  haveI hpNZ : NeZero p := ⟨by omega⟩
  have hτeq : blockPerm hM hp1 (assembledSigma_H_fixed hM hp1 τ t) = τ :=
    blockPerm_assembledSigma hM hp1 τ t
  have hℓeq : MulAction.period (blockPerm hM hp1 (assembledSigma_H_fixed hM hp1 τ t)) b0
      = MulAction.period τ b0 := by rw [hτeq]
  have hshift : (posn M (((assembledSigma hM hp1 τ t) ^
      MulAction.period (blockPerm hM hp1 (assembledSigma_H_fixed hM hp1 τ t)) b0)
      (secBlk M p hM b0)) : ZMod p)
      = ∑ i ∈ Finset.range (MulAction.period τ b0), t ((τ^i) b0) := by
    rw [hℓeq]
    exact posn_pow_assembledSigma hM hp1 τ t b0 (MulAction.period τ b0)
  by_cases hs0 : (∑ i ∈ Finset.range (MulAction.period τ b0), t ((τ^i) b0)) = 0
  · rw [if_pos hs0]
    have hsp : posn M (((assembledSigma hM hp1 τ t) ^
        MulAction.period (blockPerm hM hp1 (assembledSigma_H_fixed hM hp1 τ t)) b0)
        (secBlk M p hM b0)) = 0 := by
      have hlt := posn_lt hM (((assembledSigma hM hp1 τ t) ^
        MulAction.period (blockPerm hM hp1 (assembledSigma_H_fixed hM hp1 τ t)) b0)
        (secBlk M p hM b0))
      have hcast0 : (posn M (((assembledSigma hM hp1 τ t) ^
          MulAction.period (blockPerm hM hp1 (assembledSigma_H_fixed hM hp1 τ t)) b0)
          (secBlk M p hM b0)) : ZMod p) = 0 := by rw [hshift, hs0]
      have hh := congrArg ZMod.val hcast0
      rwa [ZMod.val_cast_of_lt hlt, ZMod.val_zero] at hh
    have hres := blockCycleLabels_weight_zero_shift hM hp1 hpp
      (assembledSigma_H_fixed hM hp1 τ t) b0 hsp
    rw [hℓeq] at hres
    exact hres
  · rw [if_neg hs0]
    have hsp : posn M (((assembledSigma hM hp1 τ t) ^
        MulAction.period (blockPerm hM hp1 (assembledSigma_H_fixed hM hp1 τ t)) b0)
        (secBlk M p hM b0)) ≠ 0 := by
      intro hzero
      apply hs0
      have hcast0 : (posn M (((assembledSigma hM hp1 τ t) ^
          MulAction.period (blockPerm hM hp1 (assembledSigma_H_fixed hM hp1 τ t)) b0)
          (secBlk M p hM b0)) : ZMod p) = 0 := by rw [hzero]; simp
      rw [hshift] at hcast0
      exact hcast0
    have hres := blockCycleLabels_weight_nonzero_shift hM hp1 hpp
      (assembledSigma_H_fixed hM hp1 τ t) b0 hsp
    rw [hℓeq] at hres
    exact hres

end AssembledCycle

section OnSetMachinery

variable {α : Type*} [Fintype α] [DecidableEq α]

theorem support_subtypePerm_orbitAt (σ : Equiv.Perm α) (x0 : α) :
    (σ.subtypePerm (orbitAt_invariant σ x0)).support.card = (σ.cycleOf x0).support.card := by
  rw [← Equiv.Perm.sum_cycleType, ← Equiv.Perm.sum_cycleType, cycleType_subtypePerm_orbitAt]

theorem blockWeight_eq_local (p : ℕ) (σ : Equiv.Perm α) (x0 : α) :
    ((σ.subtypePerm (orbitAt_invariant σ x0)).cycleType.map (blockWeight p)).prod
      * (blockWeight p 1) ^
        ((orbitAt σ x0).card - (σ.subtypePerm (orbitAt_invariant σ x0)).support.card)
      = blockWeight p (orbitAt σ x0).card := by
  rw [cycleType_subtypePerm_orbitAt, support_subtypePerm_orbitAt]
  rcases eq_one_or_isCycle_of_cycleOf_self_eq (cycleOf_cycleOf_self σ x0) with h1 | ⟨hcyc, hx0mem⟩
  · have hS1 : (orbitAt σ x0).card = 1 := by
      have hor : orbitAt σ x0 = {x0} := by unfold orbitAt; rw [h1]; simp
      rw [hor]; simp
    rw [h1]
    simp [hS1]
  · have hSeq : orbitAt σ x0 = (σ.cycleOf x0).support := by
      have hsupp_eq : orbitAt (σ.cycleOf x0) x0 = (σ.cycleOf x0).support := by
        unfold orbitAt
        rw [cycleOf_cycleOf_self]
        exact Finset.insert_eq_self.mpr hx0mem
      rw [orbitAt_cycleOf_self] at hsupp_eq
      exact hsupp_eq
    rw [hcyc.cycleType, ← hSeq]
    simp

theorem orbitAt_subset_of_invariant {σ : Equiv.Perm α} {A : Finset α}
    (hA : ∀ x, σ x ∈ A ↔ x ∈ A) {x0 : α} (hx0 : x0 ∈ A) : orbitAt σ x0 ⊆ A := by
  intro y hy
  rw [mem_orbitAt] at hy
  obtain ⟨n, hn⟩ := hy.exists_nat_pow_eq
  rw [← hn]
  clear hn hy y
  induction n with
  | zero => simpa using hx0
  | succ n ih =>
    rw [pow_succ', Equiv.Perm.mul_apply]
    exact (hA _).mpr ih

end OnSetMachinery

section OnSet

variable {M : ℕ}

def blockPermWeightPieceOnSet (p : ℕ) (τ : Equiv.Perm (Fin M)) (A : Finset (Fin M))
    (hA : ∀ b, τ b ∈ A ↔ b ∈ A) : ℤ :=
  ((τ.subtypePerm hA).cycleType.map (blockWeight p)).prod
    * (blockWeight p 1) ^ (A.card - (τ.subtypePerm hA).support.card)

theorem blockPermWeightPieceOnSet_eq_mul (p : ℕ) (τ : Equiv.Perm (Fin M)) {A : Finset (Fin M)}
    (hA : ∀ b, τ b ∈ A ↔ b ∈ A) {x0 : Fin M} (hx0 : x0 ∈ A) :
    blockPermWeightPieceOnSet p τ A hA = blockWeight p (orbitAt τ x0).card *
      blockPermWeightPieceOnSet p τ (A \ orbitAt τ x0) (fun b => by
        simp only [Finset.mem_sdiff]
        exact (hA b).and (not_iff_not.mpr (orbitAt_invariant τ x0 b))) := by
  have hSsub : orbitAt τ x0 ⊆ A := orbitAt_subset_of_invariant hA hx0
  have hAd : ∀ b, τ b ∈ (A \ orbitAt τ x0) ↔ b ∈ (A \ orbitAt τ x0) := fun b => by
    simp only [Finset.mem_sdiff]
    exact (hA b).and (not_iff_not.mpr (orbitAt_invariant τ x0 b))
  have hexp : A.card - (τ.subtypePerm hA).support.card
      = ((orbitAt τ x0).card - (τ.subtypePerm (orbitAt_invariant τ x0)).support.card)
        + ((A \ orbitAt τ x0).card - (τ.subtypePerm hAd).support.card) := by
    have hcarddiff : (A \ orbitAt τ x0).card = A.card - (orbitAt τ x0).card :=
      Finset.card_sdiff_of_subset hSsub
    have h1 : (τ.subtypePerm (orbitAt_invariant τ x0)).support.card ≤ (orbitAt τ x0).card := by
      have := Finset.card_le_univ (τ.subtypePerm (orbitAt_invariant τ x0)).support
      rwa [Fintype.card_coe] at this
    have h2 : (τ.subtypePerm hAd).support.card ≤ (A \ orbitAt τ x0).card := by
      have := Finset.card_le_univ (τ.subtypePerm hAd).support
      rwa [Fintype.card_coe] at this
    have hSleA : (orbitAt τ x0).card ≤ A.card := Finset.card_le_card hSsub
    have h4 := support_card_nested_split (orbitAt_invariant τ x0) hA hSsub
    omega
  unfold blockPermWeightPieceOnSet
  rw [hexp, pow_add, cycleType_nested_split (orbitAt_invariant τ x0) hA hSsub,
    Multiset.map_add, Multiset.prod_add, ← blockWeight_eq_local p τ x0]
  ring

end OnSet

section LabelsAbove

variable {M p : ℕ} [NeZero (M * p)]

def labelsAbove (hM : 0 < M) (A : Finset (Fin M)) : Finset (ZMod (M*p)) :=
  Finset.univ.filter (fun x => blkFin M p hM x ∈ A)

theorem labelsAbove_invariant (hM : 0 < M) (hp1 : 1 < p) (τ : Equiv.Perm (Fin M))
    (t : Fin M → ZMod p) (A : Finset (Fin M)) (hA : ∀ b, τ b ∈ A ↔ b ∈ A) :
    ∀ x, assembledSigma hM hp1 τ t x ∈ labelsAbove hM A ↔ x ∈ labelsAbove hM A := by
  intro x
  unfold labelsAbove
  simp only [Finset.mem_filter, Finset.mem_univ, true_and]
  rw [assembledSigma_apply, blkFin_assembledFun hM hp1]
  exact hA (blkFin M p hM x)

theorem labelsAbove_eq_blockCycleLabels (hM : 0 < M) (hp1 : 1 < p) (τ : Equiv.Perm (Fin M))
    (t : Fin M → ZMod p) (b0 : Fin M) :
    labelsAbove hM (orbitAt τ b0) = blockCycleLabels hM hp1 (assembledSigma_H_fixed hM hp1 τ t) b0 := by
  unfold labelsAbove blockCycleLabels
  have hτeq : blockPerm hM hp1 (assembledSigma_H_fixed hM hp1 τ t) = τ :=
    blockPerm_assembledSigma hM hp1 τ t
  ext x
  simp only [Finset.mem_filter, Finset.mem_univ, true_and]
  rw [hτeq, ← periodOrbit_eq_orbitAt]

theorem assembledSigma_eqOn_labelsAbove (hM : 0 < M) (hp1 : 1 < p) (τ : Equiv.Perm (Fin M))
    (t1 t2 : Fin M → ZMod p) (A : Finset (Fin M)) (hteq : ∀ b ∈ A, t1 b = t2 b) :
    ∀ x ∈ labelsAbove hM A, assembledSigma hM hp1 τ t1 x = assembledSigma hM hp1 τ t2 x := by
  haveI hpNZ : NeZero p := ⟨by omega⟩
  intro x hx
  unfold labelsAbove at hx
  rw [Finset.mem_filter] at hx
  apply eq_of_blk_posn_eq hM
  · have hb : blkFin M p hM (assembledSigma hM hp1 τ t1 x)
        = blkFin M p hM (assembledSigma hM hp1 τ t2 x) := by
      rw [assembledSigma_apply, assembledSigma_apply, blkFin_assembledFun hM hp1,
        blkFin_assembledFun hM hp1]
    exact congrArg Fin.val hb
  · have h1 : (posn M (assembledSigma hM hp1 τ t1 x) : ZMod p)
        = (posn M (assembledSigma hM hp1 τ t2 x) : ZMod p) := by
      rw [assembledSigma_apply, assembledSigma_apply, posn_assembledFun hM hp1,
        posn_assembledFun hM hp1, hteq _ hx.2]
    have hl1 := posn_lt hM (assembledSigma hM hp1 τ t1 x)
    have hl2 := posn_lt hM (assembledSigma hM hp1 τ t2 x)
    have hh := congrArg ZMod.val h1
    rwa [ZMod.val_cast_of_lt hl1, ZMod.val_cast_of_lt hl2] at hh

theorem permWeight_subtypePerm_eqOn (hM : 0 < M) (hp1 : 1 < p) (τ : Equiv.Perm (Fin M))
    (t1 t2 : Fin M → ZMod p) (A : Finset (Fin M)) (hA : ∀ b, τ b ∈ A ↔ b ∈ A)
    (hteq : ∀ b ∈ A, t1 b = t2 b) :
    permWeight ((assembledSigma hM hp1 τ t1).subtypePerm (labelsAbove_invariant hM hp1 τ t1 A hA))
      = permWeight ((assembledSigma hM hp1 τ t2).subtypePerm (labelsAbove_invariant hM hp1 τ t2 A hA)) := by
  have heq : (assembledSigma hM hp1 τ t1).subtypePerm (labelsAbove_invariant hM hp1 τ t1 A hA)
      = (assembledSigma hM hp1 τ t2).subtypePerm (labelsAbove_invariant hM hp1 τ t2 A hA) := by
    apply Equiv.ext
    intro x
    apply Subtype.ext
    show assembledSigma hM hp1 τ t1 (x : ZMod (M*p)) = assembledSigma hM hp1 τ t2 (x : ZMod (M*p))
    exact assembledSigma_eqOn_labelsAbove hM hp1 τ t1 t2 A hteq x.1 x.2
  rw [heq]

end LabelsAbove

section SplitAS

variable {M : ℕ} {γ : Type*}

/-- Splitting a function on `↥A` into its restrictions to `↥S` and `↥(A \ S)`, for `S ⊆ A`. -/
def splitAS (A S : Finset (Fin M)) (hSA : S ⊆ A) :
    (↥A → γ) ≃ (↥S → γ) × (↥(A \ S) → γ) where
  toFun t := (fun s => t ⟨(s : Fin M), hSA s.2⟩,
              fun a => t ⟨(a : Fin M), (Finset.mem_sdiff.mp a.2).1⟩)
  invFun q := fun a =>
    if h : (a : Fin M) ∈ S then q.1 ⟨(a : Fin M), h⟩
    else q.2 ⟨(a : Fin M), Finset.mem_sdiff.mpr ⟨a.2, h⟩⟩
  left_inv t := by
    funext a
    by_cases h : (a : Fin M) ∈ S
    · simp [h]
    · simp [h]
  right_inv q := by
    obtain ⟨q1, q2⟩ := q
    ext s
    · simp [s.2]
    · have hns : (s : Fin M) ∉ S := (Finset.mem_sdiff.mp s.2).2
      simp [hns]

end SplitAS

section GDef

variable {M p : ℕ} [NeZero (M * p)] [NeZero p]

def G (hM : 0 < M) (hp1 : 1 < p) (τ : Equiv.Perm (Fin M)) (A : Finset (Fin M))
    (hA : ∀ b, τ b ∈ A ↔ b ∈ A) : ℤ :=
  ∑ t' : ↥A → ZMod p, permWeight
    ((assembledSigma hM hp1 τ (Function.extend Subtype.val t' 0)).subtypePerm
      (labelsAbove_invariant hM hp1 τ (Function.extend Subtype.val t' 0) A hA))

theorem G_empty (hM : 0 < M) (hp1 : 1 < p) (τ : Equiv.Perm (Fin M))
    (hA : ∀ b, τ b ∈ (∅ : Finset (Fin M)) ↔ b ∈ (∅ : Finset (Fin M))) :
    G hM hp1 τ ∅ hA = 1 := by
  haveI hpNZ : NeZero p := ⟨by omega⟩
  have hLAempty : labelsAbove hM (∅ : Finset (Fin M)) = (∅ : Finset (ZMod (M * p))) := by
    unfold labelsAbove
    simp
  have hLAinv : IsEmpty (↥(labelsAbove hM (∅ : Finset (Fin M)))) :=
    Finset.isEmpty_coe_sort.mpr hLAempty
  unfold G
  have hconst : ∀ t' : ↥(∅ : Finset (Fin M)) → ZMod p, permWeight
      ((assembledSigma hM hp1 τ (Function.extend Subtype.val t' 0)).subtypePerm
        (labelsAbove_invariant hM hp1 τ (Function.extend Subtype.val t' 0) ∅ hA)) = 1 := by
    intro t'
    have heq1 : (assembledSigma hM hp1 τ (Function.extend Subtype.val t' 0)).subtypePerm
        (labelsAbove_invariant hM hp1 τ (Function.extend Subtype.val t' 0) ∅ hA) = 1 := by
      apply Equiv.ext
      intro x
      exact hLAinv.elim x
    rw [heq1]
    unfold permWeight
    simp [Equiv.Perm.cycleType_one]
  rw [Finset.sum_congr rfl (fun t' _ => hconst t')]
  simp

end GDef

section LabelsAboveMono

variable {M p : ℕ} [NeZero (M * p)]

theorem labelsAbove_mono (hM : 0 < M) {A1 A2 : Finset (Fin M)} (h : A1 ⊆ A2) :
    labelsAbove (p := p) hM A1 ⊆ labelsAbove hM A2 := by
  intro x hx
  unfold labelsAbove at hx ⊢
  rw [Finset.mem_filter] at hx ⊢
  exact ⟨hx.1, h hx.2⟩

theorem labelsAbove_sdiff (hM : 0 < M) (A1 A2 : Finset (Fin M)) :
    labelsAbove (p := p) hM A1 \ labelsAbove hM A2 = labelsAbove hM (A1 \ A2) := by
  unfold labelsAbove
  ext x
  simp only [Finset.mem_sdiff, Finset.mem_filter, Finset.mem_univ, true_and]

end LabelsAboveMono

section OrbitFinEquiv

variable {M : ℕ}

/-- Enumerate a `τ`-orbit by `Fin (period τ x0)`, via `k ↦ τ^k x0`. -/
def orbitFinEquiv (τ : Equiv.Perm (Fin M)) (x0 : Fin M) :
    Fin (MulAction.period τ x0) ≃ ↥(orbitAt τ x0) := by
  refine Equiv.ofBijective (fun k => ⟨(τ ^ (k : ℕ)) x0, ?_⟩) ?_
  · rw [← periodOrbit_eq_orbitAt]
    exact pow_mem_periodOrbit τ x0 (MulAction.period_pos_of_orderOf_pos (orderOf_pos τ) x0) k
  · apply Fintype.bijective_iff_injective_and_card _ |>.mpr
    refine ⟨?_, ?_⟩
    · intro k1 k2 hk
      apply Fin.ext
      have hinj := periodOrbit_injOn τ x0
      have h1 : (k1 : ℕ) ∈ (Finset.range (MulAction.period τ x0) : Finset ℕ) :=
        Finset.mem_range.mpr k1.2
      have h2 : (k2 : ℕ) ∈ (Finset.range (MulAction.period τ x0) : Finset ℕ) :=
        Finset.mem_range.mpr k2.2
      have heq : (τ ^ (k1 : ℕ)) x0 = (τ ^ (k2 : ℕ)) x0 := congrArg Subtype.val hk
      exact hinj (by simpa using h1) (by simpa using h2) (by simpa using heq)
    · rw [Fintype.card_fin, Fintype.card_coe]
      rw [← periodOrbit_eq_orbitAt, card_periodOrbit]

theorem orbitFinEquiv_apply (τ : Equiv.Perm (Fin M)) (x0 : Fin M) (k : Fin (MulAction.period τ x0)) :
    (orbitFinEquiv τ x0 k : Fin M) = (τ ^ (k : ℕ)) x0 := rfl

end OrbitFinEquiv

theorem sum_if_shift_eq_blockWeight (p : ℕ) [NeZero p] (ℓ' : ℕ) (A B : ℤ) :
    ∑ v : Fin (ℓ'+1) → ZMod p, (if (∑ i, v i) = 0 then A else B)
      = (p:ℤ)^ℓ' * A + ((p:ℤ)^(ℓ'+1) - (p:ℤ)^ℓ') * B := by
  classical
  rw [Finset.sum_ite]
  simp only [Finset.sum_const]
  have hcard0 : (Finset.univ.filter (fun v : Fin (ℓ'+1) → ZMod p => (∑ i, v i) = 0)).card = p^ℓ' := by
    rw [← Fintype.card_subtype]
    exact card_tuple_sum_eq_zero ℓ'
  have hcardtot : (Finset.univ : Finset (Fin (ℓ'+1) → ZMod p)).card = p^(ℓ'+1) := by
    rw [Finset.card_univ, Fintype.card_fun, Fintype.card_fin, ZMod.card]
  have hcard1 : (Finset.univ.filter (fun v : Fin (ℓ'+1) → ZMod p => ¬(∑ i, v i) = 0)).card
      = p^(ℓ'+1) - p^ℓ' := by
    rw [Finset.filter_not, Finset.card_sdiff_of_subset (Finset.filter_subset _ _), hcard0, hcardtot]
  have hle : p^ℓ' ≤ p^(ℓ'+1) := Nat.pow_le_pow_right (NeZero.pos p) (by omega)
  rw [hcard0, hcard1, nsmul_eq_mul, nsmul_eq_mul, Nat.cast_sub hle]
  push_cast
  ring

section SumLocalWeight

variable {M p : ℕ} [NeZero p]

theorem sum_local_weight_eq_blockWeight (hpp : p.Prime) (τ : Equiv.Perm (Fin M)) (x0 : Fin M) :
    ∑ q1 : ↥(orbitAt τ x0) → ZMod p,
      (if (∑ i ∈ Finset.range (MulAction.period τ x0),
            (Function.extend Subtype.val q1 (0 : Fin M → ZMod p)) ((τ^i) x0)) = 0
       then (numDivisors (MulAction.period τ x0) : ℤ) ^ p
       else (numDivisors (p * MulAction.period τ x0) : ℤ))
    = blockWeight p (orbitAt τ x0).card := by
  set ℓ := MulAction.period τ x0 with hℓdef
  have hℓpos : 0 < ℓ := MulAction.period_pos_of_orderOf_pos (orderOf_pos τ) x0
  have hcardS : (orbitAt τ x0).card = ℓ := by
    rw [← periodOrbit_eq_orbitAt, card_periodOrbit]
  set F : (↥(orbitAt τ x0) → ZMod p) → (Fin ℓ → ZMod p) :=
    fun q1 => fun i => q1 (orbitFinEquiv τ x0 i) with hFdef
  have hbij : Function.Bijective F := by
    constructor
    · intro q1 q2 heq
      funext s
      have h := congrFun heq ((orbitFinEquiv τ x0).symm s)
      simp only [hFdef, Equiv.apply_symm_apply] at h
      exact h
    · intro v
      refine ⟨fun s => v ((orbitFinEquiv τ x0).symm s), ?_⟩
      funext i
      simp only [hFdef, Equiv.symm_apply_apply]
  have hgterm : ∀ q1 : ↥(orbitAt τ x0) → ZMod p, ∀ i : Fin ℓ,
      (Function.extend Subtype.val q1 (0 : Fin M → ZMod p)) ((τ^(i:ℕ)) x0) = F q1 i := by
    intro q1 i
    have hmem : (τ^(i:ℕ)) x0 ∈ orbitAt τ x0 := by
      rw [← periodOrbit_eq_orbitAt]
      exact pow_mem_periodOrbit τ x0 hℓpos i
    have h1 : (Function.extend Subtype.val q1 (0 : Fin M → ZMod p)) ((τ^(i:ℕ)) x0)
        = q1 ⟨(τ^(i:ℕ)) x0, hmem⟩ :=
      Subtype.val_injective.extend_apply q1 0 ⟨(τ^(i:ℕ)) x0, hmem⟩
    rw [h1, hFdef]
    congr 1
  have hreindex : ∑ q1 : ↥(orbitAt τ x0) → ZMod p,
      (if (∑ i ∈ Finset.range ℓ,
            (Function.extend Subtype.val q1 (0 : Fin M → ZMod p)) ((τ^i) x0)) = 0
       then (numDivisors ℓ : ℤ) ^ p else (numDivisors (p * ℓ) : ℤ))
    = ∑ v : Fin ℓ → ZMod p,
      (if (∑ i : Fin ℓ, v i) = 0 then (numDivisors ℓ : ℤ)^p else (numDivisors (p*ℓ) : ℤ)) := by
    apply Fintype.sum_bijective F hbij
    intro q1
    have hsum : (∑ i ∈ Finset.range ℓ,
        (Function.extend Subtype.val q1 (0 : Fin M → ZMod p)) ((τ^i) x0))
        = ∑ i : Fin ℓ, F q1 i := by
      rw [← Fin.sum_univ_eq_sum_range
        (fun n => (Function.extend Subtype.val q1 (0 : Fin M → ZMod p)) ((τ^n) x0)) ℓ]
      exact Finset.sum_congr rfl (fun i _ => hgterm q1 i)
    rw [hsum]
  obtain ⟨ℓ', hℓ'⟩ := Nat.exists_eq_succ_of_ne_zero hℓpos.ne'
  rw [hreindex, hcardS, hℓ']
  show (∑ v : Fin (ℓ'+1) → ZMod p,
      (if (∑ i, v i) = 0 then (numDivisors (ℓ'+1) : ℤ)^p else (numDivisors (p*(ℓ'+1)) : ℤ)))
    = blockWeight p (ℓ'+1)
  rw [sum_if_shift_eq_blockWeight p ℓ' ((numDivisors (ℓ'+1):ℤ)^p) (numDivisors (p*(ℓ'+1)):ℤ)]
  unfold blockWeight
  simp only [Nat.add_sub_cancel]
  rw [pow_succ]
  push_cast
  ring

end SumLocalWeight

section GStep

variable {M p : ℕ} [NeZero (M * p)] [NeZero p]

theorem G_step (hM : 0 < M) (hp1 : 1 < p) (hpp : p.Prime) (τ : Equiv.Perm (Fin M))
    {A : Finset (Fin M)} (hA : ∀ b, τ b ∈ A ↔ b ∈ A) {x0 : Fin M} (hx0 : x0 ∈ A) :
    G hM hp1 τ A hA = blockWeight p (orbitAt τ x0).card *
      G hM hp1 τ (A \ orbitAt τ x0) (fun b => by
        simp only [Finset.mem_sdiff]
        exact (hA b).and (not_iff_not.mpr (orbitAt_invariant τ x0 b))) := by
  have hSA : (orbitAt τ x0) ⊆ A := orbitAt_subset_of_invariant hA hx0
  have hS : ∀ b, τ b ∈ (orbitAt τ x0) ↔ b ∈ (orbitAt τ x0) := orbitAt_invariant τ x0
  have hAS : ∀ b, τ b ∈ (A \ orbitAt τ x0) ↔ b ∈ (A \ orbitAt τ x0) := fun b => by
    simp only [Finset.mem_sdiff]
    exact (hA b).and (not_iff_not.mpr (hS b))
  have hfact : ∀ t' : ↥A → ZMod p,
      permWeight ((assembledSigma hM hp1 τ (Function.extend Subtype.val t' 0)).subtypePerm
        (labelsAbove_invariant hM hp1 τ (Function.extend Subtype.val t' 0) A hA))
      = permWeight ((assembledSigma hM hp1 τ
          (Function.extend Subtype.val (splitAS A (orbitAt τ x0) hSA t').1 0)).subtypePerm
          (labelsAbove_invariant hM hp1 τ
            (Function.extend Subtype.val (splitAS A (orbitAt τ x0) hSA t').1 0)
            (orbitAt τ x0) hS))
        * permWeight ((assembledSigma hM hp1 τ
          (Function.extend Subtype.val (splitAS A (orbitAt τ x0) hSA t').2 0)).subtypePerm
          (labelsAbove_invariant hM hp1 τ
            (Function.extend Subtype.val (splitAS A (orbitAt τ x0) hSA t').2 0)
            (A \ orbitAt τ x0) hAS)) := by
    intro t'
    set text := Function.extend Subtype.val t' (0 : Fin M → ZMod p) with htext
    set q1 := (splitAS A (orbitAt τ x0) hSA t').1 with hq1
    set q2 := (splitAS A (orbitAt τ x0) hSA t').2 with hq2
    set tS := Function.extend Subtype.val q1 (0 : Fin M → ZMod p) with htS
    set tAS := Function.extend Subtype.val q2 (0 : Fin M → ZMod p) with htAS
    have hLA1 : labelsAbove (p := p) hM (orbitAt τ x0) ⊆ labelsAbove hM A :=
      labelsAbove_mono hM hSA
    have hLA2 : labelsAbove (p := p) hM A \ labelsAbove hM (orbitAt τ x0)
        = labelsAbove hM (A \ orbitAt τ x0) :=
      labelsAbove_sdiff hM A (orbitAt τ x0)
    have hsplit := permWeight_nested_split'
      (labelsAbove_invariant hM hp1 τ text (orbitAt τ x0) hS)
      (labelsAbove_invariant hM hp1 τ text A hA)
      (labelsAbove_invariant hM hp1 τ text (A \ orbitAt τ x0) hAS)
      hLA1 hLA2
    rw [hsplit]
    have hSonS : ∀ b ∈ orbitAt τ x0, text b = tS b := by
      intro b hb
      have hbA : b ∈ A := hSA hb
      have h1 : text b = t' ⟨b, hbA⟩ := Subtype.val_injective.extend_apply t' 0 ⟨b, hbA⟩
      have h2 : q1 ⟨b, hb⟩ = t' ⟨b, hbA⟩ := by rw [hq1]; rfl
      have h3 : tS b = q1 ⟨b, hb⟩ := Subtype.val_injective.extend_apply q1 0 ⟨b, hb⟩
      rw [h1, h3, h2]
    have hASonAS : ∀ b ∈ (A \ orbitAt τ x0), text b = tAS b := by
      intro b hb
      have hbA : b ∈ A := (Finset.mem_sdiff.mp hb).1
      have h1 : text b = t' ⟨b, hbA⟩ := Subtype.val_injective.extend_apply t' 0 ⟨b, hbA⟩
      have h2 : q2 ⟨b, hb⟩ = t' ⟨b, hbA⟩ := by rw [hq2]; rfl
      have h3 : tAS b = q2 ⟨b, hb⟩ := Subtype.val_injective.extend_apply q2 0 ⟨b, hb⟩
      rw [h1, h3, h2]
    rw [permWeight_subtypePerm_eqOn hM hp1 τ text tS (orbitAt τ x0) hS hSonS,
      permWeight_subtypePerm_eqOn hM hp1 τ text tAS (A \ orbitAt τ x0) hAS hASonAS]
  unfold G
  rw [Finset.sum_congr rfl (fun t' _ => hfact t')]
  rw [Equiv.sum_comp (splitAS A (orbitAt τ x0) hSA)
    (fun q : (↥(orbitAt τ x0) → ZMod p) × (↥(A \ orbitAt τ x0) → ZMod p) =>
      permWeight ((assembledSigma hM hp1 τ (Function.extend Subtype.val q.1 0)).subtypePerm
          (labelsAbove_invariant hM hp1 τ (Function.extend Subtype.val q.1 0) (orbitAt τ x0) hS))
        * permWeight ((assembledSigma hM hp1 τ (Function.extend Subtype.val q.2 0)).subtypePerm
          (labelsAbove_invariant hM hp1 τ (Function.extend Subtype.val q.2 0)
            (A \ orbitAt τ x0) hAS)))]
  rw [Fintype.sum_prod_type]
  dsimp only
  have hfactor : (∑ x : ↥(orbitAt τ x0) → ZMod p, ∑ y : ↥(A \ orbitAt τ x0) → ZMod p,
      permWeight ((assembledSigma hM hp1 τ (Function.extend Subtype.val x 0)).subtypePerm
        (labelsAbove_invariant hM hp1 τ (Function.extend Subtype.val x 0) (orbitAt τ x0) hS))
      * permWeight ((assembledSigma hM hp1 τ (Function.extend Subtype.val y 0)).subtypePerm
        (labelsAbove_invariant hM hp1 τ (Function.extend Subtype.val y 0) (A \ orbitAt τ x0) hAS)))
    = (∑ x : ↥(orbitAt τ x0) → ZMod p, permWeight
        ((assembledSigma hM hp1 τ (Function.extend Subtype.val x 0)).subtypePerm
          (labelsAbove_invariant hM hp1 τ (Function.extend Subtype.val x 0) (orbitAt τ x0) hS)))
      * (∑ y : ↥(A \ orbitAt τ x0) → ZMod p, permWeight
        ((assembledSigma hM hp1 τ (Function.extend Subtype.val y 0)).subtypePerm
          (labelsAbove_invariant hM hp1 τ (Function.extend Subtype.val y 0) (A \ orbitAt τ x0) hAS))) :=
    (Fintype.sum_mul_sum _ _).symm
  rw [hfactor]
  congr 1
  have hswrw : ∀ q1 : ↥(orbitAt τ x0) → ZMod p,
      permWeight ((assembledSigma hM hp1 τ (Function.extend Subtype.val q1 0)).subtypePerm
        (labelsAbove_invariant hM hp1 τ (Function.extend Subtype.val q1 0) (orbitAt τ x0) hS))
      = if (∑ i ∈ Finset.range (MulAction.period τ x0),
            (Function.extend Subtype.val q1 (0 : Fin M → ZMod p)) ((τ^i) x0)) = 0
        then (numDivisors (MulAction.period τ x0) : ℤ) ^ p
        else (numDivisors (p * MulAction.period τ x0) : ℤ) := by
    intro q1
    rw [permWeight_subtypePerm_congr_finset
      (labelsAbove_invariant hM hp1 τ (Function.extend Subtype.val q1 0) (orbitAt τ x0) hS)
      (blockCycleLabels_invariant hM hp1
        (assembledSigma_H_fixed hM hp1 τ (Function.extend Subtype.val q1 0)) x0)
      (labelsAbove_eq_blockCycleLabels hM hp1 τ (Function.extend Subtype.val q1 0) x0)]
    exact assembledSigma_blockCycle_weight hM hp1 hpp τ (Function.extend Subtype.val q1 0) x0
  rw [Finset.sum_congr rfl (fun q1 _ => hswrw q1)]
  exact sum_local_weight_eq_blockWeight hpp τ x0

end GStep

section GInduction

variable {M p : ℕ} [NeZero (M * p)] [NeZero p]

theorem blockPermWeightPieceOnSet_empty (p : ℕ) (τ : Equiv.Perm (Fin M))
    (hA : ∀ b, τ b ∈ (∅ : Finset (Fin M)) ↔ b ∈ (∅ : Finset (Fin M))) :
    blockPermWeightPieceOnSet p τ ∅ hA = 1 := by
  unfold blockPermWeightPieceOnSet
  haveI hempty : IsEmpty (↥(∅ : Finset (Fin M))) := Finset.isEmpty_coe_sort.mpr rfl
  have heq1 : τ.subtypePerm hA = 1 := by
    apply Equiv.ext
    intro x
    exact hempty.elim x
  rw [heq1]
  simp [Equiv.Perm.cycleType_one]

theorem G_eq_blockPermWeightPieceOnSet (hM : 0 < M) (hp1 : 1 < p) (hpp : p.Prime)
    (τ : Equiv.Perm (Fin M)) :
    ∀ (A : Finset (Fin M)) (hA : ∀ b, τ b ∈ A ↔ b ∈ A),
      G hM hp1 τ A hA = blockPermWeightPieceOnSet p τ A hA := by
  intro A
  induction A using Finset.strongInductionOn with
  | _ A ih =>
    intro hA
    rcases Finset.eq_empty_or_nonempty A with hAe | hAne
    · subst hAe
      rw [G_empty hM hp1 τ hA, blockPermWeightPieceOnSet_empty p τ hA]
    · obtain ⟨x0, hx0⟩ := hAne
      have hSA : orbitAt τ x0 ⊆ A := orbitAt_subset_of_invariant hA hx0
      have hSne : (orbitAt τ x0).Nonempty := ⟨x0, x0_mem_orbitAt τ x0⟩
      have hssubset : A \ orbitAt τ x0 ⊂ A := Finset.sdiff_ssubset hSA hSne
      have hAS : ∀ b, τ b ∈ (A \ orbitAt τ x0) ↔ b ∈ (A \ orbitAt τ x0) := fun b => by
        simp only [Finset.mem_sdiff]
        exact (hA b).and (not_iff_not.mpr (orbitAt_invariant τ x0 b))
      rw [G_step hM hp1 hpp τ hA hx0, blockPermWeightPieceOnSet_eq_mul p τ hA hx0,
        ih (A \ orbitAt τ x0) hssubset hAS]

end GInduction

section UnivSpecialize

theorem permWeight_subtypePerm_univ {α : Type*} [Fintype α] [DecidableEq α] (σ : Equiv.Perm α)
    (h : ∀ x, σ x ∈ (Finset.univ : Finset α) ↔ x ∈ (Finset.univ : Finset α)) :
    permWeight (σ.subtypePerm h) = permWeight σ := by
  have hcongr : (Equiv.subtypeUnivEquiv (Finset.mem_univ (α := α))).permCongr (σ.subtypePerm h)
      = σ := by
    apply Equiv.ext
    intro x
    simp [Equiv.subtypeUnivEquiv_apply, Equiv.subtypeUnivEquiv_symm_apply,
      Equiv.Perm.subtypePerm_apply]
  have hcyc : (σ.subtypePerm h).cycleType = σ.cycleType := by
    have h2 := congrArg Equiv.Perm.cycleType hcongr
    rwa [cycleType_permCongr] at h2
  unfold permWeight
  rw [hcyc]

variable {M p : ℕ} [NeZero (M * p)] [NeZero p]

theorem labelsAbove_univ (hM : 0 < M) :
    labelsAbove (p := p) hM (Finset.univ : Finset (Fin M)) = Finset.univ := by
  unfold labelsAbove
  ext x
  simp

theorem G_univ_eq (hM : 0 < M) (hp1 : 1 < p) (τ : Equiv.Perm (Fin M))
    (hUniv : ∀ b, τ b ∈ (Finset.univ : Finset (Fin M)) ↔ b ∈ (Finset.univ : Finset (Fin M))) :
    G hM hp1 τ Finset.univ hUniv = ∑ t : Fin M → ZMod p, permWeight (assembledSigma hM hp1 τ t) := by
  set e : ↥(Finset.univ : Finset (Fin M)) ≃ Fin M :=
    Equiv.subtypeUnivEquiv (Finset.mem_univ (α := Fin M)) with hedef
  have hextend : ∀ t' : ↥(Finset.univ : Finset (Fin M)) → ZMod p,
      Function.extend Subtype.val t' (0 : Fin M → ZMod p) = t' ∘ e.symm := by
    intro t'
    funext b
    have hpre := Subtype.val_injective.extend_apply t' (0 : Fin M → ZMod p) (e.symm b)
    have hval : (Subtype.val (e.symm b) : Fin M) = b := by
      simp [hedef, Equiv.subtypeUnivEquiv_symm_apply]
    rw [hval] at hpre
    exact hpre
  have hpointwise : ∀ t' : ↥(Finset.univ : Finset (Fin M)) → ZMod p,
      permWeight ((assembledSigma hM hp1 τ (Function.extend Subtype.val t' 0)).subtypePerm
        (labelsAbove_invariant hM hp1 τ (Function.extend Subtype.val t' 0) Finset.univ hUniv))
      = permWeight (assembledSigma hM hp1 τ (t' ∘ e.symm)) := by
    intro t'
    have hLA : (labelsAbove_invariant hM hp1 τ (Function.extend Subtype.val t' 0)
        (Finset.univ : Finset (Fin M)) hUniv)
        = (labelsAbove_invariant hM hp1 τ (Function.extend Subtype.val t' 0)
          (Finset.univ : Finset (Fin M)) hUniv) := rfl
    rw [permWeight_subtypePerm_congr_finset
      (labelsAbove_invariant hM hp1 τ (Function.extend Subtype.val t' 0) Finset.univ hUniv)
      (by rw [← labelsAbove_univ (p := p) hM]
          exact labelsAbove_invariant hM hp1 τ (Function.extend Subtype.val t' 0)
            Finset.univ hUniv)
      (labelsAbove_univ hM)]
    rw [permWeight_subtypePerm_univ, hextend t']
  unfold G
  rw [Finset.sum_congr rfl (fun t' _ => hpointwise t')]
  have hEapp : ∀ t' : ↥(Finset.univ : Finset (Fin M)) → ZMod p,
      (Equiv.arrowCongr e (Equiv.refl (ZMod p))) t' = t' ∘ e.symm := fun t' => rfl
  have hreindex := Equiv.sum_comp (Equiv.arrowCongr e (Equiv.refl (ZMod p)))
    (fun t : Fin M → ZMod p => permWeight (assembledSigma hM hp1 τ t))
  simp only [hEapp] at hreindex
  exact hreindex

theorem blockPermWeightPieceOnSet_univ_eq (p : ℕ) (τ : Equiv.Perm (Fin M))
    (hUniv : ∀ b, τ b ∈ (Finset.univ : Finset (Fin M)) ↔ b ∈ (Finset.univ : Finset (Fin M))) :
    blockPermWeightPieceOnSet p τ Finset.univ hUniv = blockPermWeight p M τ := by
  unfold blockPermWeightPieceOnSet blockPermWeight
  have hcongr : (Equiv.subtypeUnivEquiv (Finset.mem_univ (α := Fin M))).permCongr
      (τ.subtypePerm hUniv) = τ := by
    apply Equiv.ext
    intro x
    simp [Equiv.subtypeUnivEquiv_apply, Equiv.subtypeUnivEquiv_symm_apply,
      Equiv.Perm.subtypePerm_apply]
  have hcs : (τ.subtypePerm hUniv).cycleType = τ.cycleType := by
    have h2 := congrArg Equiv.Perm.cycleType hcongr
    rwa [cycleType_permCongr] at h2
  have hsupp : (τ.subtypePerm hUniv).support.card = τ.support.card := by
    rw [← Equiv.Perm.sum_cycleType, ← Equiv.Perm.sum_cycleType, hcs]
  rw [hcs, hsupp, Finset.card_univ, Fintype.card_fin]

end UnivSpecialize

section FinalAssembly

variable {M p : ℕ} [NeZero (M * p)] [NeZero p]

noncomputable def sigmaEquiv (hM : 0 < M) (hp1 : 1 < p) :
    (Equiv.Perm (Fin M) × (Fin M → ZMod p))
      ≃ {σ : Equiv.Perm (ZMod (M*p)) // ((M:ℕ):ZMod (M*p)) +ᵥ σ = σ} := by
  haveI hpNZ : NeZero p := ⟨by omega⟩
  refine Equiv.ofBijective
    (fun q => ⟨assembledSigma hM hp1 q.1 q.2, assembledSigma_H_fixed hM hp1 q.1 q.2⟩) ⟨?_, ?_⟩
  · intro q1 q2 heq
    apply assembledSigma_injective2 hM hp1
    exact congrArg Subtype.val heq
  · intro σ'
    refine ⟨(blockPerm hM hp1 σ'.2, tExtract hM hp1 σ'.1), ?_⟩
    apply Subtype.ext
    exact assembledSigma_tExtract_eq hM hp1 σ'.2

theorem sum_Hfixed_eq_sum_assembledSigma (hM : 0 < M) (hp1 : 1 < p) :
    ∑ σ ∈ Finset.univ.filter
      (fun σ : Equiv.Perm (ZMod (M*p)) => ((M:ℕ):ZMod (M*p)) +ᵥ σ = σ), permWeight σ
    = ∑ τ : Equiv.Perm (Fin M), ∑ t : Fin M → ZMod p, permWeight (assembledSigma hM hp1 τ t) := by
  haveI hpNZ : NeZero p := ⟨by omega⟩
  have hstep1 : ∑ σ ∈ Finset.univ.filter
      (fun σ : Equiv.Perm (ZMod (M*p)) => ((M:ℕ):ZMod (M*p)) +ᵥ σ = σ), permWeight σ
      = ∑ σ' : {σ : Equiv.Perm (ZMod (M*p)) // ((M:ℕ):ZMod (M*p)) +ᵥ σ = σ}, permWeight σ'.1 := by
    rw [Finset.sum_subtype]
    intro x
    rw [Finset.mem_filter]
    simp
  rw [hstep1, ← Equiv.sum_comp (sigmaEquiv hM hp1) (fun σ' => permWeight σ'.1),
    Fintype.sum_prod_type]
  rfl

end FinalAssembly

theorem XNH_eq_blockSum {p r : ℕ} (hp : p.Prime) (hr : 1 ≤ r)
    {N : ℕ} [NeZero N] (hN : N = p ^ r) :
    ∑ σ ∈ Finset.univ.filter
      (fun σ : Equiv.Perm (ZMod N) => ((p ^ (r - 1) : ℕ) : ZMod N) +ᵥ σ = σ), permWeight σ
      = ∑ τ : Equiv.Perm (Fin (p ^ (r - 1))), blockPermWeight p (p ^ (r - 1)) τ := by
  have hp1 : 1 < p := hp.one_lt
  haveI hpNZ : NeZero p := ⟨hp.pos.ne'⟩
  have hMpos : 0 < p ^ (r-1) := pow_pos hp.pos (r-1)
  have hNeq : N = p ^ (r-1) * p := by
    rw [hN, ← pow_succ]
    congr 1
    omega
  subst hNeq
  rw [sum_Hfixed_eq_sum_assembledSigma hMpos hp1]
  refine Finset.sum_congr rfl (fun τ _ => ?_)
  have hUniv : ∀ b, τ b ∈ (Finset.univ : Finset (Fin (p^(r-1)))) ↔
      b ∈ (Finset.univ : Finset (Fin (p^(r-1)))) := fun b => by simp
  rw [← G_univ_eq hMpos hp1 τ hUniv,
    G_eq_blockPermWeightPieceOnSet hMpos hp1 hp τ Finset.univ hUniv,
    blockPermWeightPieceOnSet_univ_eq p τ hUniv]


/-! **Proposition 4.2 (`prop:primepower`), odd-prime case**: `a(p^r) ≡ -1 (mod p^r)`. -/

/-! ### Toward `primepower_odd'`/`primepower_two_large'`: grouping `blockPermSum` by support size

The `D_L` grouping identity (`blockPermSum_eq_sum_L`): `blockPermSum p (Fin M) = ∑_{L=0}^{M}
(M.choose L) * (blockWeight p 1)^(M-L) * D L`, where `D L := derangementBlockSum p L` is the
"no-fixed-point" (derangement-weighted) sub-sum `∑_{τ : Equiv.Perm (Fin L), τ.support = univ}
(τ.cycleType.map (blockWeight p)).prod`. Proved by grouping `∑ τ, blockPermWeightPiece p τ` first
by `τ.support` (a `Finset (Fin M)`, via `blockPermWeightPiece_sum_support_eq`, itself proved via
an explicit `Finset.sum_bij'` transporting `τ` restricted to its support across a chosen
`Fin S.card ≃ ↥S` to a support-`univ` permutation of `Fin S.card`), then regrouping that outer sum
by `S.card` (via `Finset.card_powersetCard`, the standard "number of `L`-subsets of an `M`-set is
`M.choose L`" fact). This is the standalone sanity-check piece of the roadmap sketched in
`primepower_odd'`'s docstring; the remaining piece is a `p`-adic valuation lower bound on each
`L ≥ 2` term (via Legendre's formula, `M = p^(r-1)`), not yet attempted. -/

open Equiv Equiv.Perm

theorem eq_ofSubtype_subtypePerm_of_support_eq {α : Type*} [Fintype α] [DecidableEq α]
    {τ : Equiv.Perm α} {S : Finset α} (hτS : τ.support = S) (hSA : ∀ x, τ x ∈ S ↔ x ∈ S) :
    τ = Equiv.Perm.ofSubtype (τ.subtypePerm hSA) := by
  apply Equiv.ext
  intro x
  by_cases hx : x ∈ S
  · rw [Equiv.Perm.ofSubtype_apply_of_mem _ hx, Equiv.Perm.subtypePerm_apply]
  · rw [Equiv.Perm.ofSubtype_apply_of_not_mem _ hx]
    have hnotmem : x ∉ τ.support := by rw [hτS]; exact hx
    exact Equiv.Perm.notMem_support.mp hnotmem

noncomputable def derangementBlockSum (p L : ℕ) : ℤ :=
  ∑ τ ∈ Finset.univ.filter (fun τ : Equiv.Perm (Fin L) => τ.support = Finset.univ),
    (τ.cycleType.map (blockWeight p)).prod

theorem blockPermWeightPiece_sum_support_eq (p : ℕ) {M : ℕ} (S : Finset (Fin M)) :
    ∑ τ ∈ Finset.univ.filter (fun τ : Equiv.Perm (Fin M) => τ.support = S),
      blockPermWeightPiece p τ
    = (blockWeight p 1) ^ (M - S.card) * derangementBlockSum p S.card := by
  classical
  unfold derangementBlockSum
  rw [Finset.mul_sum]
  set L := S.card with hLdef
  set e : Fin L ≃ ↥S := (Fintype.equivFinOfCardEq (Fintype.card_coe S)).symm with hedef
  have hSA : ∀ (τ : Equiv.Perm (Fin M)), τ.support = S → ∀ x, τ x ∈ S ↔ x ∈ S := by
    intro τ hτS x
    rw [← hτS]
    exact Equiv.Perm.apply_mem_support
  -- Clean, self-contained pointwise unfoldings, to avoid `e`/`e.symm` notation getting
  -- inconsistently unfolded by later `congrArg`/`rw` chains.
  have hA : ∀ (X : Equiv.Perm ↥S) (y : Fin L), (e.symm.permCongr X) y = e.symm (X (e y)) :=
    fun X y => by rw [Equiv.permCongr_apply, Equiv.symm_symm]
  have hB : ∀ (X : Equiv.Perm (Fin L)) (s : ↥S), (e.permCongr X) s = e (X (e.symm s)) :=
    fun X s => Equiv.permCongr_apply e X s
  apply Finset.sum_bij'
    (i := fun (τ : Equiv.Perm (Fin M)) (hτ : τ ∈ Finset.univ.filter
        (fun τ : Equiv.Perm (Fin M) => τ.support = S)) =>
      e.symm.permCongr (τ.subtypePerm (hSA τ (by
        simp only [Finset.mem_filter, Finset.mem_univ, true_and] at hτ; exact hτ))))
    (j := fun (τ' : Equiv.Perm (Fin L))
        (_ : τ' ∈ Finset.univ.filter (fun τ' : Equiv.Perm (Fin L) => τ'.support = Finset.univ)) =>
      Equiv.Perm.ofSubtype (e.permCongr τ'))
    ?_ ?_ ?_ ?_ ?_
  · -- hi : i maps into target filter
    intro τ hτ
    simp only [Finset.mem_filter, Finset.mem_univ, true_and] at hτ ⊢
    ext y
    simp only [Equiv.Perm.mem_support, Finset.mem_univ, iff_true]
    intro hc
    rw [hA (τ.subtypePerm (hSA τ hτ)) y] at hc
    have heq2 : (τ.subtypePerm (hSA τ hτ)) (e y) = e y := by
      have h6 := congrArg e hc
      rwa [Equiv.apply_symm_apply] at h6
    rw [Equiv.Perm.subtypePerm_apply] at heq2
    have heq : τ (e y : Fin M) = (e y : Fin M) := congrArg Subtype.val heq2
    have hxmem : (e y : Fin M) ∈ S := (e y).2
    have hsuppmem : (e y : Fin M) ∈ τ.support := by rw [hτ]; exact hxmem
    rw [Equiv.Perm.mem_support] at hsuppmem
    exact hsuppmem heq
  · -- hj : j maps into source filter
    intro τ' hτ'
    simp only [Finset.mem_filter, Finset.mem_univ, true_and] at hτ' ⊢
    ext x
    rw [Equiv.Perm.mem_support]
    constructor
    · intro hc
      by_contra hxS
      exact hc (Equiv.Perm.ofSubtype_apply_of_not_mem _ hxS)
    · intro hxS
      rw [Equiv.Perm.ofSubtype_apply_of_mem _ hxS, hB τ' ⟨x, hxS⟩]
      intro hc
      have hc' : e (τ' (e.symm ⟨x, hxS⟩)) = (⟨x, hxS⟩ : ↥S) := Subtype.ext hc
      have heq : τ' (e.symm ⟨x, hxS⟩) = e.symm ⟨x, hxS⟩ := by
        have h5 := congrArg e.symm hc'
        rwa [Equiv.symm_apply_apply] at h5
      have hmemsupp : e.symm (⟨x, hxS⟩ : ↥S) ∈ τ'.support := by rw [hτ']; exact Finset.mem_univ _
      rw [Equiv.Perm.mem_support] at hmemsupp
      exact hmemsupp heq
  · -- left_inv : j (i τ) = τ
    intro τ hτ
    simp only [Finset.mem_filter, Finset.mem_univ, true_and] at hτ
    apply Equiv.ext
    intro x
    by_cases hx : x ∈ S
    · show (Equiv.Perm.ofSubtype (e.permCongr (e.symm.permCongr
          (τ.subtypePerm (hSA τ hτ))))) x = τ x
      rw [Equiv.Perm.ofSubtype_apply_of_mem _ hx, hB (e.symm.permCongr (τ.subtypePerm (hSA τ hτ)))
        ⟨x, hx⟩, hA (τ.subtypePerm (hSA τ hτ))]
      simp only [Equiv.symm_apply_apply, Equiv.apply_symm_apply, Equiv.Perm.subtypePerm_apply]
    · show (Equiv.Perm.ofSubtype (e.permCongr (e.symm.permCongr
          (τ.subtypePerm (hSA τ hτ))))) x = τ x
      rw [Equiv.Perm.ofSubtype_apply_of_not_mem _ hx]
      have hnotmem : x ∉ τ.support := by rw [hτ]; exact hx
      exact (Equiv.Perm.notMem_support.mp hnotmem).symm
  · -- right_inv : i (j τ') = τ'
    intro τ' hτ'
    simp only [Finset.mem_filter, Finset.mem_univ, true_and] at hτ'
    have hjS : (Equiv.Perm.ofSubtype (e.permCongr τ')).support = S := by
      ext x
      rw [Equiv.Perm.mem_support]
      constructor
      · intro hc
        by_contra hxS
        exact hc (Equiv.Perm.ofSubtype_apply_of_not_mem _ hxS)
      · intro hxS
        rw [Equiv.Perm.ofSubtype_apply_of_mem _ hxS, hB τ' ⟨x, hxS⟩]
        intro hc
        have hc' : e (τ' (e.symm ⟨x, hxS⟩)) = (⟨x, hxS⟩ : ↥S) := Subtype.ext hc
        have heq : τ' (e.symm ⟨x, hxS⟩) = e.symm ⟨x, hxS⟩ := by
          have h5 := congrArg e.symm hc'
          rwa [Equiv.symm_apply_apply] at h5
        have hmemsupp : e.symm (⟨x, hxS⟩ : ↥S) ∈ τ'.support := by
          rw [hτ']; exact Finset.mem_univ _
        rw [Equiv.Perm.mem_support] at hmemsupp
        exact hmemsupp heq
    apply Equiv.ext
    intro b
    show (e.symm.permCongr ((Equiv.Perm.ofSubtype (e.permCongr τ')).subtypePerm
      (hSA (Equiv.Perm.ofSubtype (e.permCongr τ')) hjS))) b = τ' b
    have hval : (((Equiv.Perm.ofSubtype (e.permCongr τ')).subtypePerm
        (hSA (Equiv.Perm.ofSubtype (e.permCongr τ')) hjS)) (e b) : Fin M)
        = ((e (τ' b) : ↥S) : Fin M) := by
      rw [Equiv.Perm.subtypePerm_apply]
      have hmem : (e b : Fin M) ∈ S := (e b).2
      show (Equiv.Perm.ofSubtype (e.permCongr τ')) (e b : Fin M) = ((e (τ' b) : ↥S) : Fin M)
      rw [Equiv.Perm.ofSubtype_apply_of_mem _ hmem, hB τ' ⟨(e b : Fin M), hmem⟩]
      have hmk : (⟨(e b : Fin M), hmem⟩ : ↥S) = e b := rfl
      rw [hmk, Equiv.symm_apply_apply]
    have heq3 : ((Equiv.Perm.ofSubtype (e.permCongr τ')).subtypePerm
        (hSA (Equiv.Perm.ofSubtype (e.permCongr τ')) hjS)) (e b) = e (τ' b) := Subtype.ext hval
    rw [hA ((Equiv.Perm.ofSubtype (e.permCongr τ')).subtypePerm
      (hSA (Equiv.Perm.ofSubtype (e.permCongr τ')) hjS)) b, heq3, Equiv.symm_apply_apply]
  · -- value preservation
    intro τ hτ
    simp only [Finset.mem_filter, Finset.mem_univ, true_and] at hτ
    have hcyc : τ.cycleType = (τ.subtypePerm (hSA τ hτ)).cycleType := by
      conv_lhs => rw [eq_ofSubtype_subtypePerm_of_support_eq hτ (hSA τ hτ)]
      rw [Equiv.Perm.cycleType_ofSubtype]
    have hcard : τ.support.card = L := by rw [hτ]
    show (τ.cycleType.map (blockWeight p)).prod * (blockWeight p 1) ^
        (Fintype.card (Fin M) - τ.support.card)
      = (blockWeight p 1) ^ (M - L) *
        ((e.symm.permCongr (τ.subtypePerm (hSA τ hτ))).cycleType.map (blockWeight p)).prod
    rw [hcard, hcyc, cycleType_permCongr, Fintype.card_fin]
    ring

open Equiv Equiv.Perm

theorem blockPermSum_eq_sum_support (p M : ℕ) :
    blockPermSum p (Fin M) = ∑ S : Finset (Fin M),
      ∑ τ ∈ Finset.univ.filter (fun τ : Equiv.Perm (Fin M) => τ.support = S),
        blockPermWeightPiece p τ := by
  unfold blockPermSum
  exact (Finset.sum_fiberwise_of_maps_to
    (t := (Finset.univ : Finset (Finset (Fin M))))
    (fun τ (_ : τ ∈ (Finset.univ : Finset (Equiv.Perm (Fin M)))) => Finset.mem_univ (τ.support))
    (blockPermWeightPiece p)).symm

theorem blockPermSum_eq_sum_L (p M : ℕ) :
    blockPermSum p (Fin M) = ∑ L ∈ Finset.range (M+1),
      (M.choose L : ℤ) * (blockWeight p 1)^(M-L) * derangementBlockSum p L := by
  classical
  rw [blockPermSum_eq_sum_support]
  rw [Finset.sum_congr rfl (fun S (_ : S ∈ (Finset.univ : Finset (Finset (Fin M)))) =>
    blockPermWeightPiece_sum_support_eq p S)]
  have hgroup : ∑ S : Finset (Fin M), (blockWeight p 1) ^ (M - S.card) * derangementBlockSum p S.card
      = ∑ L ∈ Finset.range (M+1), ∑ S ∈ Finset.univ.filter (fun S : Finset (Fin M) => S.card = L),
          (blockWeight p 1) ^ (M - S.card) * derangementBlockSum p S.card := by
    exact (Finset.sum_fiberwise_of_maps_to
      (t := Finset.range (M+1))
      (g := fun S : Finset (Fin M) => S.card)
      (fun S (_ : S ∈ (Finset.univ : Finset (Finset (Fin M)))) => by
        apply Finset.mem_range.mpr
        have hle := Finset.card_le_univ S
        rw [Fintype.card_fin] at hle
        omega)
      (fun S : Finset (Fin M) => (blockWeight p 1) ^ (M - S.card) * derangementBlockSum p S.card)).symm
  rw [hgroup]
  apply Finset.sum_congr rfl
  intro L _
  have hcardset : Finset.univ.filter (fun S : Finset (Fin M) => S.card = L)
      = Finset.powersetCard L (Finset.univ : Finset (Fin M)) := by
    ext S
    simp [Finset.mem_powersetCard]
  rw [hcardset]
  rw [Finset.sum_congr rfl (fun S hS => by
    rw [(Finset.mem_powersetCard.mp hS).2])]
  rw [Finset.sum_const, Finset.card_powersetCard, Finset.card_univ, Fintype.card_fin, nsmul_eq_mul]
  ring

/-! ### The `p`-adic valuation bound on `D_L = derangementBlockSum p L`, and the assembled
congruence `blockPermSum p (Fin M) ≡ (blockWeight p 1)^M (mod p^r)` for `M = p^(r-1)`, `p` odd.

Every `τ` counted in `D_L` has `τ.support = Finset.univ`, hence (as a permutation with no fixed
points) `τ.cycleType` consists entirely of parts `≥ 2` summing to `L`; so `τ.cycleType.card ≤ L/2`,
and since `blockWeight p ℓ` carries an explicit factor `p^(ℓ-1)`, the product over the cycle type
carries a factor of `p^(L - τ.cycleType.card) ≥ p^(⌈L/2⌉)`. Combined with the exact valuation
`v_p(M.choose L) = (r-1) - v_p(L)` (`Nat.factorization_choose_prime_pow`, `M = p^(r-1)`) and the
elementary bound `2 * v_p(L) + 1 ≤ L` (for `p ≥ 3`), the two valuations sum to exactly `r` for
every `L` with `2 ≤ L ≤ M`, giving `p^r ∣ (M.choose L) * W_1^(M-L) * D_L` for each such `L`; the
`L = 0` term is exactly `W_1^M` and the `L = 1` term vanishes (`derangementBlockSum p 1 = 0`, no
fixed-point-free permutation of a 1-element set), so summing over `L` gives the full congruence. -/

theorem two_mul_add_one_le_pow (p v : ℕ) (hp3 : 3 ≤ p) : 2 * v + 1 ≤ p ^ v := by
  induction v with
  | zero => simp
  | succ v ih =>
    have h1 : p ^ (v + 1) = p * p ^ v := by ring
    rw [h1]
    have h2 : 3 * p ^ v ≤ p * p ^ v := Nat.mul_le_mul_right _ hp3
    have h3 : 3 * (2 * v + 1) ≤ 3 * p ^ v := Nat.mul_le_mul_left _ ih
    omega

theorem two_mul_padicValNat_lt (p : ℕ) (hp3 : 3 ≤ p) (L : ℕ) (hL : 0 < L) :
    2 * padicValNat p L + 1 ≤ L := by
  have hle : p ^ (padicValNat p L) ≤ L := Nat.le_of_dvd hL pow_padicValNat_dvd
  have hpow := two_mul_add_one_le_pow p (padicValNat p L) hp3
  omega

theorem card_le_sum_of_two_le {s : Multiset ℕ} (hs : ∀ c ∈ s, 2 ≤ c) : s.card ≤ s.sum := by
  induction s using Multiset.induction with
  | empty => simp
  | cons c s ih =>
    have hc : 2 ≤ c := hs c (Multiset.mem_cons_self c s)
    have hs' : ∀ x ∈ s, 2 ≤ x := fun x hx => hs x (Multiset.mem_cons_of_mem hx)
    have := ih hs'
    simp only [Multiset.card_cons, Multiset.sum_cons]
    omega

theorem two_mul_card_le_sum_of_two_le {s : Multiset ℕ} (hs : ∀ c ∈ s, 2 ≤ c) :
    2 * s.card ≤ s.sum := by
  induction s using Multiset.induction with
  | empty => simp
  | cons c s ih =>
    have hc : 2 ≤ c := hs c (Multiset.mem_cons_self c s)
    have hs' : ∀ x ∈ s, 2 ≤ x := fun x hx => hs x (Multiset.mem_cons_of_mem hx)
    have := ih hs'
    simp only [Multiset.card_cons, Multiset.sum_cons]
    omega

theorem dvd_prod_map_blockWeight (p : ℕ) (s : Multiset ℕ) (hs : ∀ c ∈ s, 2 ≤ c) :
    (p : ℤ) ^ (s.sum - s.card) ∣ (s.map (blockWeight p)).prod := by
  induction s using Multiset.induction with
  | empty => simp
  | cons c s ih =>
    have hc : 2 ≤ c := hs c (Multiset.mem_cons_self c s)
    have hs' : ∀ x ∈ s, 2 ≤ x := fun x hx => hs x (Multiset.mem_cons_of_mem hx)
    have hcard_le_sum : s.card ≤ s.sum := card_le_sum_of_two_le hs'
    have hdvd1 : (p : ℤ) ^ (c - 1) ∣ blockWeight p c := by
      unfold blockWeight
      exact Dvd.intro _ rfl
    have hdvd2 : (p : ℤ) ^ (s.sum - s.card) ∣ (s.map (blockWeight p)).prod := ih hs'
    have hdvd3 : (p : ℤ) ^ ((c - 1) + (s.sum - s.card)) ∣
        blockWeight p c * (s.map (blockWeight p)).prod := by
      rw [pow_add]
      exact mul_dvd_mul hdvd1 hdvd2
    have heq : (c - 1) + (s.sum - s.card) = (c + s.sum) - (s.card + 1) := by omega
    simp only [Multiset.map_cons, Multiset.prod_cons, Multiset.sum_cons, Multiset.card_cons]
    rwa [heq] at hdvd3

theorem derangementBlockSum_zero (p : ℕ) : derangementBlockSum p 0 = 1 := by
  unfold derangementBlockSum
  have hfilter : (Finset.univ : Finset (Equiv.Perm (Fin 0))).filter
      (fun τ => τ.support = Finset.univ) = Finset.univ := by
    apply Finset.filter_true_of_mem
    intro τ _
    apply Finset.eq_univ_of_forall
    intro x
    exact Fin.elim0 x
  rw [hfilter]
  rw [Finset.sum_eq_single (1 : Equiv.Perm (Fin 0))]
  · simp
  · intro b _ hb
    exact absurd (Subsingleton.elim b 1) hb
  · intro h
    exact absurd (Finset.mem_univ 1) h

theorem derangementBlockSum_one (p : ℕ) : derangementBlockSum p 1 = 0 := by
  unfold derangementBlockSum
  have hτeq1 : ∀ τ : Equiv.Perm (Fin 1), τ = 1 := fun τ =>
    Equiv.ext (fun x => Subsingleton.elim (τ x) x)
  have hfilter : (Finset.univ : Finset (Equiv.Perm (Fin 1))).filter
      (fun τ => τ.support = Finset.univ) = ∅ := by
    apply Finset.filter_false_of_mem
    intro τ _
    rw [hτeq1 τ, Equiv.Perm.support_one]
    intro hcontra
    have hmem : (0 : Fin 1) ∈ (Finset.univ : Finset (Fin 1)) := Finset.mem_univ _
    rw [← hcontra] at hmem
    exact absurd hmem (Finset.notMem_empty _)
  rw [hfilter]
  simp

theorem derangementBlockSum_dvd (p L : ℕ) (hp3 : 3 ≤ p) (hL : 2 ≤ L) :
    (p : ℤ) ^ (padicValNat p L + 1) ∣ derangementBlockSum p L := by
  unfold derangementBlockSum
  have hval : ∀ τ ∈ Finset.univ.filter (fun τ : Equiv.Perm (Fin L) => τ.support = Finset.univ),
      (p : ℤ) ^ (padicValNat p L + 1) ∣ (τ.cycleType.map (blockWeight p)).prod := by
    intro τ hτ
    simp only [Finset.mem_filter, Finset.mem_univ, true_and] at hτ
    have hsum : τ.cycleType.sum = L := by
      rw [Equiv.Perm.sum_cycleType, hτ, Finset.card_univ, Fintype.card_fin]
    have hge2 : ∀ c ∈ τ.cycleType, 2 ≤ c := fun c hc => Equiv.Perm.two_le_of_mem_cycleType hc
    have hcard_le : 2 * τ.cycleType.card ≤ τ.cycleType.sum := two_mul_card_le_sum_of_two_le hge2
    have hval2 : 2 * padicValNat p L + 1 ≤ L := two_mul_padicValNat_lt p hp3 L (by omega)
    have hdvd := dvd_prod_map_blockWeight p τ.cycleType hge2
    have hexp : padicValNat p L + 1 ≤ τ.cycleType.sum - τ.cycleType.card := by omega
    have hpow_dvd : (p:ℤ) ^ (padicValNat p L + 1) ∣ (p:ℤ) ^ (τ.cycleType.sum - τ.cycleType.card) :=
      pow_dvd_pow _ hexp
    exact hpow_dvd.trans hdvd
  exact Finset.dvd_sum hval

theorem choose_prime_pow_dvd (p r L : ℕ) (hp : p.Prime) (hL0 : L ≠ 0) (hLM : L ≤ p ^ (r - 1)) :
    (p : ℤ) ^ ((r - 1) - padicValNat p L) ∣ ((p ^ (r - 1)).choose L : ℤ) := by
  have hfact := Nat.factorization_choose_prime_pow hp hLM hL0
  simp only [Nat.factorization_def _ hp] at hfact
  rw [← hfact]
  exact_mod_cast pow_padicValNat_dvd

theorem blockPermSum_dvd_sub_W1_pow (p r : ℕ) (hp : p.Prime) (hp3 : 3 ≤ p) (hr : 1 ≤ r) :
    (p : ℤ) ^ r ∣ blockPermSum p (Fin (p ^ (r - 1))) - (blockWeight p 1) ^ (p ^ (r - 1)) := by
  set M := p ^ (r - 1) with hMdef
  have hM1 : 1 ≤ M := Nat.one_le_iff_ne_zero.mpr (pow_ne_zero _ hp.ne_zero)
  rw [blockPermSum_eq_sum_L p M]
  have hsplit : ∑ L ∈ Finset.range (M + 1),
      ((M.choose L : ℤ) * (blockWeight p 1) ^ (M - L) * derangementBlockSum p L)
      = (blockWeight p 1) ^ M
        + ∑ L ∈ Finset.Ico 2 (M + 1),
            ((M.choose L : ℤ) * (blockWeight p 1) ^ (M - L) * derangementBlockSum p L) := by
    rw [Finset.range_eq_Ico,
      ← Finset.sum_Ico_consecutive _ (show (0:ℕ) ≤ 2 by omega) (show (2:ℕ) ≤ M + 1 by omega)]
    have h01 : Finset.Ico (0:ℕ) 2 = {0, 1} := by decide
    rw [h01]
    rw [Finset.sum_insert (by decide), Finset.sum_singleton]
    have e0 : (M.choose 0 : ℤ) * (blockWeight p 1) ^ (M - 0) * derangementBlockSum p 0
        = (blockWeight p 1) ^ M := by
      rw [derangementBlockSum_zero]
      simp
    have e1 : (M.choose 1 : ℤ) * (blockWeight p 1) ^ (M - 1) * derangementBlockSum p 1 = 0 := by
      rw [derangementBlockSum_one]
      ring
    rw [e0, e1]
    ring
  rw [hsplit]
  have hgoal : (blockWeight p 1) ^ M + ∑ L ∈ Finset.Ico 2 (M + 1),
      ((M.choose L : ℤ) * (blockWeight p 1) ^ (M - L) * derangementBlockSum p L)
      - (blockWeight p 1) ^ M
      = ∑ L ∈ Finset.Ico 2 (M + 1),
          ((M.choose L : ℤ) * (blockWeight p 1) ^ (M - L) * derangementBlockSum p L) := by
    ring
  rw [hgoal]
  apply Finset.dvd_sum
  intro L hL
  rw [Finset.mem_Ico] at hL
  obtain ⟨hL2, hLM1⟩ := hL
  have hLM : L ≤ M := by omega
  have hL0 : L ≠ 0 := by omega
  have h1 := choose_prime_pow_dvd p r L hp hL0 hLM
  have h2 := derangementBlockSum_dvd p L hp3 hL2
  have hvle : padicValNat p L ≤ r - 1 := by
    have hple : p ^ (padicValNat p L) ≤ L := Nat.le_of_dvd (by omega) pow_padicValNat_dvd
    have hple2 : p ^ (padicValNat p L) ≤ p ^ (r - 1) := le_trans hple hLM
    exact (Nat.pow_le_pow_iff_right hp.one_lt).mp hple2
  have hexp : (r - 1 - padicValNat p L) + (padicValNat p L + 1) = r := by omega
  have hdvd12 : (p : ℤ) ^ r ∣ (M.choose L : ℤ) * derangementBlockSum p L := by
    rw [← hexp, pow_add]
    exact mul_dvd_mul h1 h2
  have h3 : (M.choose L : ℤ) * (blockWeight p 1) ^ (M - L) * derangementBlockSum p L
      = (M.choose L : ℤ) * derangementBlockSum p L * (blockWeight p 1) ^ (M - L) := by ring
  rw [h3]
  exact hdvd12.mul_right _

/-! ### Bridging `numDivisors` to `Nat.divisors`, to compute `blockWeight p 1 = 2p - 1` -/

theorem numDivisors_eq_card_divisors (m : ℕ) : numDivisors m = (Nat.divisors m).card := by
  unfold numDivisors Nat.divisors
  rw [List.countP_eq_length_filter]
  rw [← List.toFinset_card_of_nodup]
  · congr 1
    ext d
    simp only [List.mem_toFinset, List.mem_filter, List.mem_map, List.mem_range,
      Finset.mem_filter, Finset.mem_Ico, beq_iff_eq]
    constructor
    · rintro ⟨⟨a, ha, rfl⟩, hdvd⟩
      exact ⟨⟨by omega, by omega⟩, Nat.dvd_of_mod_eq_zero hdvd⟩
    · rintro ⟨⟨h1, h2⟩, hdvd⟩
      refine ⟨⟨d - 1, by omega, by omega⟩, ?_⟩
      exact Nat.dvd_iff_mod_eq_zero.mp hdvd
  · exact List.Nodup.filter _ ((List.nodup_range).map (fun a b hab => by omega))

theorem numDivisors_prime {p : ℕ} (hp : p.Prime) : numDivisors p = 2 := by
  rw [numDivisors_eq_card_divisors, hp.divisors]
  rw [Finset.card_insert_of_notMem (by simp [hp.ne_one.symm]), Finset.card_singleton]

/-- `blockWeight p 1 = 2*p - 1` (as an integer identity `blockWeight p 1 = -(1 - 2*p)`, the form
needed for the lifting-the-exponent step). `numDivisors 1 = 1` (`decide`), `numDivisors p = 2`
(`numDivisors_prime`), so `blockWeight p 1 = p^0 * (1^p + (p-1)*2) = 1 + 2p - 2 = 2p - 1`. -/
theorem blockWeight_one_eq (p : ℕ) (hp : p.Prime) :
    blockWeight p 1 = 2 * (p : ℤ) - 1 := by
  unfold blockWeight
  have hnd1 : numDivisors 1 = 1 := by decide
  simp only [mul_one]
  rw [hnd1, numDivisors_prime hp]
  simp
  ring

theorem odd_prime_ge_three {p : ℕ} (hp : p.Prime) (hodd : Odd p) : 3 ≤ p := by
  have hne2 : p ≠ 2 := by rintro rfl; exact (by decide : ¬ Odd 2) hodd
  have := hp.two_le
  omega

/-- `emultiplicity p (2p) = 1` for an odd prime `p`: `p ∣ 2p` trivially, and `p^2 ∣ 2p` would
force `p ∣ 2` (cancelling one factor of `p`), impossible since `p ≥ 3`. -/
theorem emultiplicity_two_mul_prime {p : ℕ} (hp : p.Prime) (hp3 : 3 ≤ p) :
    emultiplicity (p : ℤ) (2 * (p : ℤ)) = 1 := by
  apply emultiplicity_eq_of_dvd_of_not_dvd
  · rw [pow_one]; exact Dvd.intro 2 (by ring)
  · intro hcontra
    have hp0 : (p:ℤ) ≠ 0 := by exact_mod_cast hp.pos.ne'
    have heq : (p:ℤ)^2 = (p:ℤ) * (p:ℤ) := sq (p:ℤ) ▸ rfl
    rw [heq, show (2:ℤ) * (p:ℤ) = (p:ℤ) * 2 by ring] at hcontra
    have h2 : (p:ℤ) ∣ 2 := (mul_dvd_mul_iff_left hp0).mp hcontra
    have h2' : p ∣ 2 := by exact_mod_cast h2
    have := Nat.le_of_dvd (by norm_num) h2'
    omega

/-- **The lifting-the-exponent step (`eq:vp` in the paper)**: `(2p-1)^(p^(r-1)) ≡ -1 (mod p^r)`,
equivalently `p^r ∣ (2p-1)^(p^(r-1)) + 1`. Proved via Mathlib's odd-prime LTE lemma
`Int.emultiplicity_pow_add_pow` applied to `x := 2p - 1`, `y := 1` (so `x + y = 2p`, of
`emultiplicity p` exactly `1`, and `n := p^(r-1)` is odd with `emultiplicity p n = r - 1`),
giving `emultiplicity p (x^n + y^n) = 1 + (r - 1) = r`. -/
theorem lte_step (p r : ℕ) (hp : p.Prime) (hodd : Odd p) (hr : 1 ≤ r) :
    (p : ℤ) ^ r ∣ (2 * (p : ℤ) - 1) ^ (p ^ (r - 1)) + 1 := by
  have hp3 := odd_prime_ge_three hp hodd
  set n := p ^ (r - 1) with hndef
  have hn_odd : Odd n := by
    rw [hndef]
    exact (hp.odd_of_ne_two (by omega)).pow
  set x : ℤ := 2 * (p:ℤ) - 1 with hxdef
  set y : ℤ := 1 with hydef
  have hxy : (p:ℤ) ∣ x + y := by
    have hval : x + y = 2 * (p:ℤ) := by rw [hxdef, hydef]; ring
    rw [hval]; exact Dvd.intro 2 (by ring)
  have hx : ¬ (p:ℤ) ∣ x := by
    intro hdvd
    have hdvd1 : (p:ℤ) ∣ (2*(p:ℤ) - x) := dvd_sub (Dvd.intro 2 (by ring)) hdvd
    have hval : (2*(p:ℤ) - x) = 1 := by rw [hxdef]; ring
    rw [hval] at hdvd1
    have hple : (p:ℤ) ≤ 1 := Int.le_of_dvd (by norm_num) hdvd1
    have : (3:ℤ) ≤ (p:ℤ) := by exact_mod_cast hp3
    omega
  have hval := Int.emultiplicity_pow_add_pow hp hodd hxy hx hn_odd
  have hval2 : emultiplicity (p:ℤ) (x + y) = 1 := by
    have hveq : x + y = 2 * (p:ℤ) := by rw [hxdef, hydef]; ring
    rw [hveq]; exact emultiplicity_two_mul_prime hp hp3
  rw [hval2] at hval
  have hvaln : emultiplicity p n = ((r - 1 : ℕ) : ℕ∞) := by
    rw [hndef]; exact_mod_cast hp.emultiplicity_pow_self
  rw [hvaln] at hval
  have hrcast : (1 : ℕ∞) + ((r-1 : ℕ) : ℕ∞) = (r : ℕ∞) := by
    have : (1:ℕ) + (r-1) = r := by omega
    exact_mod_cast this
  rw [hrcast] at hval
  have hle : (r:ℕ) ≤ emultiplicity (p:ℤ) (x^n + y^n) := by rw [hval]
  have hfinal := pow_dvd_of_le_emultiplicity hle
  simpa [hxdef, hydef] using hfinal

/-- **Proposition 4.2 (`prop:primepower`), odd-prime case**: `a(p^r) ≡ -1 (mod p^r)`.

**Fully proved.** Assembled from: `primepower_setup_reduction` (`a N ≡ ∑_{H-fixed σ} permWeight σ
(mod N)`), `XNH_eq_blockSum` (that sum `= ∑ τ, blockPermWeight p M τ` for `M = p^(r-1)`),
`blockPermSum_eq_sum_blockPermWeight` (bridging to `blockPermSum p (Fin M)`),
`blockPermSum_dvd_sub_W1_pow` (the `D_L`/Legendre valuation congruence `blockPermSum p (Fin M) ≡
(blockWeight p 1)^M (mod p^r)`), `blockWeight_one_eq` (`blockWeight p 1 = 2p - 1`), and `lte_step`
(the lifting-the-exponent step `(2p-1)^M ≡ -1 (mod p^r)`). Chaining these five congruences
telescopes exactly to `a(p^r) ≡ -1 (mod p^r)`. -/
theorem primepower_odd' (p r : ℕ) (hp : p.Prime) (hodd : Odd p) (hr : 1 ≤ r) :
    (p ^ r : ℤ) ∣ (a (p ^ r) + 1) := by
  have hp3 : 3 ≤ p := odd_prime_ge_three hp hodd
  haveI : NeZero (p ^ r) := ⟨pow_ne_zero r hp.pos.ne'⟩
  have hred := primepower_setup_reduction hp hr (N := p ^ r) rfl
  have hxnh := XNH_eq_blockSum hp hr (N := p ^ r) rfl
  have hbps := blockPermSum_eq_sum_blockPermWeight p (p ^ (r - 1))
  have hval := blockPermSum_dvd_sub_W1_pow p r hp hp3 hr
  have hw1 := blockWeight_one_eq p hp
  have hlte := lte_step p r hp hodd hr
  rw [hxnh, ← hbps] at hred
  rw [hw1] at hval
  push_cast at hred
  have heq : a (p ^ r) + 1 = (a (p ^ r) - blockPermSum p (Fin (p ^ (r - 1))))
      + (blockPermSum p (Fin (p ^ (r - 1))) - (2 * (p:ℤ) - 1) ^ (p ^ (r - 1)))
      + ((2 * (p:ℤ) - 1) ^ (p ^ (r - 1)) + 1) := by ring
  rw [heq]
  exact dvd_add (dvd_add hred hval) hlte

/-! ### Toward `primepower_two_large'`: the fixed-point-free involution count is odd

The `p = 2` case needs one genuinely new combinatorial ingredient with no counterpart in the
odd-prime proof: the number of *fixed-point-free involutions* of `Fin n` (permutations with
`support = univ` and every cycle of length exactly `2`) is odd, for every even `n`. This is
proved here via a "peel the partner of `0`" recursion: `allTwoFilter (m+2) ≃ (partner of 0 : one
of `m+1` choices) × allTwoFilter m`, giving `#(allTwoFilter (m+2)) = (m+1) * #(allTwoFilter m)`,
and hence by induction `#(allTwoFilter (2*j))` is a product of odd numbers `(2j-1)(2j-3)⋯1`. -/

/-- The set of fixed-point-free "all cycles length 2" permutations of `Fin n`. -/
def allTwoFilter (n : ℕ) : Finset (Equiv.Perm (Fin n)) :=
  Finset.univ.filter
    (fun τ : Equiv.Perm (Fin n) => τ.support = Finset.univ ∧ ∀ c ∈ τ.cycleType, c = 2)

/-- Cycle-type additivity across the `orbitAt`/`ρPerm` decomposition (the same identity proved
inline inside `permWeight_eq_mul` in `ProductCongruence.lean`, extracted here as a standalone
fact about `cycleType` alone, with no `permWeight`/weight-function involved). -/
theorem cycleType_add_of_orbitAt {α : Type*} [Fintype α] [DecidableEq α]
    {σ : Equiv.Perm α} {x0 : α} {S : Finset α} (hS : orbitAt σ x0 = S) :
    σ.cycleType = (σ.cycleOf x0).cycleType + (ρPerm hS).cycleType := by
  conv_lhs => rw [← cycleOf_mul_ofSubtype_ρPerm hS]
  rw [(disjoint_cycleOf_ofSubtype_ρPerm hS).cycleType_mul, Equiv.Perm.cycleType_ofSubtype]

/-- For `σ ∈ allTwoFilter (m+2)`, the cycle through `0` (which is genuine, since `0` is not
fixed) has support of size exactly `2`, since its length is a member of `σ.cycleType` and every
member of `σ.cycleType` equals `2`. -/
theorem card_orbitAt_eq_two {m : ℕ} {σ : Equiv.Perm (Fin (m + 2))}
    (hσ : σ ∈ allTwoFilter (m + 2)) :
    (orbitAt σ (0 : Fin (m + 2))).card = 2 := by
  unfold allTwoFilter at hσ
  rw [Finset.mem_filter] at hσ
  obtain ⟨-, hsupp, hall⟩ := hσ
  have h0mem : (0 : Fin (m + 2)) ∈ σ.support := by rw [hsupp]; exact Finset.mem_univ _
  have h0ne : σ (0 : Fin (m + 2)) ≠ 0 := Equiv.Perm.mem_support.mp h0mem
  set S := orbitAt σ (0 : Fin (m + 2)) with hSdef
  have hcycle := cycleType_add_of_orbitAt (hS := hSdef.symm)
  have hisCycle : (σ.cycleOf 0).IsCycle := Equiv.Perm.isCycle_cycleOf σ h0ne
  have hcycEq : (σ.cycleOf 0).cycleType = {(σ.cycleOf 0).support.card} := hisCycle.cycleType
  have hmemc : (σ.cycleOf 0).support.card ∈ σ.cycleType := by
    rw [hcycle, hcycEq]
    exact Multiset.mem_add.mpr (Or.inl (Multiset.mem_singleton_self _))
  have hval : (σ.cycleOf 0).support.card = 2 := hall _ hmemc
  have h0ne' : (σ.cycleOf 0) (0 : Fin (m + 2)) ≠ 0 := by
    rw [Equiv.Perm.cycleOf_apply_self]; exact h0ne
  have hSeq : S = (σ.cycleOf 0).support := by
    unfold orbitAt at hSdef
    rw [hSdef]
    exact Finset.insert_eq_self.mpr (Equiv.Perm.mem_support.mpr h0ne')
  rw [hSeq, hval]

/-- The cycle through `0` is exactly the swap of `0` and `σ 0` (a length-`2` cycle with support
`{0, σ 0}` is forced to be this swap, via `IsCycle.eq_swap_of_apply_apply_eq_self` combined with
`orderOf = 2`). -/
theorem cycleOf_eq_swap {m : ℕ} {σ : Equiv.Perm (Fin (m + 2))}
    (hσ : σ ∈ allTwoFilter (m + 2)) :
    σ.cycleOf 0 = Equiv.swap (0 : Fin (m + 2)) (σ 0) := by
  unfold allTwoFilter at hσ
  rw [Finset.mem_filter] at hσ
  obtain ⟨-, hsupp, hall⟩ := hσ
  have h0mem : (0 : Fin (m + 2)) ∈ σ.support := by rw [hsupp]; exact Finset.mem_univ _
  have h0ne : σ (0 : Fin (m + 2)) ≠ 0 := Equiv.Perm.mem_support.mp h0mem
  have hisCycle : (σ.cycleOf 0).IsCycle := Equiv.Perm.isCycle_cycleOf σ h0ne
  have hcard2 : (orbitAt σ (0 : Fin (m + 2))).card = 2 := by
    apply card_orbitAt_eq_two
    unfold allTwoFilter
    rw [Finset.mem_filter]
    exact ⟨Finset.mem_univ _, hsupp, hall⟩
  have hSeq : orbitAt σ (0 : Fin (m + 2)) = (σ.cycleOf 0).support := by
    unfold orbitAt
    have h0ne' : (σ.cycleOf 0) (0 : Fin (m + 2)) ≠ 0 := by
      rw [Equiv.Perm.cycleOf_apply_self]; exact h0ne
    exact Finset.insert_eq_self.mpr (Equiv.Perm.mem_support.mpr h0ne')
  have hval : (σ.cycleOf 0).support.card = 2 := by rw [← hSeq]; exact hcard2
  have hc0 : (σ.cycleOf 0) (0 : Fin (m + 2)) = σ 0 := Equiv.Perm.cycleOf_apply_self σ 0
  have hffx : (σ.cycleOf 0) ((σ.cycleOf 0) (0 : Fin (m + 2))) = 0 := by
    have horder : orderOf (σ.cycleOf 0) = 2 := by rw [hisCycle.orderOf, hval]
    have hsq : (σ.cycleOf 0) * (σ.cycleOf 0) = 1 := by
      have hp := pow_orderOf_eq_one (σ.cycleOf 0)
      rw [horder, pow_two] at hp
      exact hp
    have := congrArg (fun e : Equiv.Perm (Fin (m + 2)) => e (0 : Fin (m + 2))) hsq
    simpa [Equiv.Perm.mul_apply] using this
  have h0ne'' : (σ.cycleOf 0) (0 : Fin (m + 2)) ≠ 0 := by rw [hc0]; exact h0ne
  have := hisCycle.eq_swap_of_apply_apply_eq_self h0ne'' hffx
  rwa [hc0] at this

/-- `orbitAt σ 0 = {0, σ 0}`. -/
theorem orbitAt_eq_pair {m : ℕ} {σ : Equiv.Perm (Fin (m + 2))}
    (hσ : σ ∈ allTwoFilter (m + 2)) :
    orbitAt σ (0 : Fin (m + 2)) = {0, σ 0} := by
  unfold allTwoFilter at hσ
  rw [Finset.mem_filter] at hσ
  obtain ⟨-, hsupp, hall⟩ := hσ
  have hσ' : σ ∈ allTwoFilter (m + 2) := by
    unfold allTwoFilter; rw [Finset.mem_filter]; exact ⟨Finset.mem_univ _, hsupp, hall⟩
  have h0mem : (0 : Fin (m + 2)) ∈ σ.support := by rw [hsupp]; exact Finset.mem_univ _
  have h0ne : σ (0 : Fin (m + 2)) ≠ 0 := Equiv.Perm.mem_support.mp h0mem
  have h0ne' : (σ.cycleOf 0) (0 : Fin (m + 2)) ≠ 0 := by
    rw [Equiv.Perm.cycleOf_apply_self]; exact h0ne
  have hSeq : orbitAt σ (0 : Fin (m + 2)) = (σ.cycleOf 0).support :=
    Finset.insert_eq_self.mpr (Equiv.Perm.mem_support.mpr h0ne')
  rw [hSeq, cycleOf_eq_swap hσ', Equiv.Perm.support_swap h0ne.symm]

/-- `ρPerm` (the permutation induced on the complement of the cycle through `0`) inherits the
"all-2-cycle, no fixed points" property from `σ`. -/
theorem ρPerm_mem_of_allTwoFilter {m : ℕ} {S : Finset (Fin (m + 2))} {σ : Equiv.Perm (Fin (m + 2))}
    (hσm : σ ∈ allTwoFilter (m + 2)) (hS : orbitAt σ 0 = S) :
    (ρPerm hS).support = Finset.univ ∧ ∀ c ∈ (ρPerm hS).cycleType, c = 2 := by
  have hσm2 := hσm
  unfold allTwoFilter at hσm2
  rw [Finset.mem_filter] at hσm2
  obtain ⟨-, hsupp, hall⟩ := hσm2
  have h0mem : (0 : Fin (m + 2)) ∈ σ.support := by rw [hsupp]; exact Finset.mem_univ _
  have h0ne : σ (0 : Fin (m + 2)) ≠ 0 := Equiv.Perm.mem_support.mp h0mem
  have hcycOf : σ.cycleOf 0 = Equiv.swap (0 : Fin (m + 2)) (σ 0) := cycleOf_eq_swap hσm
  have hcycAdd := cycleType_add_of_orbitAt hS
  rw [hcycOf] at hcycAdd
  have hswapCT : (Equiv.swap (0 : Fin (m + 2)) (σ 0)).cycleType = {2} := by
    rw [(Equiv.Perm.isCycle_swap h0ne.symm).cycleType, Equiv.Perm.support_swap h0ne.symm]
    rw [Finset.card_pair_eq_two_iff.mpr h0ne.symm]
  rw [hswapCT] at hcycAdd
  have hScard : S.card = 2 := by rw [← hS]; exact card_orbitAt_eq_two hσm
  have hcardeq : Fintype.card (↥(Sᶜ : Finset (Fin (m + 2)))) = m := by
    rw [Fintype.card_coe, Finset.card_compl, Fintype.card_fin, hScard]
    omega
  refine ⟨?_, ?_⟩
  · have hsumEq : σ.cycleType.sum = 2 + (ρPerm hS).cycleType.sum := by
      have h := congrArg Multiset.sum hcycAdd
      rwa [Multiset.sum_add, Multiset.sum_singleton] at h
    have hsuppcard : σ.support.card = σ.cycleType.sum := (Equiv.Perm.sum_cycleType σ).symm
    have hfullcard : σ.support.card = m + 2 := by rw [hsupp]; exact Fintype.card_fin _
    have hρsum : (ρPerm hS).cycleType.sum = m := by omega
    have hρcard : (ρPerm hS).support.card = m := by
      rw [← Equiv.Perm.sum_cycleType]; exact hρsum
    exact Finset.eq_univ_of_card (ρPerm hS).support (by rw [hρcard, hcardeq])
  · intro c hc
    apply hall
    rw [hcycAdd]
    exact Multiset.mem_add.mpr (Or.inr hc)

/-- **The fiber-cardinality lemma**: for `S` with `0 ∈ S`, `S.card = 2`, the fiber
`{σ ∈ allTwoFilter (m+2) : orbitAt σ 0 = S}` is in bijection with `allTwoFilter m` (via
`σ ↦ e.permCongr (ρPerm hS)`, transporting the complement of `S` to `Fin m` by a fixed
cardinality equivalence `e`; the inverse direction reconstructs `σ` as `swap 0 k *
ofSubtype (e.symm.permCongr τ')`, where `k` is `S`'s unique element other than `0`). -/
theorem allTwoFilter_fiber_card {m : ℕ} {S : Finset (Fin (m + 2))}
    (h0S : (0 : Fin (m + 2)) ∈ S) (hS2 : S.card = 2) :
    (Finset.univ.filter
      (fun σ : Equiv.Perm (Fin (m + 2)) => σ ∈ allTwoFilter (m + 2) ∧ orbitAt σ 0 = S)).card
      = (allTwoFilter m).card := by
  classical
  obtain ⟨k, hk⟩ :=
    Finset.card_eq_one.mp (by rw [Finset.card_erase_of_mem h0S, hS2] : (S.erase 0).card = 1)
  have hkne : k ≠ 0 := (Finset.mem_erase.mp (hk ▸ Finset.mem_singleton_self k)).1
  have hSeq2 : S = {0, k} := by rw [← Finset.insert_erase h0S, hk]
  have hcardeq : Fintype.card (↥(Sᶜ : Finset (Fin (m + 2)))) = m := by
    rw [Fintype.card_coe, Finset.card_compl, Fintype.card_fin, hS2]
    omega
  set e : (↥(Sᶜ : Finset (Fin (m + 2)))) ≃ Fin m := Fintype.equivFinOfCardEq hcardeq with hedef
  have hjmem : ∀ τ' ∈ allTwoFilter m,
      Equiv.swap (0 : Fin (m + 2)) k * Equiv.Perm.ofSubtype (e.symm.permCongr τ') ∈
        Finset.univ.filter
          (fun σ : Equiv.Perm (Fin (m + 2)) => σ ∈ allTwoFilter (m + 2) ∧ orbitAt σ 0 = S) := by
    intro τ' hτ'
    unfold allTwoFilter at hτ'
    rw [Finset.mem_filter] at hτ'
    obtain ⟨hτ'univ, hτ'supp, hτ'all⟩ := hτ'
    set σ' : Equiv.Perm (Fin (m + 2)) :=
      Equiv.swap (0 : Fin (m + 2)) k * Equiv.Perm.ofSubtype (e.symm.permCongr τ') with hσ'def
    have hdisj : (Equiv.swap (0 : Fin (m + 2)) k).Disjoint
        (Equiv.Perm.ofSubtype (e.symm.permCongr τ') : Equiv.Perm (Fin (m + 2))) := by
      intro x
      by_cases hx : x ∈ S
      · right
        have hxc : x ∉ (Sᶜ : Finset (Fin (m + 2))) := by simp [hx]
        exact Equiv.Perm.ofSubtype_apply_of_not_mem _ hxc
      · left
        have hxns : x ∉ (Equiv.swap (0 : Fin (m + 2)) k).support := by
          rw [Equiv.Perm.support_swap hkne.symm, ← hSeq2]; exact hx
        exact Equiv.Perm.notMem_support.mp hxns
    have hofSubtype_card :
        (Equiv.Perm.ofSubtype (e.symm.permCongr τ') : Equiv.Perm (Fin (m + 2))).support.card
          = m := by
      rw [← Equiv.Perm.sum_cycleType, Equiv.Perm.cycleType_ofSubtype, cycleType_permCongr,
        Equiv.Perm.sum_cycleType, hτ'supp, Finset.card_univ, Fintype.card_fin]
    have hofSubtype_sub :
        (Equiv.Perm.ofSubtype (e.symm.permCongr τ') : Equiv.Perm (Fin (m + 2))).support ⊆ Sᶜ := by
      intro x hx
      rw [Equiv.Perm.mem_support] at hx
      by_contra hxS
      rw [Finset.mem_compl, not_not] at hxS
      exact hx (Equiv.Perm.ofSubtype_apply_of_not_mem _ (by simp [hxS]))
    have hScard : (Sᶜ : Finset (Fin (m + 2))).card = m := by
      rw [Finset.card_compl, Fintype.card_fin, hS2]; omega
    have hofSubtype_supp :
        (Equiv.Perm.ofSubtype (e.symm.permCongr τ') : Equiv.Perm (Fin (m + 2))).support = Sᶜ := by
      apply Finset.eq_of_subset_of_card_le hofSubtype_sub
      rw [hofSubtype_card, hScard]
    have hσ'supp : σ'.support = Finset.univ := by
      rw [hσ'def, hdisj.support_mul, Equiv.Perm.support_swap hkne.symm, ← hSeq2,
        hofSubtype_supp, Finset.union_compl]
    have hσ'cyc : ∀ c ∈ σ'.cycleType, c = 2 := by
      intro c hc
      rw [hσ'def, hdisj.cycleType_mul, Equiv.Perm.cycleType_ofSubtype, cycleType_permCongr] at hc
      rw [(Equiv.Perm.isCycle_swap hkne.symm).cycleType, Equiv.Perm.support_swap hkne.symm,
        Finset.card_pair_eq_two_iff.mpr hkne.symm] at hc
      rcases Multiset.mem_add.mp hc with h2 | hτc
      · exact Multiset.mem_singleton.mp h2
      · exact hτ'all c hτc
    have hσ'mem : σ' ∈ allTwoFilter (m + 2) := by
      unfold allTwoFilter; rw [Finset.mem_filter]; exact ⟨Finset.mem_univ _, hσ'supp, hσ'cyc⟩
    have hσ'0 : σ' 0 = k := by
      have h0notSc : (0 : Fin (m + 2)) ∉ (Sᶜ : Finset (Fin (m + 2))) := by simp [h0S]
      rw [hσ'def, Equiv.Perm.mul_apply, Equiv.Perm.ofSubtype_apply_of_not_mem _ h0notSc,
        Equiv.swap_apply_left]
    rw [Finset.mem_filter]
    refine ⟨Finset.mem_univ _, hσ'mem, ?_⟩
    rw [orbitAt_eq_pair hσ'mem, hσ'0, hSeq2]
  refine Finset.card_bij'
    (i := fun (σ : Equiv.Perm (Fin (m + 2)))
        (hσ : σ ∈ Finset.univ.filter
          (fun σ : Equiv.Perm (Fin (m + 2)) => σ ∈ allTwoFilter (m + 2) ∧ orbitAt σ 0 = S)) =>
      e.permCongr (ρPerm (Finset.mem_filter.mp hσ).2.2))
    (j := fun (τ' : Equiv.Perm (Fin m)) (_ : τ' ∈ allTwoFilter m) =>
      Equiv.swap (0 : Fin (m + 2)) k * Equiv.Perm.ofSubtype (e.symm.permCongr τ'))
    ?hi ?hj ?left_inv ?right_inv
  case hi =>
    intro σ hσ
    obtain ⟨-, hσm, hSeq⟩ := Finset.mem_filter.mp hσ
    obtain ⟨hρsupp, hρall⟩ := ρPerm_mem_of_allTwoFilter hσm hSeq
    unfold allTwoFilter
    rw [Finset.mem_filter]
    refine ⟨Finset.mem_univ _, ?_, ?_⟩
    · have hcardEq : (e.permCongr (ρPerm hSeq)).support.card = (ρPerm hSeq).support.card := by
        rw [← Equiv.Perm.sum_cycleType, ← Equiv.Perm.sum_cycleType, cycleType_permCongr]
      rw [hρsupp, Finset.card_univ, Fintype.card_coe] at hcardEq
      apply Finset.eq_univ_of_card
      rw [hcardEq, Fintype.card_fin, ← Fintype.card_coe, hcardeq]
    · intro c hc
      apply hρall
      rwa [cycleType_permCongr] at hc
  case hj => exact hjmem
  case left_inv =>
    intro σ ha
    obtain ⟨-, hσm, hSeq⟩ := Finset.mem_filter.mp ha
    have hcancel : ∀ X : Equiv.Perm (↥(Sᶜ : Finset (Fin (m + 2)))),
        e.symm.permCongr (e.permCongr X) = X := by
      intro X
      rw [← Equiv.permCongr_symm]
      exact Equiv.symm_apply_apply e.permCongr X
    have h0mem : (0 : Fin (m + 2)) ∈ σ.support := by
      have hσm2 := hσm
      unfold allTwoFilter at hσm2; rw [Finset.mem_filter] at hσm2
      rw [hσm2.2.1]; exact Finset.mem_univ _
    have h0ne : σ (0 : Fin (m + 2)) ≠ 0 := Equiv.Perm.mem_support.mp h0mem
    have hσ0eq : σ 0 = k := by
      have hpair := orbitAt_eq_pair hσm
      rw [hSeq, hSeq2] at hpair
      have hmemσ0 : σ 0 ∈ ({0, σ 0} : Finset (Fin (m + 2))) :=
        Finset.mem_insert_of_mem (Finset.mem_singleton_self _)
      rw [← hpair] at hmemσ0
      rcases Finset.mem_insert.mp hmemσ0 with h | h
      · exact absurd h h0ne
      · exact Finset.mem_singleton.mp h
    have step1 : σ.cycleOf 0 * Equiv.Perm.ofSubtype (ρPerm hSeq) = σ :=
      cycleOf_mul_ofSubtype_ρPerm hSeq
    have step2 : σ.cycleOf 0 = Equiv.swap (0 : Fin (m + 2)) (σ 0) := cycleOf_eq_swap hσm
    rw [step2] at step1
    have hrecon0 : σ = Equiv.swap (0 : Fin (m + 2)) (σ 0) * Equiv.Perm.ofSubtype (ρPerm hSeq) :=
      step1.symm
    have step3 : Equiv.swap (0 : Fin (m + 2)) (σ 0) = Equiv.swap (0 : Fin (m + 2)) k := by
      rw [hσ0eq]
    have hrecon : σ = Equiv.swap (0 : Fin (m + 2)) k * Equiv.Perm.ofSubtype (ρPerm hSeq) := by
      rw [← step3]; exact hrecon0
    show Equiv.swap (0 : Fin (m + 2)) k *
        Equiv.Perm.ofSubtype (e.symm.permCongr (e.permCongr (ρPerm hSeq))) = σ
    rw [hcancel, ← hrecon]
  case right_inv =>
    intro τ' ha
    have hswapCycle : Equiv.swap (0 : Fin (m + 2)) k ∈ CycleFinset (0 : Fin (m + 2)) S := by
      rw [mem_CycleFinset_of_two_le h0S (by rw [hS2])]
      exact ⟨Equiv.Perm.isCycle_swap hkne.symm, by
        rw [Equiv.Perm.support_swap hkne.symm, hSeq2]⟩
    have hmemS := Finset.mem_filter.mp (hjmem τ' ha)
    have hS' : orbitAt (Equiv.swap (0 : Fin (m + 2)) k *
        Equiv.Perm.ofSubtype (e.symm.permCongr τ')) (0 : Fin (m + 2)) = S := hmemS.2.2
    have hρeq : ρPerm hS' = e.symm.permCongr τ' :=
      ρPerm_mul_ofSubtype hswapCycle (e.symm.permCongr τ') hS'
    show e.permCongr (ρPerm hS') = τ'
    rw [hρeq]
    exact Equiv.apply_symm_apply e.permCongr τ'

theorem allTwoFilter_zero_card : (allTwoFilter 0).card = 1 := by
  have hsub : ∀ τ : Equiv.Perm (Fin 0), τ = 1 := fun τ => Equiv.ext (fun x => Fin.elim0 x)
  have heq : allTwoFilter 0 = {1} := by
    unfold allTwoFilter
    ext τ
    simp only [Finset.mem_filter, Finset.mem_univ, true_and, Finset.mem_singleton]
    constructor
    · intro _; exact hsub τ
    · intro h
      rw [h]
      refine ⟨?_, ?_⟩
      · apply Finset.eq_univ_of_forall; intro x; exact Fin.elim0 x
      · intro c hc; simp [Equiv.Perm.cycleType_one] at hc
  rw [heq]; exact Finset.card_singleton 1

/-- **The peeling recursion**: `#(allTwoFilter (m+2)) = (m+1) * #(allTwoFilter m)`, via grouping
by `S := orbitAt σ 0` (always `0 ∈ S`, `S.card = 2`, `m+1` such `S` by `card_filter_zero_mem_card_eq`)
and `allTwoFilter_fiber_card` for each fiber. -/
theorem allTwoFilter_succ_succ_card (m : ℕ) :
    (allTwoFilter (m + 2)).card = (m + 1) * (allTwoFilter m).card := by
  classical
  have hmaps : ∀ σ ∈ allTwoFilter (m + 2),
      orbitAt σ (0 : Fin (m + 2)) ∈
        Finset.univ.filter (fun S : Finset (Fin (m + 2)) => (0 : Fin (m + 2)) ∈ S ∧ S.card = 2) := by
    intro σ hσ
    rw [Finset.mem_filter]
    exact ⟨Finset.mem_univ _, x0_mem_orbitAt σ 0, card_orbitAt_eq_two hσ⟩
  rw [Finset.card_eq_sum_card_fiberwise hmaps]
  have hfiber_eq : ∀ S ∈ Finset.univ.filter
      (fun S : Finset (Fin (m + 2)) => (0 : Fin (m + 2)) ∈ S ∧ S.card = 2),
      ((allTwoFilter (m + 2)).filter (fun σ => orbitAt σ (0 : Fin (m + 2)) = S)).card
        = (allTwoFilter m).card := by
    intro S hS
    rw [Finset.mem_filter] at hS
    have heqSet : (allTwoFilter (m + 2)).filter (fun σ => orbitAt σ (0 : Fin (m + 2)) = S)
        = Finset.univ.filter
          (fun σ : Equiv.Perm (Fin (m + 2)) => σ ∈ allTwoFilter (m + 2) ∧ orbitAt σ 0 = S) := by
      unfold allTwoFilter
      rw [Finset.filter_filter]
      ext σ; simp [and_comm]
    rw [heqSet]
    exact allTwoFilter_fiber_card hS.2.1 hS.2.2
  rw [Finset.sum_congr rfl hfiber_eq, Finset.sum_const]
  rw [card_filter_zero_mem_card_eq (m + 1) 2 (by omega)]
  norm_num

/-- **The parity result**: the count of fixed-point-free involutions of `Fin (2j)` is odd, by
induction on `j` using `allTwoFilter_succ_succ_card` (`#(allTwoFilter (2(j+1))) = (2j+1) *
#(allTwoFilter (2j))`, a product of two odd numbers). -/
theorem allTwoFilter_double_card_odd (j : ℕ) : Odd (allTwoFilter (2 * j)).card := by
  induction j with
  | zero => rw [Nat.mul_zero, allTwoFilter_zero_card]; exact odd_one
  | succ j ih =>
    have heq : 2 * (j + 1) = (2 * j) + 2 := by ring
    rw [heq, allTwoFilter_succ_succ_card]
    have h1 : Odd (2 * j + 1) := ⟨j, by ring⟩
    exact h1.mul ih

/-! ### Toward `primepower_two_large'`: the "has-a-cycle-`≥3`" elimination and the `j = 1, 2`
cancellation

With the involution-parity fact in hand, the rest closes without needing the paper's digit-sum
identity: split `derangementBlockSum 2 L` into a "some cycle `≥ 3`" part (divisible by `2^r` for
*every* `L`, via an elementary refinement of the `D_L` valuation bound that needs no `p`-oddness)
and an "all cycles `= 2`" part (`L = 2j`, valuation exactly `r-1` at `j = 1, 2`, individually
divisible by `2^r` for `j ≥ 3`; the `j=1,2` terms are handled together via "odd + odd = even"). -/

theorem two_mul_le_two_pow (v : ℕ) : 2 * v ≤ 2 ^ v := by
  induction v with
  | zero => simp
  | succ v ih =>
    have h1 : (2 : ℕ) ^ (v + 1) = 2 * 2 ^ v := by ring
    rw [h1]
    rcases Nat.eq_zero_or_pos v with hv | hv
    · subst hv; simp
    · omega

theorem two_mul_padicValNat_le (L : ℕ) (hL : 0 < L) : 2 * padicValNat 2 L ≤ L := by
  have hle : 2 ^ (padicValNat 2 L) ≤ L := Nat.le_of_dvd hL pow_padicValNat_dvd
  have hpow := two_mul_le_two_pow (padicValNat 2 L)
  omega

theorem two_mul_card_add_one_le_sum_of_ge3 {s : Multiset ℕ} (hs : ∀ c ∈ s, 2 ≤ c)
    (h3 : ∃ c ∈ s, 3 ≤ c) : 2 * s.card + 1 ≤ s.sum := by
  induction s using Multiset.induction with
  | empty => obtain ⟨c, hc, -⟩ := h3; simp at hc
  | cons c s ih =>
    have hc2 : 2 ≤ c := hs c (Multiset.mem_cons_self c s)
    have hs' : ∀ x ∈ s, 2 ≤ x := fun x hx => hs x (Multiset.mem_cons_of_mem hx)
    have hsum' : 2 * s.card ≤ s.sum := two_mul_card_le_sum_of_two_le hs'
    by_cases hc3 : 3 ≤ c
    · simp only [Multiset.card_cons, Multiset.sum_cons]
      omega
    · have hc2' : c = 2 := by omega
      have h3' : ∃ x ∈ s, 3 ≤ x := by
        obtain ⟨x, hx, hx3⟩ := h3
        rcases Multiset.mem_cons.mp hx with rfl | hx
        · omega
        · exact ⟨x, hx, hx3⟩
      have := ih hs' h3'
      simp only [Multiset.card_cons, Multiset.sum_cons]
      omega

open scoped Classical in
noncomputable def derangementBlockSumGe3 (p L : ℕ) : ℤ :=
  ∑ τ ∈ Finset.univ.filter
    (fun τ : Equiv.Perm (Fin L) => τ.support = Finset.univ ∧ ∃ c ∈ τ.cycleType, 3 ≤ c),
    (τ.cycleType.map (blockWeight p)).prod

open scoped Classical in
noncomputable def derangementBlockSumAll2 (p L : ℕ) : ℤ :=
  ∑ τ ∈ Finset.univ.filter
    (fun τ : Equiv.Perm (Fin L) => τ.support = Finset.univ ∧ ∀ c ∈ τ.cycleType, c = 2),
    (τ.cycleType.map (blockWeight p)).prod

theorem derangementBlockSum_split (p L : ℕ) :
    derangementBlockSum p L = derangementBlockSumGe3 p L + derangementBlockSumAll2 p L := by
  classical
  unfold derangementBlockSum derangementBlockSumGe3 derangementBlockSumAll2
  have heqfilter : Finset.univ.filter (fun τ : Equiv.Perm (Fin L) => τ.support = Finset.univ)
      = (Finset.univ.filter
          (fun τ : Equiv.Perm (Fin L) => τ.support = Finset.univ ∧ ∀ c ∈ τ.cycleType, c = 2)) ∪
        (Finset.univ.filter
          (fun τ : Equiv.Perm (Fin L) => τ.support = Finset.univ ∧ ∃ c ∈ τ.cycleType, 3 ≤ c)) := by
    ext τ
    simp only [Finset.mem_filter, Finset.mem_univ, true_and, Finset.mem_union]
    constructor
    · intro hsupp
      by_cases hall : ∀ c ∈ τ.cycleType, c = 2
      · exact Or.inl ⟨hsupp, hall⟩
      · refine Or.inr ⟨hsupp, ?_⟩
        push Not at hall
        obtain ⟨c, hc, hcne⟩ := hall
        exact ⟨c, hc, by
          have := Equiv.Perm.two_le_of_mem_cycleType hc
          omega⟩
    · rintro (⟨h, -⟩ | ⟨h, -⟩) <;> exact h
  have hdisj : Disjoint
      (Finset.univ.filter
        (fun τ : Equiv.Perm (Fin L) => τ.support = Finset.univ ∧ ∀ c ∈ τ.cycleType, c = 2))
      (Finset.univ.filter
        (fun τ : Equiv.Perm (Fin L) => τ.support = Finset.univ ∧ ∃ c ∈ τ.cycleType, 3 ≤ c)) := by
    rw [Finset.disjoint_left]
    intro τ h1 h2
    simp only [Finset.mem_filter, Finset.mem_univ, true_and] at h1 h2
    obtain ⟨-, hall⟩ := h1
    obtain ⟨-, c, hc, hc3⟩ := h2
    have := hall c hc
    omega
  rw [heqfilter, Finset.sum_union hdisj]
  ring

theorem derangementBlockSumGe3_dvd_two (L : ℕ) (hL : 0 < L) :
    (2 : ℤ) ^ (padicValNat 2 L + 1) ∣ derangementBlockSumGe3 2 L := by
  unfold derangementBlockSumGe3
  apply Finset.dvd_sum
  intro τ hτ
  simp only [Finset.mem_filter, Finset.mem_univ, true_and] at hτ
  obtain ⟨hsupp, hge3⟩ := hτ
  have hsum : τ.cycleType.sum = L := by
    rw [Equiv.Perm.sum_cycleType, hsupp, Finset.card_univ, Fintype.card_fin]
  have hge2 : ∀ c ∈ τ.cycleType, 2 ≤ c := fun c hc => Equiv.Perm.two_le_of_mem_cycleType hc
  have hcard_bound : 2 * τ.cycleType.card + 1 ≤ τ.cycleType.sum :=
    two_mul_card_add_one_le_sum_of_ge3 hge2 hge3
  have hval2 : 2 * padicValNat 2 L ≤ L := two_mul_padicValNat_le L hL
  have hdvd := dvd_prod_map_blockWeight 2 τ.cycleType hge2
  have hexp : padicValNat 2 L + 1 ≤ τ.cycleType.sum - τ.cycleType.card := by omega
  have hpow_dvd : (2:ℤ) ^ (padicValNat 2 L + 1) ∣ (2:ℤ) ^ (τ.cycleType.sum - τ.cycleType.card) :=
    pow_dvd_pow _ hexp
  exact hpow_dvd.trans hdvd

theorem derangementBlockSumAll2_eq (p j : ℕ) :
    derangementBlockSumAll2 p (2 * j) = (allTwoFilter (2 * j)).card * (blockWeight p 2) ^ j := by
  classical
  unfold derangementBlockSumAll2 allTwoFilter
  have hconst : ∀ τ ∈ Finset.univ.filter
      (fun τ : Equiv.Perm (Fin (2 * j)) => τ.support = Finset.univ ∧ ∀ c ∈ τ.cycleType, c = 2),
      (τ.cycleType.map (blockWeight p)).prod = (blockWeight p 2) ^ j := by
    intro τ hτ
    simp only [Finset.mem_filter, Finset.mem_univ, true_and] at hτ
    obtain ⟨hsupp, hall⟩ := hτ
    have hsum : τ.cycleType.sum = 2 * j := by
      rw [Equiv.Perm.sum_cycleType, hsupp, Finset.card_univ, Fintype.card_fin]
    have hcard : τ.cycleType.card = j := by
      have hsum2 : τ.cycleType.sum = 2 * τ.cycleType.card := by
        conv_lhs => rw [← Multiset.map_id τ.cycleType]
        have : τ.cycleType.map id = τ.cycleType.map (fun _ => (2 : ℕ)) := by
          apply Multiset.map_congr rfl
          intro c hc; simpa using hall c hc
        rw [this, Multiset.map_const', Multiset.sum_replicate, smul_eq_mul, mul_comm]
      omega
    have hrepl : τ.cycleType = Multiset.replicate j 2 := Multiset.eq_replicate.mpr ⟨hcard, hall⟩
    have heq : τ.cycleType.map (blockWeight p) = Multiset.replicate j (blockWeight p 2) := by
      rw [hrepl, Multiset.map_replicate]
    rw [heq, Multiset.prod_replicate]
  rw [Finset.sum_congr rfl hconst, Finset.sum_const, nsmul_eq_mul]

theorem derangementBlockSumAll2_odd_eq_zero (p L : ℕ) (hL : Odd L) :
    derangementBlockSumAll2 p L = 0 := by
  classical
  unfold derangementBlockSumAll2
  have hempty : Finset.univ.filter
      (fun τ : Equiv.Perm (Fin L) => τ.support = Finset.univ ∧ ∀ c ∈ τ.cycleType, c = 2) = ∅ := by
    apply Finset.filter_false_of_mem
    rintro τ - ⟨hsupp, hall⟩
    have hsum : τ.cycleType.sum = L := by
      rw [Equiv.Perm.sum_cycleType, hsupp, Finset.card_univ, Fintype.card_fin]
    have hsum2 : τ.cycleType.sum = 2 * τ.cycleType.card := by
      conv_lhs => rw [← Multiset.map_id τ.cycleType]
      have heqm : τ.cycleType.map id = τ.cycleType.map (fun _ => (2 : ℕ)) := by
        apply Multiset.map_congr rfl
        intro c hc; simpa using hall c hc
      rw [heqm, Multiset.map_const', Multiset.sum_replicate, smul_eq_mul, mul_comm]
    obtain ⟨k, hk⟩ := hL
    omega
  rw [hempty]
  simp

theorem numDivisors_four_eq : numDivisors 4 = 3 := by decide

theorem blockWeight_two_eq : blockWeight 2 2 = 14 := by
  unfold blockWeight
  have h2 : numDivisors 2 = 2 := numDivisors_prime (by norm_num)
  have h4 : numDivisors (2 * 2) = 3 := numDivisors_four_eq
  rw [h2, h4]
  norm_num

/-- The "ge3" part contributes valuation `≥ r` for every `L`, `2 ≤ L ≤ M`, generically. -/
theorem term_ge3_dvd_two_pow (r L : ℕ) (hr : 1 ≤ r) (hL0 : L ≠ 0) (hLM : L ≤ 2 ^ (r - 1)) :
    (2 : ℤ) ^ r ∣ ((2 ^ (r - 1)).choose L : ℤ) * (blockWeight 2 1) ^ (2 ^ (r - 1) - L) *
      derangementBlockSumGe3 2 L := by
  have h1 := choose_prime_pow_dvd 2 r L Nat.prime_two hL0 hLM
  have h2 := derangementBlockSumGe3_dvd_two L (by omega)
  have hvle : padicValNat 2 L ≤ r - 1 := by
    have hple : 2 ^ (padicValNat 2 L) ≤ L := Nat.le_of_dvd (by omega) pow_padicValNat_dvd
    have hple2 : 2 ^ (padicValNat 2 L) ≤ 2 ^ (r - 1) := le_trans hple hLM
    exact (Nat.pow_le_pow_iff_right (by norm_num)).mp hple2
  have hexp : (r - 1 - padicValNat 2 L) + (padicValNat 2 L + 1) = r := by omega
  have hdvd12 : (2 : ℤ) ^ r ∣ ((2 ^ (r - 1)).choose L : ℤ) * derangementBlockSumGe3 2 L := by
    have hpoweq : (2 : ℤ) ^ r
        = (2 : ℤ) ^ (r - 1 - padicValNat 2 L) * (2 : ℤ) ^ (padicValNat 2 L + 1) := by
      rw [← pow_add, hexp]
    rw [hpoweq]
    exact mul_dvd_mul h1 h2
  have h3 : ((2 ^ (r - 1)).choose L : ℤ) * (blockWeight 2 1) ^ (2 ^ (r - 1) - L) *
      derangementBlockSumGe3 2 L
      = ((2 ^ (r - 1)).choose L : ℤ) * derangementBlockSumGe3 2 L *
          (blockWeight 2 1) ^ (2 ^ (r - 1) - L) := by ring
  rw [h3]
  exact hdvd12.mul_right _

/-- The "all2" part contributes valuation `≥ r` for `L = 2j`, `j ≥ 3`. -/
theorem term_all2_dvd_two_pow_of_j_ge3 (r j : ℕ) (hr : 1 ≤ r) (hj3 : 3 ≤ j)
    (hLM : 2 * j ≤ 2 ^ (r - 1)) :
    (2 : ℤ) ^ r ∣ ((2 ^ (r - 1)).choose (2 * j) : ℤ) * (blockWeight 2 1) ^ (2 ^ (r - 1) - 2 * j) *
      derangementBlockSumAll2 2 (2 * j) := by
  have h1 := choose_prime_pow_dvd 2 r (2 * j) Nat.prime_two (by omega) hLM
  rw [derangementBlockSumAll2_eq, blockWeight_two_eq]
  have hvle : padicValNat 2 (2 * j) ≤ r - 1 := by
    have hple : 2 ^ (padicValNat 2 (2 * j)) ≤ 2 * j := Nat.le_of_dvd (by omega) pow_padicValNat_dvd
    have hple2 : 2 ^ (padicValNat 2 (2 * j)) ≤ 2 ^ (r - 1) := le_trans hple hLM
    exact (Nat.pow_le_pow_iff_right (by norm_num)).mp hple2
  haveI : Fact (Nat.Prime 2) := ⟨Nat.prime_two⟩
  have hv2j : padicValNat 2 (2 * j) = padicValNat 2 j + 1 := by
    rw [padicValNat.mul (by norm_num) (by omega), padicValNat_self, add_comm]
  have hj_v2 : padicValNat 2 j ≤ j - 2 := by
    have := two_mul_padicValNat_le j (by omega)
    omega
  have h14 : (14 : ℤ) ^ j = 2 ^ j * 7 ^ j := by
    rw [show (14 : ℤ) = 2 * 7 by norm_num, mul_pow]
  have hcount_dvd : (2 : ℤ) ^ j ∣ ((allTwoFilter (2 * j)).card : ℤ) * (14 : ℤ) ^ j :=
    ⟨((allTwoFilter (2 * j)).card : ℤ) * 7 ^ j, by rw [h14]; ring⟩
  have hexp_ge : r ≤ (r - 1 - padicValNat 2 (2 * j)) + j := by
    rw [hv2j]; omega
  have hpoweq : (2 : ℤ) ^ ((r - 1 - padicValNat 2 (2 * j)) + j)
      = (2 : ℤ) ^ (r - 1 - padicValNat 2 (2 * j)) * (2 : ℤ) ^ j := pow_add 2 _ _
  have hdvd12 : (2 : ℤ) ^ ((r - 1 - padicValNat 2 (2 * j)) + j)
      ∣ ((2 ^ (r - 1)).choose (2 * j) : ℤ) *
        (((allTwoFilter (2 * j)).card : ℤ) * (14 : ℤ) ^ j) := by
    rw [hpoweq]; exact mul_dvd_mul h1 hcount_dvd
  have hdvd12' : (2 : ℤ) ^ r ∣ ((2 ^ (r - 1)).choose (2 * j) : ℤ) *
      (((allTwoFilter (2 * j)).card : ℤ) * (14 : ℤ) ^ j) :=
    (pow_dvd_pow 2 hexp_ge).trans hdvd12
  have h3 : ((2 ^ (r - 1)).choose (2 * j) : ℤ) * (blockWeight 2 1) ^ (2 ^ (r - 1) - 2 * j) *
      (((allTwoFilter (2 * j)).card : ℤ) * (14 : ℤ) ^ j)
      = ((2 ^ (r - 1)).choose (2 * j) : ℤ) * (((allTwoFilter (2 * j)).card : ℤ) * (14 : ℤ) ^ j) *
          (blockWeight 2 1) ^ (2 ^ (r - 1) - 2 * j) := by ring
  rw [h3]
  exact hdvd12'.mul_right _

/-- The exact odd cofactor of `M.choose L` at its own `2`-adic valuation, via `ordProj`/`ordCompl`
(`Nat.not_dvd_ordCompl` gives the cofactor's coprimality to `2`). -/
theorem choose_odd_cofactor (r L : ℕ) (hL0 : L ≠ 0) (hLM : L ≤ 2 ^ (r - 1)) :
    ∃ q : ℕ, Odd q ∧ (2 ^ (r - 1)).choose L = 2 ^ (r - 1 - padicValNat 2 L) * q := by
  set n := (2 ^ (r - 1)).choose L with hndef
  have hn0 : n ≠ 0 := (Nat.choose_pos hLM).ne'
  have hfact := Nat.factorization_choose_prime_pow Nat.prime_two hLM hL0
  simp only [Nat.factorization_def _ Nat.prime_two] at hfact
  refine ⟨ordCompl[2] n, ?_, ?_⟩
  · rw [← Nat.not_even_iff_odd, even_iff_two_dvd]
    exact Nat.not_dvd_ordCompl Nat.prime_two hn0
  · have hself := Nat.ordProj_mul_ordCompl_eq_self n 2
    have hordProj : ordProj[2] n = 2 ^ (r - 1 - padicValNat 2 L) := by
      show (2 : ℕ) ^ n.factorization 2 = 2 ^ (r - 1 - padicValNat 2 L)
      rw [Nat.factorization_def _ Nat.prime_two, hfact]
    rw [← hordProj]
    exact hself.symm

theorem padicValNat_two_two : padicValNat 2 2 = 1 := by
  haveI : Fact (Nat.Prime 2) := ⟨Nat.prime_two⟩
  exact padicValNat_self

theorem padicValNat_two_four : padicValNat 2 4 = 2 := by
  haveI : Fact (Nat.Prime 2) := ⟨Nat.prime_two⟩
  have : (4 : ℕ) = 2 * 2 := by norm_num
  rw [this, padicValNat.mul (by norm_num) (by norm_num), padicValNat_self]

/-- The `L = 2` (`j = 1`) term equals `2^(r-1)` times an odd number. -/
theorem term_all2_two_eq (r : ℕ) (hr : 3 ≤ r) :
    ∃ u : ℤ, Odd u ∧
      ((2 ^ (r - 1)).choose 2 : ℤ) * (blockWeight 2 1) ^ (2 ^ (r - 1) - 2) *
          derangementBlockSumAll2 2 2
        = 2 ^ (r - 1) * u := by
  have hLM2 : (2 : ℕ) ≤ 2 ^ (r - 1) := by
    calc (2 : ℕ) = 2 ^ 1 := by norm_num
    _ ≤ 2 ^ (r - 1) := Nat.pow_le_pow_right (by norm_num) (by omega)
  obtain ⟨q1, hq1odd, hq1eq⟩ := choose_odd_cofactor r 2 (by norm_num) hLM2
  rw [padicValNat_two_two] at hq1eq
  have hcount1 : Odd (allTwoFilter 2).card := by
    have := allTwoFilter_double_card_odd 1
    norm_num at this
    exact this
  have hW1 : blockWeight 2 1 = 3 := by
    have := blockWeight_one_eq 2 Nat.prime_two
    norm_num at this
    exact this
  have hall2 : derangementBlockSumAll2 2 2 = (allTwoFilter 2).card * 14 := by
    have heq := derangementBlockSumAll2_eq 2 1
    norm_num at heq
    rw [heq, blockWeight_two_eq]
  refine ⟨(7 : ℤ) * (q1 : ℤ) * (3 : ℤ) ^ (2 ^ (r - 1) - 2) * ((allTwoFilter 2).card : ℤ), ?_, ?_⟩
  · have h7 : Odd (7 : ℤ) := by decide
    have hq1 : Odd (q1 : ℤ) := by exact_mod_cast hq1odd
    have h3pow : Odd ((3 : ℤ) ^ (2 ^ (r - 1) - 2)) := by
      apply Odd.pow
      decide
    have hcount1' : Odd ((allTwoFilter 2).card : ℤ) := by exact_mod_cast hcount1
    exact ((h7.mul hq1).mul h3pow).mul hcount1'
  · rw [hall2, hW1]
    have hq1eq' : ((2 ^ (r - 1)).choose 2 : ℤ) = 2 ^ (r - 2) * (q1 : ℤ) := by
      exact_mod_cast hq1eq
    rw [hq1eq']
    have hexp : r - 2 + 1 = r - 1 := by omega
    push_cast
    rw [show (14 : ℤ) = 2 * 7 by norm_num]
    rw [← hexp, pow_succ]
    ring

/-- The `L = 4` (`j = 2`) term equals `2^(r-1)` times an odd number. -/
theorem term_all2_four_eq (r : ℕ) (hr : 3 ≤ r) :
    ∃ u : ℤ, Odd u ∧
      ((2 ^ (r - 1)).choose 4 : ℤ) * (blockWeight 2 1) ^ (2 ^ (r - 1) - 4) *
          derangementBlockSumAll2 2 4
        = 2 ^ (r - 1) * u := by
  have hLM4 : (4 : ℕ) ≤ 2 ^ (r - 1) := by
    calc (4 : ℕ) = 2 ^ 2 := by norm_num
    _ ≤ 2 ^ (r - 1) := Nat.pow_le_pow_right (by norm_num) (by omega)
  obtain ⟨q2, hq2odd, hq2eq⟩ := choose_odd_cofactor r 4 (by norm_num) hLM4
  rw [padicValNat_two_four] at hq2eq
  have hcount2 : Odd (allTwoFilter 4).card := by
    have := allTwoFilter_double_card_odd 2
    norm_num at this
    exact this
  have hW1 : blockWeight 2 1 = 3 := by
    have := blockWeight_one_eq 2 Nat.prime_two
    norm_num at this
    exact this
  have hall4 : derangementBlockSumAll2 2 4 = (allTwoFilter 4).card * 196 := by
    have heq := derangementBlockSumAll2_eq 2 2
    norm_num at heq
    rw [heq, blockWeight_two_eq]
    norm_num
  refine ⟨(49 : ℤ) * (q2 : ℤ) * (3 : ℤ) ^ (2 ^ (r - 1) - 4) * ((allTwoFilter 4).card : ℤ), ?_, ?_⟩
  · have h49 : Odd (49 : ℤ) := by decide
    have hq2 : Odd (q2 : ℤ) := by exact_mod_cast hq2odd
    have h3pow : Odd ((3 : ℤ) ^ (2 ^ (r - 1) - 4)) := by
      apply Odd.pow
      decide
    have hcount2' : Odd ((allTwoFilter 4).card : ℤ) := by exact_mod_cast hcount2
    exact ((h49.mul hq2).mul h3pow).mul hcount2'
  · rw [hall4, hW1]
    have hq2eq' : ((2 ^ (r - 1)).choose 4 : ℤ) = 2 ^ (r - 3) * (q2 : ℤ) := by
      exact_mod_cast hq2eq
    rw [hq2eq']
    have hexp : r - 3 + 2 = r - 1 := by omega
    push_cast
    rw [show (196 : ℤ) = 2 ^ 2 * 49 by norm_num]
    rw [← hexp, pow_add]
    ring

/-- The `j = 1` and `j = 2` terms, individually only divisible by `2^(r-1)`, sum to a multiple of
`2^r` via "odd + odd = even". -/
theorem term_all2_pair_dvd (r : ℕ) (hr : 3 ≤ r) :
    (2 : ℤ) ^ r ∣
      (((2 ^ (r - 1)).choose 2 : ℤ) * (blockWeight 2 1) ^ (2 ^ (r - 1) - 2) *
          derangementBlockSumAll2 2 2)
      + (((2 ^ (r - 1)).choose 4 : ℤ) * (blockWeight 2 1) ^ (2 ^ (r - 1) - 4) *
          derangementBlockSumAll2 2 4) := by
  obtain ⟨u1, hu1odd, hu1eq⟩ := term_all2_two_eq r hr
  obtain ⟨u2, hu2odd, hu2eq⟩ := term_all2_four_eq r hr
  rw [hu1eq, hu2eq, ← mul_add]
  have heven : Even (u1 + u2) := hu1odd.add_odd hu2odd
  obtain ⟨v, hv⟩ := heven
  rw [hv]
  have : (2 : ℤ) ^ (r - 1) * (v + v) = 2 ^ r * v := by
    have hexp : r - 1 + 1 = r := by omega
    conv_rhs => rw [← hexp, pow_succ]
    ring
  rw [this]
  exact Dvd.intro v rfl

/-- **The full `p = 2` valuation congruence**, the analogue of `blockPermSum_dvd_sub_W1_pow` for
`p = 2`: assembled from the `L = 0, 1` base cases (as in the odd-prime file), the `derangementBlockSum_split`
grouping, the uniform `term_ge3_dvd_two_pow` bound (all `L`), and `term_all2_pair_dvd` /
`term_all2_dvd_two_pow_of_j_ge3` for the "all cycles `= 2`" part. -/
theorem blockPermSum_two_dvd_sub_W1_pow (r : ℕ) (hr : 3 ≤ r) :
    (2 : ℤ) ^ r ∣ blockPermSum 2 (Fin (2 ^ (r - 1))) - (blockWeight 2 1) ^ (2 ^ (r - 1)) := by
  set M := 2 ^ (r - 1) with hMdef
  have hM1 : 1 ≤ M := Nat.one_le_iff_ne_zero.mpr (pow_ne_zero _ (by norm_num))
  have hM4 : 4 ≤ M := by
    rw [hMdef]
    calc (4 : ℕ) = 2 ^ 2 := by norm_num
      _ ≤ 2 ^ (r - 1) := Nat.pow_le_pow_right (by norm_num) (by omega)
  rw [blockPermSum_eq_sum_L 2 M]
  have hsplit : ∑ L ∈ Finset.range (M + 1),
      ((M.choose L : ℤ) * (blockWeight 2 1) ^ (M - L) * derangementBlockSum 2 L)
      = (blockWeight 2 1) ^ M
        + ∑ L ∈ Finset.Ico 2 (M + 1),
            ((M.choose L : ℤ) * (blockWeight 2 1) ^ (M - L) * derangementBlockSum 2 L) := by
    rw [Finset.range_eq_Ico,
      ← Finset.sum_Ico_consecutive _ (show (0:ℕ) ≤ 2 by omega) (show (2:ℕ) ≤ M + 1 by omega)]
    have h01 : Finset.Ico (0:ℕ) 2 = {0, 1} := by decide
    rw [h01]
    rw [Finset.sum_insert (by decide), Finset.sum_singleton]
    have e0 : (M.choose 0 : ℤ) * (blockWeight 2 1) ^ (M - 0) * derangementBlockSum 2 0
        = (blockWeight 2 1) ^ M := by
      rw [derangementBlockSum_zero]
      simp
    have e1 : (M.choose 1 : ℤ) * (blockWeight 2 1) ^ (M - 1) * derangementBlockSum 2 1 = 0 := by
      rw [derangementBlockSum_one]
      ring
    rw [e0, e1]
    ring
  rw [hsplit]
  have hgoal : (blockWeight 2 1) ^ M + ∑ L ∈ Finset.Ico 2 (M + 1),
      ((M.choose L : ℤ) * (blockWeight 2 1) ^ (M - L) * derangementBlockSum 2 L)
      - (blockWeight 2 1) ^ M
      = ∑ L ∈ Finset.Ico 2 (M + 1),
          ((M.choose L : ℤ) * (blockWeight 2 1) ^ (M - L) * derangementBlockSum 2 L) := by
    ring
  rw [hgoal]
  have hsplitL : ∀ L ∈ Finset.Ico 2 (M + 1),
      (M.choose L : ℤ) * (blockWeight 2 1) ^ (M - L) * derangementBlockSum 2 L
      = (M.choose L : ℤ) * (blockWeight 2 1) ^ (M - L) * derangementBlockSumGe3 2 L
        + (M.choose L : ℤ) * (blockWeight 2 1) ^ (M - L) * derangementBlockSumAll2 2 L := by
    intro L _
    rw [derangementBlockSum_split]
    ring
  rw [Finset.sum_congr rfl hsplitL, Finset.sum_add_distrib]
  apply dvd_add
  · apply Finset.dvd_sum
    intro L hL
    rw [Finset.mem_Ico] at hL
    exact term_ge3_dvd_two_pow r L (by omega) (by omega) (by omega)
  · have hpartition : Finset.Ico 2 (M + 1)
        = ({2, 4} : Finset ℕ) ∪ (Finset.Ico 2 (M + 1) \ {2, 4}) := by
      rw [Finset.union_sdiff_of_subset]
      intro x hx
      simp only [Finset.mem_insert, Finset.mem_singleton] at hx
      rw [Finset.mem_Ico]
      rcases hx with rfl | rfl <;> omega
    rw [hpartition, Finset.sum_union Finset.disjoint_sdiff]
    apply dvd_add
    · have h24 : ∑ L ∈ ({2, 4} : Finset ℕ),
          ((M.choose L : ℤ) * (blockWeight 2 1) ^ (M - L) * derangementBlockSumAll2 2 L)
          = (M.choose 2 : ℤ) * (blockWeight 2 1) ^ (M - 2) * derangementBlockSumAll2 2 2
            + (M.choose 4 : ℤ) * (blockWeight 2 1) ^ (M - 4) * derangementBlockSumAll2 2 4 := by
        rw [Finset.sum_insert (by decide), Finset.sum_singleton]
      rw [h24]
      exact term_all2_pair_dvd r hr
    · apply Finset.dvd_sum
      intro L hL
      simp only [Finset.mem_sdiff, Finset.mem_Ico, Finset.mem_insert, Finset.mem_singleton] at hL
      obtain ⟨⟨hL2, hLM1⟩, hLne⟩ := hL
      rcases Nat.even_or_odd L with heven | hodd
      · obtain ⟨j, hj⟩ := heven
        have hj2 : L = 2 * j := by omega
        have hj3 : 3 ≤ j := by
          push Not at hLne
          omega
        rw [hj2]
        exact term_all2_dvd_two_pow_of_j_ge3 r j (by omega) hj3 (by omega)
      · have hzero : derangementBlockSumAll2 2 L = 0 := derangementBlockSumAll2_odd_eq_zero 2 L hodd
        rw [hzero, mul_zero]
        exact dvd_zero _

/-- **The `p = 2` lifting-the-exponent step**: `2^r ∣ 3^(2^(r-1)) - 1`, via `padicValNat`'s
`p = 2` even-exponent LTE lemma `padicValNat.pow_two_sub_one_ge` (applied to `x := 3`,
`n := 2^(r-1)`, giving `v_2(2^(r-1)) + 2 ≤ v_2(3^(2^(r-1)) - 1)`, i.e. `r + 1 ≤ v_2(...)`). -/
theorem lte_step_two (r : ℕ) (hr : 2 ≤ r) :
    (2 : ℤ) ^ r ∣ (3 : ℤ) ^ (2 ^ (r - 1)) - 1 := by
  set n := 2 ^ (r - 1) with hndef
  have hn0 : n ≠ 0 := by rw [hndef]; positivity
  have hn_even : Even n := ⟨2 ^ (r - 2), by
    rw [hndef]
    have heq : r - 1 = (r - 2) + 1 := by omega
    rw [heq, pow_succ]; ring⟩
  haveI : Fact (Nat.Prime 2) := ⟨Nat.prime_two⟩
  have hpvn : padicValNat 2 n = r - 1 := by
    rw [hndef]; exact padicValNat.prime_pow (r - 1)
  have hkey := padicValNat.pow_two_sub_one_ge (x := 3) (n := n) (by norm_num) (by decide) hn0 hn_even
  rw [hpvn] at hkey
  have hrle : r ≤ padicValNat 2 (3 ^ n - 1) := by omega
  have hdvd_nat : (2 : ℕ) ^ r ∣ 3 ^ n - 1 := by
    have h1 : 2 ^ (padicValNat 2 (3 ^ n - 1)) ∣ (3 ^ n - 1) := pow_padicValNat_dvd
    exact (pow_dvd_pow 2 hrle).trans h1
  have h3n_ge1 : 1 ≤ 3 ^ n := Nat.one_le_iff_ne_zero.mpr (by positivity)
  have hcast : ((3 ^ n - 1 : ℕ) : ℤ) = (3 : ℤ) ^ n - 1 := by
    rw [Nat.cast_sub h3n_ge1]; push_cast; ring
  rw [← hcast]
  exact_mod_cast hdvd_nat

/-- **Proposition 4.2 (`prop:primepower`), `p = 2`, `r ≥ 3`**: `a(2^r) ≡ 1 (mod 2^r)`.

**Fully proved.** Assembled exactly as `primepower_odd'`, but with the `p = 2`-specific pieces
above: `primepower_setup_reduction`, `XNH_eq_blockSum`, `blockPermSum_eq_sum_blockPermWeight`,
`blockPermSum_two_dvd_sub_W1_pow` (the valuation congruence `blockPermSum 2 (Fin M) ≡
(blockWeight 2 1)^M (mod 2^r)`, relying on `allTwoFilter_double_card_odd` for the `j=1,2`
cancellation), `blockWeight_one_eq` (`blockWeight 2 1 = 3`), and `lte_step_two` (`3^M ≡ 1
(mod 2^r)`). These telescope to `a(2^r) ≡ 1 (mod 2^r)`. -/
theorem primepower_two_large' (r : ℕ) (hr : 3 ≤ r) :
    (2 ^ r : ℤ) ∣ (a (2 ^ r) - 1) := by
  haveI : NeZero (2 ^ r) := ⟨pow_ne_zero r (by norm_num)⟩
  have hred := primepower_setup_reduction Nat.prime_two (by omega : 1 ≤ r) (N := 2 ^ r) rfl
  have hxnh := XNH_eq_blockSum Nat.prime_two (by omega : 1 ≤ r) (N := 2 ^ r) rfl
  have hbps := blockPermSum_eq_sum_blockPermWeight 2 (2 ^ (r - 1))
  have hval := blockPermSum_two_dvd_sub_W1_pow r hr
  have hw1 : blockWeight 2 1 = 3 := by
    have := blockWeight_one_eq 2 Nat.prime_two
    norm_num at this
    exact this
  have hlte := lte_step_two r (by omega)
  rw [hxnh, ← hbps] at hred
  rw [hw1] at hval
  push_cast at hred
  have heq : a (2 ^ r) - 1 = (a (2 ^ r) - blockPermSum 2 (Fin (2 ^ (r - 1))))
